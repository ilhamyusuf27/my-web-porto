---
import { profile } from "../../data/profile";

const navItems = [
  { id: "about", label: "Profile" },
  { id: "skills", label: "Capabilities" },
  { id: "experience", label: "Experience" },
  { id: "projects", label: "Work" },
  { id: "contact", label: "Contact" },
];
---

<nav class="nav" aria-label="Primary navigation">
  <a class="nav__brand" href="#hero" aria-label={`${profile.name} — back to start`}>
    <span>{profile.name}</span>
    <small>Frontend developer</small>
  </a>

  <ul class="nav__links" role="list">
    {navItems.map((item) => (
      <li>
        <a href={`#${item.id}`} data-hud-item={item.id}>{item.label}</a>
      </li>
    ))}
  </ul>

  <a class="nav__availability" href="#contact">
    <span aria-hidden="true"></span>
    Available
  </a>
</nav>

<style>
  :global(html[data-modal-open]) .nav {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 9400;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
    min-height: 76px;
    padding: 0 clamp(1.25rem, 4vw, 4.5rem);
    color: #f5f5f5;
    background: rgba(5, 5, 5, 0.88);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(14px);
  }

  .nav__brand { display: flex; align-items: baseline; gap: .8rem; width: max-content; }
  .nav__brand span { font-weight: 600; letter-spacing: -.03em; }
  .nav__brand small { color: #777; font-family: var(--font-mono); font-size: .62rem; }
  .nav__links { display: flex; align-items: center; gap: clamp(1rem, 2.4vw, 2.2rem); margin: 0; padding: 0; list-style: none; }
  .nav__links a { position: relative; color: #777; font-size: .78rem; transition: color 400ms cubic-bezier(.32,.72,0,1); }
  .nav__links a::after { content: ""; position: absolute; left: 0; right: 0; bottom: -.55rem; height: 1px; background: #f5f5f5; transform: scaleX(0); transform-origin: right; transition: transform 500ms cubic-bezier(.32,.72,0,1); }
  .nav__links a:hover, .nav__links a:focus-visible, .nav__links a.is-active { color: #f5f5f5; }
  .nav__links a:hover::after, .nav__links a:focus-visible::after, .nav__links a.is-active::after { transform: scaleX(1); transform-origin: left; }
  .nav__availability { justify-self: end; display: inline-flex; align-items: center; gap: .55rem; font-family: var(--font-mono); font-size: .66rem; text-transform: uppercase; letter-spacing: .08em; }
  .nav__availability span { width: 6px; height: 6px; border-radius: 50%; background: #cba6f7; box-shadow: 0 0 0 4px rgba(203,166,247,.1); }

  @media (max-width: 820px) {
    .nav { grid-template-columns: 1fr auto; min-height: 64px; }
    .nav__links, .nav__brand small { display: none; }
  }
</style>
