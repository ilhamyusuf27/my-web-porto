---
import Section from "../layout/Section.astro";

const capabilityModules = [
  {
    title: "Frontend systems",
    label: "Daily practice",
    summary: "Responsive application interfaces, reusable components, typed state, and UI architecture built to stay maintainable.",
    tools: ["React", "Vue", "TypeScript", "SCSS", "Tailwind", "Git"],
  },
  {
    title: "Client delivery",
    label: "Production work",
    summary: "Content-managed and commerce websites shaped for practical editing, handoff, performance, and long-term client use.",
    tools: ["WordPress", "Elementor", "WooCommerce", "ACF", "WPML", "Custom themes"],
  },
  {
    title: "Backend integration",
    label: "Fullstack range",
    summary: "Product APIs, data flows, authentication states, and persistence work that connect interfaces to real application behavior.",
    tools: ["Node.js", "NestJS", "Prisma", "PostgreSQL", "REST"],
  },
  {
    title: "Interface motion",
    label: "Interaction craft",
    summary: "Purposeful transitions and rendering experiments that clarify state changes without competing with the content.",
    tools: ["GSAP", "Three.js", "Canvas", "Framer Motion"],
  },
  {
    title: "Reliability practice",
    label: "Current direction",
    summary: "Deployment hygiene, Linux workflows, automation, and observability fundamentals that make delivery more dependable.",
    tools: ["Docker", "Linux", "CI/CD", "Cloudflare", "Monitoring / SRE"],
  },
];

const marqueeTools = capabilityModules.flatMap((module) => module.tools);
---

<Section id="skills" label="Expertise" index="02" class="section--capabilities">
  <div class="capabilities" data-reveal data-capabilities>
    <header class="capabilities__intro" data-capability-intro>
      <div class="capabilities__sticky">
        <h2>Built across<br />the product stack.</h2>
        <p>
          Frontend-led, with enough backend and delivery range to understand
          how the complete system fits together.
        </p>
        <span class="capabilities__hint">Scroll through capabilities</span>
      </div>
    </header>

    <div class="capabilities__ledger">
      {capabilityModules.map((module) => (
        <article class="capability-row" data-capability-row>
          <header>
            <span>{module.label}</span>
            <i aria-hidden="true"></i>
          </header>
          <h3>{module.title}</h3>
          <p>{module.summary}</p>
          <ul role="list" aria-label={`${module.title} tools`}>
            {module.tools.map((tool) => <li>{tool}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>

  <div class="capabilities__marquee" aria-hidden="true">
    <div>
      {[...marqueeTools, ...marqueeTools].map((tool) => (
        <span>{tool}</span>
      ))}
    </div>
  </div>
</Section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const desktop = window.matchMedia("(min-width: 901px)").matches;
  const root = document.querySelector<HTMLElement>("[data-capabilities]");

  if (root && !reduceMotion) {
    const rows = gsap.utils.toArray<HTMLElement>("[data-capability-row]", root);

    rows.forEach((row) => {
      gsap.fromTo(
        row,
        { autoAlpha: 0.22, x: desktop ? 72 : 24, scale: 0.985 },
        {
          autoAlpha: 1,
          x: 0,
          scale: 1,
          ease: "none",
          scrollTrigger: {
            trigger: row,
            start: "top 86%",
            end: "top 44%",
            scrub: 0.55,
          },
        }
      );
    });

  }
</script>

<style>
  :global(.section--capabilities) {
    min-height: 170dvh;
    align-items: start;
    padding-bottom: 0 !important;
  }

  .capabilities {
    display: grid;
    grid-template-columns: minmax(320px, .82fr) minmax(0, 1.18fr);
    gap: clamp(4rem, 10vw, 10rem);
    align-items: start;
  }

  .capabilities__intro {
    position: sticky;
    top: 90px;
    align-self: start;
    min-height: calc(100dvh - 11rem);
  }
  .capabilities__sticky { display: grid; align-content: center; min-height: calc(100dvh - 11rem); }
  .capabilities__intro h2 { max-width: 750px; }
  .capabilities__intro p { max-width: 38ch; margin-top: 2rem; color: #858585; font-size: clamp(1rem, 1.5vw, 1.18rem); line-height: 1.65; }
  .capabilities__hint { display: inline-flex; align-items: center; gap: .65rem; margin-top: clamp(3rem, 9vh, 6rem); color: #5f5f5f; font-family: var(--font-mono) !important; font-size: .62rem; letter-spacing: .08em; text-transform: uppercase; }
  .capabilities__hint::before { content: ""; width: 2.2rem; height: 1px; background: #444; }

  .capabilities__ledger { border-top: 1px solid #2a2a2a; }
  .capability-row { min-height: clamp(340px, 52vh, 500px); display: flex; flex-direction: column; justify-content: center; padding: clamp(2rem, 5vw, 4rem) 0; border-bottom: 1px solid #2a2a2a; transform-origin: 0 50%; }
  .capability-row header { display: flex; align-items: center; gap: 1rem; color: #666; font-family: var(--font-mono); font-size: .63rem; letter-spacing: .08em; text-transform: uppercase; }
  .capability-row header span { font-family: var(--font-mono) !important; }
  .capability-row header i { flex: 1; height: 1px; background: #202020; transition: background 500ms cubic-bezier(.32,.72,0,1); }
  .capability-row h3 { max-width: 14ch; margin-top: clamp(2rem, 5vh, 3.5rem); font-size: clamp(2.8rem, 5.5vw, 6rem); line-height: .92; letter-spacing: -.065em; }
  .capability-row p { max-width: 54ch; margin-top: 1.35rem; color: #777; font-size: .95rem; line-height: 1.65; }
  .capability-row ul { display: flex; flex-wrap: wrap; gap: .5rem 1.2rem; margin: auto 0 0; padding: clamp(2rem, 6vh, 4rem) 0 0; list-style: none; }
  .capability-row li { position: relative; color: #999; font-family: var(--font-mono) !important; font-size: .67rem; }
  .capability-row li:not(:last-child)::after { content: "/"; position: absolute; left: calc(100% + .55rem); color: #3d3d3d; }
  .capability-row:hover header i { background: #6e5a82; }
  .capability-row:hover h3 { color: #fff; }

  .capabilities__marquee { width: 100vw; margin-top: clamp(5rem, 10vh, 8rem); margin-left: calc(50% - 50vw); overflow: hidden; border-top: 1px solid #222; border-bottom: 1px solid #222; }
  .capabilities__marquee > div { display: flex; width: max-content; animation: capability-marquee 42s linear infinite; }
  .capabilities__marquee span { display: inline-flex; align-items: center; min-height: 4.5rem; padding-inline: 1.8rem; color: #494949; font-size: clamp(1rem, 1.6vw, 1.35rem); letter-spacing: -.025em; white-space: nowrap; }
  .capabilities__marquee span::after { content: ""; width: 4px; height: 4px; margin-left: 3.6rem; border-radius: 50%; background: #6e5a82; }
  @keyframes capability-marquee { to { transform: translateX(-50%); } }

  @media (max-width: 900px) {
    :global(.section--capabilities) { min-height: 100dvh; }
    .capabilities { grid-template-columns: 1fr; gap: 4rem; }
    .capabilities__intro { position: static; top: auto; }
    .capabilities__intro, .capabilities__sticky { min-height: 0; }
    .capabilities__hint { display: none; }
    .capability-row { min-height: 0; padding-block: 3.5rem; }
    .capability-row h3 { font-size: clamp(2.6rem, 12vw, 4.8rem); }
  }

  @media (prefers-reduced-motion: reduce) {
    .capabilities__marquee > div { animation: none; }
  }
</style>
