---
import Section from "../layout/Section.astro";
import { profile } from "../../data/profile";

const principles = [
  {
    title: "Build for the next change",
    text: "Structure components and decisions so the next developer can extend the work without reverse engineering it.",
  },
  {
    title: "Design the whole workflow",
    text: "Account for APIs, product states, content operations, and the people who use the system every day.",
  },
  {
    title: "Expand without losing depth",
    text: "Keep frontend as the core while growing the backend and reliability skills needed to deliver complete products.",
  },
];
---

<Section id="about" label="Operator Profile" index="01" accent="mauve" class="section--profile-editorial">
  <div class="profile-story" data-profile-story>
    <header class="profile-story__intro">
      <div class="profile-story__portrait" data-profile-portrait>
        <img
          src={profile.avatar}
          alt={`Portrait of ${profile.name}`}
          loading="lazy"
          decoding="async"
        />
        <div class="profile-story__identity">
          <span>@{profile.callsign}</span>
          <strong>{profile.name}</strong>
        </div>
      </div>

      <div class="profile-story__statement">
        <h2 id="about-title">
          I build interfaces that stay clear
          <span>after the handoff.</span>
        </h2>
        <p>{profile.intro}</p>
      </div>
    </header>

    <div class="profile-story__context" data-profile-context>
      <dl aria-label="Profile context">
        <div>
          <dt>Based in</dt>
          <dd>{profile.location}</dd>
        </div>
        <div>
          <dt>Primary role</dt>
          <dd>{profile.role}</dd>
        </div>
        <div>
          <dt>Current direction</dt>
          <dd>Production-minded delivery</dd>
        </div>
        <div>
          <dt>Availability</dt>
          <dd>{profile.availability}</dd>
        </div>
      </dl>
    </div>

    <section class="profile-story__principles" aria-label="Working principles">
      {principles.map((principle, index) => (
        <article data-profile-principle>
          <span aria-hidden="true">{String(index + 1).padStart(2, "0")}</span>
          <h3>{principle.title}</h3>
          <p>{principle.text}</p>
        </article>
      ))}
    </section>
  </div>
</Section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const root = document.querySelector<HTMLElement>("[data-profile-story]");
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (root && !reduceMotion) {
    const portrait = root.querySelector<HTMLElement>("[data-profile-portrait]");
    const portraitImage = portrait?.querySelector<HTMLElement>("img");
    const identity = portrait?.querySelector<HTMLElement>(".profile-story__identity");
    const statementTitle = root.querySelector<HTMLElement>(".profile-story__statement h2");
    const statementCopy = root.querySelector<HTMLElement>(".profile-story__statement > p");
    const context = root.querySelector<HTMLElement>("[data-profile-context]");
    const contextCells = context?.querySelectorAll<HTMLElement>("dl > div") ?? [];
    const principles = gsap.utils.toArray<HTMLElement>("[data-profile-principle]", root);

    const intro = gsap.timeline({
      scrollTrigger: { trigger: root, start: "top 68%", once: true },
    });

    intro
      .fromTo(
        portrait,
        { autoAlpha: 0, x: -46, clipPath: "inset(0 100% 0 0)" },
        { autoAlpha: 1, x: 0, clipPath: "inset(0 0% 0 0)", duration: 1.05, ease: "power4.out" }
      )
      .fromTo(portraitImage, { scale: 1.14 }, { scale: 1.015, duration: 1.3, ease: "power3.out" }, "<")
      .fromTo(identity, { autoAlpha: 0, y: 28 }, { autoAlpha: 1, y: 0, duration: .65, ease: "power3.out" }, "-=.55")
      .fromTo(
        statementTitle,
        { autoAlpha: 0, y: 74, clipPath: "inset(0 0 100% 0)" },
        { autoAlpha: 1, y: 0, clipPath: "inset(0 0 0% 0)", duration: 1, ease: "power4.out" },
        "-=.62"
      )
      .fromTo(
        statementCopy,
        { autoAlpha: 0, y: 28 },
        { autoAlpha: 1, y: 0, duration: .68, ease: "power3.out" },
        "-=.48"
      )
      .fromTo(context, { autoAlpha: 0, scaleX: .72, transformOrigin: "left center" }, { autoAlpha: 1, scaleX: 1, duration: .72, ease: "power3.out" }, "-=.38")
      .fromTo(contextCells, { autoAlpha: 0, y: 18 }, { autoAlpha: 1, y: 0, duration: .5, stagger: .065, ease: "power2.out" }, "-=.3");

    if (portraitImage) {
      gsap.to(portraitImage, {
        yPercent: 5,
        ease: "none",
        scrollTrigger: {
          trigger: root,
          start: "top bottom",
          end: "bottom top",
          scrub: 1.1,
        },
      });
    }

    gsap.fromTo(principles, { autoAlpha: 0, x: (index) => index % 2 === 0 ? -34 : 34, y: 28 }, {
      autoAlpha: 1,
      x: 0,
      y: 0,
      duration: .78,
      stagger: .11,
      ease: "power3.out",
      scrollTrigger: { trigger: principles[0], start: "top 88%", once: true },
    });
  }
</script>

<style>
  :global(.section--profile-editorial) {
    min-height: 145dvh;
    padding-block: clamp(8rem, 14vh, 12rem) clamp(10rem, 18vh, 15rem) !important;
  }
  .profile-story { display: grid; gap: clamp(5rem, 11vh, 9rem); }
  .profile-story__intro { display: grid; grid-template-columns: minmax(240px, .62fr) minmax(0, 1.38fr); gap: clamp(3rem, 9vw, 9rem); align-items: end; }
  .profile-story__portrait { position: relative; min-height: clamp(420px, 62vh, 680px); margin: 0; overflow: hidden; background: var(--surface-panel-soft); }
  .profile-story__portrait::after { content: ""; position: absolute; inset: 0; background: linear-gradient(to top, rgba(7,7,7,.88), transparent 42%); pointer-events: none; }
  .profile-story__portrait img { width: 100%; height: 100%; position: absolute; inset: 0; object-fit: cover; filter: grayscale(1) contrast(1.04) brightness(.78); transform: scale(1.015); transition: filter .65s ease, transform .8s cubic-bezier(.16,1,.3,1); }
  .profile-story__portrait:hover img { filter: grayscale(.25) contrast(1.02) brightness(.88); transform: scale(1.04); }
  .profile-story__identity { position: absolute; z-index: 1; left: clamp(1.25rem, 3vw, 2.5rem); right: clamp(1.25rem, 3vw, 2.5rem); bottom: clamp(1.25rem, 3vw, 2.5rem); display: grid; gap: .45rem; }
  .profile-story__identity span { color: #b795d9; font-family: var(--font-mono); font-size: .66rem; }
  .profile-story__identity strong { color: #eee; font-size: clamp(1.8rem, 3.5vw, 3.5rem); font-weight: 500; letter-spacing: -.055em; }
  .profile-story__statement { display: grid; gap: 2rem; padding-bottom: clamp(0rem, 4vh, 3rem); }
  .profile-story__statement h2 { max-width: 11ch; font-size: clamp(4.2rem, 8vw, 8.5rem); line-height: .84; letter-spacing: -.075em; }
  .profile-story__statement h2 span { display: block; color: #a1aabc; font-weight: 400; }
  .profile-story__statement > p { max-width: 48ch; color: #bac2cf; font-size: clamp(1rem, 1.35vw, 1.15rem); line-height: 1.65; }
  .profile-story__context { padding-block: 1.4rem; border-top: 1px solid var(--divider-line-strong); border-bottom: 1px solid var(--divider-line); }
  .profile-story__context dl { display: grid; grid-template-columns: .75fr .8fr 1fr 1.25fr; gap: 2rem; margin: 0; }
  .profile-story__context div { display: grid; gap: .65rem; }
  .profile-story__context dt { color: #949eb1; font-family: var(--font-mono); font-size: .61rem; letter-spacing: .08em; text-transform: uppercase; }
  .profile-story__context dd { margin: 0; color: #cbd0d9; font-size: .82rem; line-height: 1.45; }
  .profile-story__principles { display: grid; grid-template-columns: repeat(12, minmax(0,1fr)); gap: clamp(2rem, 5vw, 5rem); }
  .profile-story__principles article { grid-column: span 4; display: grid; align-content: start; gap: 1.25rem; padding-top: 1.25rem; border-top: 1px solid var(--divider-line); }
  .profile-story__principles article { transition: transform .4s cubic-bezier(.16,1,.3,1), border-color .3s ease; }
  .profile-story__principles article:hover { transform: translateY(-6px); border-color: #745e87; }
  .profile-story__principles article:nth-child(2) { margin-top: clamp(2rem, 7vh, 5rem); }
  .profile-story__principles article:nth-child(3) { margin-top: clamp(4rem, 14vh, 10rem); }
  .profile-story__principles article > span { color: #b99bd3; font-family: var(--font-mono); font-size: .62rem; }
  .profile-story__principles h3 { max-width: 13ch; font-size: clamp(1.7rem, 3vw, 3rem); line-height: 1; letter-spacing: -.05em; }
  .profile-story__principles p { max-width: 36ch; color: #a3acbe; font-size: .88rem; line-height: 1.65; }
  @media (max-width: 800px) {
    :global(.section--profile-editorial) { min-height: 100dvh; padding-block: 7rem 10rem !important; }
    .profile-story__intro { grid-template-columns: 1fr; }
    .profile-story__portrait { min-height: min(70dvh, 620px); }
    .profile-story__statement h2 { font-size: clamp(3.7rem, 15vw, 7rem); }
    .profile-story__context dl { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .profile-story__principles { grid-template-columns: 1fr; }
    .profile-story__principles article, .profile-story__principles article:nth-child(n) { grid-column: 1; margin-top: 0; }
  }
  @media (max-width: 480px) {
    .profile-story__context dl { grid-template-columns: 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    .profile-story__portrait img, .profile-story__principles article { transition: none; }
    .profile-story__portrait:hover img { transform: none; }
    .profile-story__principles article:hover { transform: none; }
  }
</style>
