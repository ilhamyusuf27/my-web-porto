---
import Section from "../layout/Section.astro";
import PixelButton from "../ui/PixelButton.astro";
import Icon from "../ui/Icon.astro";
import { socials, resumeUrl } from "../../data/socials";
import { profile } from "../../data/profile";

const email = socials.find((s) => s.id === "email");
const otherSocials = socials.filter((s) => s.id !== "email");
---

<Section id="contact" label="Contact" index="08" accent="mauve" class="section--dense">
  <div class="contact">
    <div class="contact__main" data-reveal>
      <span class="contact__signal">
        <span class="contact__signal-dot" />
        signal open
      </span>

      <h2 class="contact__title">Get in touch</h2>
      <p class="contact__copy">
        Thanks for reading through the portfolio. If you need a frontend developer
        who can also own backend and reliability work, I'd be glad to talk.
      </p>

      <div class="contact__actions">
        {email && (
          <PixelButton
            href={email.url}
            icon="mdi:send"
            variant="primary"
            class="contact__email-btn"
          >
            Send a transmission
          </PixelButton>
        )}
        <PixelButton href={resumeUrl} iconRight="mdi:download" variant="ghost" target="_blank" rel="noreferrer">
          Download CV
        </PixelButton>
      </div>

      <ul class="contact__links" role="list">
        {
          otherSocials.map((social) => (
            <li>
              <a
                class="contact__link"
                href={social.url}
                target={social.id === "email" ? undefined : "_blank"}
                rel="noreferrer"
              >
                <Icon name={social.icon} size={18} />
                <span class="contact__link-text">
                  <strong>{social.label}</strong>
                  <small>{social.handle}</small>
                </span>
                <Icon name="mdi:open-in-new" size={14} class="contact__link-ext" />
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="contact__launch" aria-hidden="true" data-reveal>
      <div class="contact__launch-pad">
        <span class="contact__rocket">
          <Icon name="mdi:rocket-launch" size={56} />
        </span>
        <span class="contact__trail" />
        <span class="contact__pad" />
      </div>
      <p class="contact__callsign">end of transmission - {profile.callsign}.dev</p>
    </div>
  </div>
</Section>

<style>
  .contact {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(220px, 0.75fr);
    gap: clamp(1rem, 3vw, 2rem);
    align-items: center;
  }

  .contact__signal {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--mauve);
    background: var(--mantle);
    border: 1px solid rgba(203, 166, 247, 0.42);
    padding: 0.3rem 0.55rem;
    margin-bottom: 0.75rem;
  }

  .contact__signal-dot {
    width: 7px;
    height: 7px;
    background: var(--mauve);
    box-shadow: none;
    animation: pulse 1.4s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .contact__title {
    font-size: clamp(2rem, 6vw, 3.5rem);
    margin-bottom: 0.55rem;
  }

  .contact__copy {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--subtext-1);
    max-width: 48ch;
    margin-bottom: 1.1rem;
  }

  .contact__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.1rem;
  }

  .contact__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.75rem;
  }

  .contact__link {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    background: var(--bg-card);
    border: 1px solid var(--border-dim);
    box-shadow: 3px 3px 0 rgba(17, 17, 27, 0.75);
    padding: 0.65rem 0.85rem;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }

  .contact__link:hover {
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 rgba(17, 17, 27, 0.8), 0 0 0 1px rgba(203, 166, 247, 0.34);
  }

  .contact__link :global(svg:first-child) {
    color: var(--mauve);
    flex: none;
  }

  .contact__link-text {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .contact__link-text strong {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--text);
  }

  .contact__link-text small {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--subtext-0);
  }

  .contact__link-ext {
    color: var(--overlay-0);
  }

  .contact__launch {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .contact__launch-pad {
    position: relative;
    width: 100%;
    max-width: 210px;
    height: 210px;
    display: grid;
    place-items: center;
  }

  .contact__rocket {
    color: var(--mauve);
    filter: drop-shadow(0 0 6px rgba(203, 166, 247, 0.14));
    animation: launch 3.5s ease-in-out infinite;
  }

  @keyframes launch {
    0%, 15% { transform: translateY(20px) rotate(-8deg); }
    55%, 70% { transform: translateY(-30px) rotate(6deg); }
    100% { transform: translateY(20px) rotate(-8deg); }
  }

  .contact__trail {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translateX(-50%);
    width: 6px;
    height: 80px;
    background: linear-gradient(to bottom, var(--mauve), transparent);
    opacity: 0.32;
    animation: trail 3.5s ease-in-out infinite;
  }

  @keyframes trail {
    0%, 15% { opacity: 0; height: 0; }
    30%, 60% { opacity: 0.7; height: 80px; }
    100% { opacity: 0; height: 0; }
  }

  .contact__pad {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    width: 100px;
    height: 14px;
    background: repeating-linear-gradient(90deg, rgba(88, 91, 112, 0.82) 0 8px, rgba(69, 71, 90, 0.72) 8px 16px);
    border: 1px solid var(--border-dim);
  }

  .contact__callsign {
    font-family: var(--font-pixel);
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--subtext-0);
    text-align: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .contact__rocket,
    .contact__trail,
    .contact__signal-dot {
      animation: none;
    }
  }

  @media (max-width: 860px) {
    .contact {
      grid-template-columns: 1fr;
    }

    .contact__launch {
      order: -1;
    }

    .contact__launch-pad {
      height: 160px;
    }
  }
</style>
