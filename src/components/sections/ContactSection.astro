---
import Section from "../layout/Section.astro";
import Icon from "../ui/Icon.astro";
import { socials, resumeUrl } from "../../data/socials";
import { profile } from "../../data/profile";

const email = socials.find((social) => social.id === "email");
const channelLinks = socials.filter((social) => social.id !== "email");
---

<Section id="contact" label="Contact" index="07" accent="mauve" class="section--contact-final">
  <div class="handshake" data-handshake>
    <header class="handshake__header">
      <div class="handshake__availability">
        <span aria-hidden="true"></span>
        {profile.availability}
      </div>
      <p>Frontend engineering, full-stack delivery, and reliability-minded product work.</p>
    </header>

    <main class="handshake__main">
      <h2 id="contact-title">Let’s build<br />something <span>reliable.</span></h2>

      {email && (
        <a class="handshake__email" href={email.url} data-contact-email>
          <span>Start a conversation</span>
          <strong>{email.handle}</strong>
          <span class="handshake__arrow" aria-hidden="true">
            <Icon name="mdi:arrow-top-right" size={30} />
          </span>
        </a>
      )}
    </main>

    <footer class="handshake__footer">
      <nav aria-label="Contact channels">
        <ul role="list">
          {channelLinks.map((social) => (
            <li>
              <a href={social.url} target="_blank" rel="noreferrer">
                <Icon name={social.icon} size={18} aria-hidden="true" />
                <span>{social.label}</span>
                <small>{social.handle}</small>
              </a>
            </li>
          ))}
          <li>
            <a href={resumeUrl} target="_blank" rel="noreferrer">
              <Icon name="mdi:file-download-outline" size={18} aria-hidden="true" />
              <span>Resume</span>
              <small>Download PDF</small>
            </a>
          </li>
        </ul>
      </nav>

      <div class="handshake__meta">
        <span>Indonesia, GMT+7</span>
        <span>Open to remote collaboration</span>
      </div>
    </footer>
  </div>
</Section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const root = document.querySelector<HTMLElement>("[data-handshake]");
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (root && !reduceMotion) {
    const titleLines = root.querySelectorAll<HTMLElement>(".handshake__main h2, .handshake__header > *");
    const email = root.querySelector<HTMLElement>("[data-contact-email]");
    const footerItems = root.querySelectorAll<HTMLElement>(".handshake__footer li, .handshake__meta span");

    const timeline = gsap.timeline({
      scrollTrigger: { trigger: root, start: "top 72%", once: true },
    });

    timeline
      .fromTo(titleLines, { autoAlpha: 0, y: 72 }, { autoAlpha: 1, y: 0, duration: .9, stagger: .08, ease: "power3.out" })
      .fromTo(email, { autoAlpha: 0, scaleX: .72, transformOrigin: "left center" }, { autoAlpha: 1, scaleX: 1, duration: .72, ease: "power3.out" }, "-=.45")
      .fromTo(footerItems, { autoAlpha: 0, y: 24 }, { autoAlpha: 1, y: 0, duration: .55, stagger: .05, ease: "power2.out" }, "-=.3");
  }
</script>

<style>
  :global(.section--contact-final) { min-height: 100dvh; padding-block: clamp(8rem, 14vh, 11rem) max(5rem, var(--dock-clearance)) !important; }
  .handshake { min-height: min(760px, calc(100dvh - 12rem)); display: grid; grid-template-rows: auto 1fr auto; gap: clamp(4rem, 9vh, 7rem); }
  .handshake__header { display: flex; justify-content: space-between; gap: 2rem; align-items: start; }
  .handshake__availability { display: inline-flex; align-items: center; gap: .65rem; color: #b795d9; font-family: var(--font-mono); font-size: .65rem; letter-spacing: .08em; text-transform: uppercase; }
  .handshake__availability > span { width: 7px; height: 7px; background: #cba6f7; animation: signal 2.4s ease-in-out infinite; }
  .handshake__header > p { max-width: 39ch; color: #a3acbe; line-height: 1.6; }
  .handshake__main { display: grid; align-content: center; gap: clamp(3rem, 7vh, 5rem); }
  .handshake h2 { max-width: 12ch; font-size: clamp(4rem, 9.2vw, 9.5rem); line-height: .84; letter-spacing: -.075em; }
  .handshake h2 span { color: #a7b0c1; font-weight: 400; }
  .handshake__email { position: relative; display: grid; grid-template-columns: minmax(170px, .35fr) minmax(0, 1fr) auto; gap: 2rem; align-items: center; padding: 1.5rem 0; border-top: 1px solid var(--divider-line-strong); border-bottom: 1px solid var(--divider-line); transition: padding .35s cubic-bezier(.16,1,.3,1), border-color .35s ease; }
  .handshake__email > span:first-child { color: #a3acbe; font-family: var(--font-mono); font-size: .65rem; letter-spacing: .08em; text-transform: uppercase; }
  .handshake__email strong { min-width: 0; overflow: hidden; color: #e7e7e7; font-size: clamp(1.35rem, 3.1vw, 3rem); font-weight: 500; letter-spacing: -.04em; text-overflow: ellipsis; white-space: nowrap; }
  .handshake__arrow { display: grid; place-items: center; width: 3.5rem; height: 3.5rem; color: #cba6f7; border: 1px solid #463c50; transition: transform .35s cubic-bezier(.16,1,.3,1), background .35s ease, color .35s ease; }
  .handshake__email:hover, .handshake__email:focus-visible { padding-inline: 1.25rem; border-color: #8d70aa; outline: none; }
  .handshake__email:hover .handshake__arrow, .handshake__email:focus-visible .handshake__arrow { color: #111; background: #cba6f7; transform: rotate(8deg); }
  .handshake__email:active .handshake__arrow { transform: scale(.96); }
  .handshake__footer { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 3rem; align-items: end; padding-top: 2rem; border-top: 1px solid var(--divider-line); }
  .handshake__footer ul { display: flex; flex-wrap: wrap; gap: 1rem 2.5rem; margin: 0; padding: 0; list-style: none; }
  .handshake__footer a { display: grid; grid-template-columns: auto auto; gap: .18rem .6rem; align-items: center; color: #d0d5de; transition: color .25s ease, transform .25s cubic-bezier(.16,1,.3,1); }
  .handshake__footer a:hover, .handshake__footer a:focus-visible { color: #e9e9e9; transform: translateY(-2px); outline: none; }
  .handshake__footer a :global(svg) { grid-row: 1 / span 2; color: #a786c6; }
  .handshake__footer a span { font-size: .85rem; font-weight: 600; }
  .handshake__footer a small { color: #929bad; font-family: var(--font-mono); font-size: .62rem; }
  .handshake__meta { display: grid; gap: .55rem; justify-items: end; color: #929bad; font-family: var(--font-mono); font-size: .62rem; text-transform: uppercase; letter-spacing: .06em; }
  @keyframes signal { 0%,100% { opacity: .45; transform: scale(.8); } 50% { opacity: 1; transform: scale(1); } }
  @media (max-width: 760px) {
    :global(.section--contact-final) { padding-block: 7rem max(6rem, var(--dock-clearance)) !important; }
    .handshake { min-height: auto; }
    .handshake__header { display: grid; }
    .handshake h2 { font-size: clamp(3.8rem, 18vw, 6rem); }
    .handshake__email { grid-template-columns: 1fr auto; gap: 1rem; }
    .handshake__email > span:first-child { grid-column: 1 / -1; }
    .handshake__email strong { font-size: clamp(1rem, 5vw, 1.5rem); }
    .handshake__footer { grid-template-columns: 1fr; }
    .handshake__footer ul { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); }
    .handshake__meta { justify-items: start; }
  }
  @media (prefers-reduced-motion: reduce) {
    .handshake__availability > span { animation: none; opacity: 1; }
    .handshake__email, .handshake__arrow, .handshake__footer a { transition: none; }
  }
</style>
