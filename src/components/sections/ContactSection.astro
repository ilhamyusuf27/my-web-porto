---
import Section from "../layout/Section.astro";
import PixelButton from "../ui/PixelButton.astro";
import Icon from "../ui/Icon.astro";
import { socials, resumeUrl } from "../../data/socials";
import { profile } from "../../data/profile";

const email = socials.find((s) => s.id === "email");
const otherSocials = socials.filter((s) => s.id !== "email");
---

<Section id="contact" label="Contact" index="08" accent="mauve" class="section--dense">
  <div class="contact">
    <div class="contact__main" data-reveal>
      <span class="contact__signal">
        <span class="contact__signal-dot" />
        signal open
      </span>

      <h2 class="contact__title">Get in touch</h2>
      <p class="contact__copy">
        Thanks for reading through the portfolio. If you need a frontend developer
        who can also own backend and reliability work, I'd be glad to talk.
      </p>

      <div class="contact__actions">
        {email && (
          <PixelButton
            href={email.url}
            icon="mdi:send"
            variant="primary"
            class="contact__email-btn"
          >
            Send a transmission
          </PixelButton>
        )}
        <PixelButton href={resumeUrl} iconRight="mdi:download" variant="ghost" target="_blank" rel="noreferrer">
          Download CV
        </PixelButton>
      </div>

      <ul class="contact__links" role="list">
        {
          otherSocials.map((social) => (
            <li>
              <a
                class="contact__link"
                href={social.url}
                target={social.id === "email" ? undefined : "_blank"}
                rel="noreferrer"
              >
                <Icon name={social.icon} size={18} />
                <span class="contact__link-text">
                  <strong>{social.label}</strong>
                  <small>{social.handle}</small>
                </span>
                <Icon name="mdi:open-in-new" size={14} class="contact__link-ext" />
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <aside class="contact__aside" data-reveal>
      <div class="contact__panel">
        <h3 class="contact__panel-title">
          <Icon name="mdi:at" size={18} />
          Direct
        </h3>

        {
          email && (
            <a class="contact__email" href={email.url}>
              {email.handle}
            </a>
          )
        }

        <dl class="contact__facts">
          <div>
            <dt>Status</dt>
            <dd>{profile.availability}</dd>
          </div>
          <div>
            <dt>Location</dt>
            <dd>{profile.location}</dd>
          </div>
          <div>
            <dt>Focus</dt>
            <dd>{profile.role}</dd>
          </div>
        </dl>
      </div>

      <p class="contact__callsign">end of transmission · {profile.callsign}.dev</p>
    </aside>
  </div>
</Section>

<style>
  .contact {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(240px, 0.9fr);
    gap: clamp(1.25rem, 3vw, 2.25rem);
    align-items: stretch;
  }

  .contact__main {
    display: flex;
    flex-direction: column;
  }

  .contact__signal {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    width: fit-content;
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--mauve);
    background: var(--mantle);
    border: 1px solid rgba(203, 166, 247, 0.42);
    padding: 0.3rem 0.55rem;
    margin-bottom: 0.85rem;
  }

  .contact__signal-dot {
    width: 7px;
    height: 7px;
    background: var(--mauve);
    animation: pulse 1.4s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .contact__title {
    font-size: clamp(2rem, 6vw, 3.25rem);
    line-height: 1.05;
    margin-bottom: 0.65rem;
  }

  .contact__copy {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--subtext-1);
    max-width: 46ch;
    margin-bottom: 1.25rem;
  }

  .contact__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-bottom: 1.25rem;
  }

  .contact__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.6rem;
  }

  .contact__link {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    background: var(--bg-card);
    border: 1px solid var(--border-dim);
    box-shadow: 3px 3px 0 rgba(17, 17, 27, 0.75);
    padding: 0.65rem 0.85rem;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }

  .contact__link:hover {
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 rgba(17, 17, 27, 0.8), 0 0 0 1px rgba(203, 166, 247, 0.34);
  }

  .contact__link :global(svg:first-child) {
    color: var(--mauve);
    flex: none;
  }

  .contact__link-text {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .contact__link-text strong {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--text);
  }

  .contact__link-text small {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--subtext-0);
  }

  .contact__link-ext {
    color: var(--overlay-0);
  }

  .contact__aside {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
  }

  .contact__panel {
    background: var(--bg-card);
    border: 1px solid var(--border-dim);
    border-top: 1px solid rgba(203, 166, 247, 0.34);
    box-shadow: 4px 4px 0 rgba(17, 17, 27, 0.72);
    padding: 1.1rem 1.2rem;
  }

  .contact__panel-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--mauve);
    margin-bottom: 0.75rem;
  }

  .contact__email {
    display: block;
    font-family: var(--font-mono);
    font-size: clamp(0.95rem, 2vw, 1.1rem);
    color: var(--text);
    word-break: break-all;
    padding-bottom: 0.85rem;
    margin-bottom: 0.85rem;
    border-bottom: 1px solid var(--border-dim);
    transition: color 0.15s ease;
  }

  .contact__email:hover {
    color: var(--mauve);
  }

  .contact__facts {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .contact__facts > div {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .contact__facts dt {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--subtext-0);
  }

  .contact__facts dd {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    color: var(--text);
  }

  .contact__callsign {
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--subtext-0);
    text-align: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .contact__signal-dot {
      animation: none;
    }
  }

  @media (max-width: 860px) {
    .contact {
      grid-template-columns: 1fr;
    }
  }

  @media (max-height: 760px) {
    .contact__title {
      font-size: clamp(1.75rem, 5vw, 2.6rem);
    }

    .contact__copy {
      margin-bottom: 1rem;
    }

    .contact__actions {
      margin-bottom: 1rem;
    }
  }
</style>
