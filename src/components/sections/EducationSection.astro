---
import Section from "../layout/Section.astro";
import Icon from "../ui/Icon.astro";
import { education } from "../../data/education";

const typeIcon: Record<string, string> = {
  degree: "mdi:school-outline",
  bootcamp: "mdi:code-braces",
  certificate: "mdi:certificate-outline",
};

const typeLabel: Record<string, string> = {
  degree: "Academic foundation",
  bootcamp: "Applied training",
  certificate: "Certification",
};

const domains = [
  "Frontend systems",
  "Full-stack delivery",
  "Interface motion",
  "Reliability practice",
];
---

<Section id="education" label="Education" index="06" accent="mauve" class="section--learning">
  <div class="learning" data-learning>
    <header class="learning__header">
      <h2 id="education-title">Learning<br /><span>records</span></h2>
      <p>
        Formal study and applied training that shaped how I design, build, and
        reason about web systems.
      </p>
    </header>

    <div class="learning__body">
      <div class="learning__rail" aria-label="Knowledge domains">
        <span class="learning__rail-title">Knowledge domains</span>
        <ol role="list">
          {domains.map((domain, index) => (
            <li>
              <span>{String(index + 1).padStart(2, "0")}</span>
              {domain}
            </li>
          ))}
        </ol>
      </div>

      <ol class="records" role="list" aria-labelledby="education-title">
        {education.map((item, index) => (
          <li class="record" data-learning-record>
            <article>
              <div class="record__marker" aria-hidden="true">
                {String(index + 1).padStart(2, "0")}
              </div>

              <div class="record__meta">
                <span>
                  <Icon name={typeIcon[item.type] ?? "mdi:school-outline"} size={16} />
                  {typeLabel[item.type] ?? item.type}
                </span>
                <time>{item.period}</time>
              </div>

              <div class="record__content">
                <div>
                  <h3>{item.title}</h3>
                  <p class="record__org">{item.org}</p>
                </div>
                <p class="record__detail">{item.detail}</p>
              </div>

              <footer>
                <span>Record note</span>
                <strong>{item.note ?? "Completed"}</strong>
              </footer>
            </article>
          </li>
        ))}
      </ol>
    </div>
  </div>
</Section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const root = document.querySelector<HTMLElement>("[data-learning]");
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (root && !reduceMotion) {
    const records = gsap.utils.toArray<HTMLElement>("[data-learning-record]", root);
    const heading = root.querySelector<HTMLElement>(".learning__header h2");
    const intro = root.querySelector<HTMLElement>(".learning__header p");
    const rail = root.querySelector<HTMLElement>(".learning__rail");

    gsap.fromTo(
      [heading, intro],
      { autoAlpha: 0, y: 54 },
      {
        autoAlpha: 1,
        y: 0,
        duration: 0.8,
        stagger: 0.1,
        ease: "power3.out",
        scrollTrigger: { trigger: root, start: "top 72%", once: true },
      }
    );

    if (rail) {
      gsap.fromTo(
        rail,
        { autoAlpha: 0, x: -42 },
        {
          autoAlpha: 1,
          x: 0,
          duration: 0.75,
          ease: "power3.out",
          scrollTrigger: { trigger: rail, start: "top 84%", once: true },
        }
      );
    }

    records.forEach((record, index) => {
      gsap.fromTo(
        record,
        { autoAlpha: 0, x: index % 2 === 0 ? 70 : -42, rotation: index % 2 === 0 ? 1 : -1 },
        {
          autoAlpha: 1,
          x: 0,
          rotation: 0,
          duration: 0.88,
          ease: "power3.out",
          scrollTrigger: { trigger: record, start: "top 88%", once: true },
        }
      );
    });
  }
</script>

<style>
  :global(.section--learning) { min-height: 135dvh; padding-block: clamp(8rem, 14vh, 12rem) !important; }
  .learning { display: grid; gap: clamp(5rem, 11vh, 9rem); }
  .learning__header { display: grid; gap: 2rem; }
  .learning__header h2 { max-width: 9ch; font-size: clamp(4.5rem, 10vw, 10rem); line-height: .76; letter-spacing: -.075em; }
  .learning__header h2 span { display: inline-block; margin-left: .8em; color: #a2abbd; font-weight: 400; }
  .learning__header p { max-width: 52ch; margin-left: min(27vw, 25rem); color: #bcc4d1; font-size: clamp(1rem, 1.4vw, 1.2rem); line-height: 1.65; }
  .learning__body { display: grid; grid-template-columns: minmax(190px, .34fr) minmax(0, 1fr); gap: clamp(3rem, 8vw, 8rem); align-items: start; }
  .learning__rail { position: sticky; top: 8rem; padding-top: 1rem; border-top: 1px solid var(--divider-line); }
  .learning__rail-title { color: #98a2b5; font-family: var(--font-mono); font-size: .64rem; letter-spacing: .08em; text-transform: uppercase; }
  .learning__rail ol { display: grid; gap: 1.25rem; margin: 2.5rem 0 0; padding: 0; list-style: none; }
  .learning__rail li { display: grid; grid-template-columns: 2rem 1fr; gap: .4rem; color: #c2c8d3; font-size: .84rem; line-height: 1.35; }
  .learning__rail li span { color: #8993a8; font-family: var(--font-mono); font-size: .62rem; }
  .records { display: grid; gap: clamp(3rem, 7vh, 5rem); margin: 0; padding: 0; list-style: none; }
  .record { position: relative; }
  .record:nth-child(even) { margin-left: clamp(0rem, 7vw, 7rem); }
  .record article { position: relative; display: grid; gap: clamp(2rem, 4vw, 3.5rem); min-height: 420px; padding: clamp(2rem, 4vw, 4rem); border: 1px solid var(--surface-border); background: var(--surface-panel); overflow: hidden; transition: border-color .3s ease, transform .3s cubic-bezier(.16,1,.3,1); }
  .record article:hover { transform: translateY(-4px); border-color: #4c4158; }
  .record__marker { position: absolute; right: -.02em; bottom: -.24em; color: rgba(203,166,247,.055); font-size: clamp(12rem, 24vw, 24rem); font-weight: 650; line-height: .8; letter-spacing: -.1em; pointer-events: none; }
  .record__meta { position: relative; display: flex; justify-content: space-between; gap: 1rem; color: #a3acbe; font-family: var(--font-mono); font-size: .65rem; letter-spacing: .07em; text-transform: uppercase; }
  .record__meta span { display: inline-flex; align-items: center; gap: .55rem; color: #b795d9; }
  .record__content { position: relative; display: grid; grid-template-columns: minmax(0, 1.1fr) minmax(240px, .7fr); gap: 3rem; align-items: end; }
  .record h3 { max-width: 12ch; font-size: clamp(2.4rem, 5vw, 5.4rem); line-height: .92; letter-spacing: -.06em; }
  .record__org { margin-top: 1rem; color: #d0d5de; }
  .record__detail { max-width: 40ch; color: #a3acbe; line-height: 1.65; }
  .record footer { position: relative; display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding-top: 1.2rem; border-top: 1px solid var(--divider-line); }
  .record footer span { color: #929bad; font-family: var(--font-mono); font-size: .62rem; letter-spacing: .08em; text-transform: uppercase; }
  .record footer strong { color: #bdbdbd; font-size: .85rem; font-weight: 500; }
  @media (max-width: 760px) {
    :global(.section--learning) { min-height: 100dvh; padding-block: 7rem !important; }
    .learning { gap: 5rem; }
    .learning__header h2 { font-size: clamp(4rem, 20vw, 7rem); }
    .learning__header h2 span { margin-left: 0; }
    .learning__header p { margin-left: 0; }
    .learning__body { grid-template-columns: 1fr; }
    .learning__rail { position: static; }
    .learning__rail ol { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .record:nth-child(even) { margin-left: 0; }
    .record article { min-height: 0; }
    .record__content { grid-template-columns: 1fr; gap: 1.5rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    .record article { transition: none; }
    .record article:hover { transform: none; }
  }
</style>
