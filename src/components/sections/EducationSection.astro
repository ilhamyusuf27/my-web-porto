---
import Section from "../layout/Section.astro";
import Icon from "../ui/Icon.astro";
import { education, certificates } from "../../data/education";

const typeIcon: Record<string, string> = {
  degree: "mdi:school-outline",
  bootcamp: "mdi:code-braces",
  certificate: "mdi:certificate-outline",
};

const typeLabel: Record<string, string> = {
  degree: "Degree",
  bootcamp: "Bootcamp",
  certificate: "Certificate",
};

const registryRows = [
  { label: "Records", value: `${education.length}`, note: "verified learning entries" },
  { label: "Credentials", value: `${certificates.length}`, note: "degree and program records" },
  { label: "Formal track", value: "Informatics", note: "web, multimedia, animation" },
  { label: "Applied track", value: "Full-stack", note: "JavaScript, Node, React, Next.js" },
];

const knowledgeDomains = [
  "Frontend systems",
  "Backend fundamentals",
  "Web delivery",
  "Interface motion",
  "Reliability direction",
];
---

<Section id="education" label="Education" index="07" accent="mauve" class="section--dense">
  <div class="edu" data-reveal>
    <section class="edu__main" aria-labelledby="education-title">
      <div class="edu__heading">
        <span class="edu__eyebrow">Knowledge Archive</span>
        <h2 id="education-title" class="edu__title">Learning records</h2>
        <p class="edu__sub">
          Formal study and applied training that support frontend delivery, full-stack work,
          and a reliability-minded engineering direction.
        </p>
      </div>

      <ol class="edu__records" role="list" aria-label="Education records">
        {
          education.map((item, index) => (
            <li class="edu__record">
              <article class="edu__entry">
                <div class="edu__entry-index" aria-hidden="true">
                  {String(index + 1).padStart(2, "0")}
                </div>
                <div class="edu__entry-body">
                  <div class="edu__entry-top">
                    <span class="edu__type">
                      <Icon name={typeIcon[item.type] ?? "mdi:school-outline"} size={15} />
                      {typeLabel[item.type] ?? item.type}
                    </span>
                    <span class="edu__period">{item.period}</span>
                  </div>
                  <h3 class="edu__entry-title">{item.title}</h3>
                  <p class="edu__org">
                    <Icon name="mdi:domain" size={14} />
                    {item.org}
                  </p>
                  <p class="edu__detail">{item.detail}</p>
                  {item.note && <span class="edu__tag">{item.note}</span>}
                </div>
              </article>
            </li>
          ))
        }
      </ol>
    </section>

    <aside class="edu__registry" aria-labelledby="registry-title" data-reveal>
      <div class="edu__registry-head">
        <span class="edu__registry-kicker">Credential Registry</span>
        <h3 id="registry-title">Education summary</h3>
      </div>

      <dl class="edu__registry-rows">
        {
          registryRows.map((row) => (
            <div class="edu__registry-row">
              <dt>{row.label}</dt>
              <dd>
                <strong>{row.value}</strong>
                <span>{row.note}</span>
              </dd>
            </div>
          ))
        }
      </dl>

      <div class="edu__domains">
        <h4>Knowledge domains</h4>
        <ul role="list">
          {
            knowledgeDomains.map((domain) => (
              <li>{domain}</li>
            ))
          }
        </ul>
      </div>

      <p class="edu__registry-note">
        Continuing direction: stronger deployment, monitoring, and SRE-minded delivery
        practices around the product work.
      </p>
    </aside>
  </div>
</Section>

<style>
  .edu {
    display: grid;
    grid-template-columns: minmax(0, 1.38fr) minmax(300px, 0.72fr);
    gap: clamp(1rem, 2.4vw, 1.6rem);
    align-items: stretch;
    position: relative;
  }

  .edu::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(90deg, transparent 0, rgba(147, 153, 178, 0.16) 49%, transparent 50%),
      linear-gradient(180deg, rgba(203, 166, 247, 0.08), transparent 36%);
    opacity: 0.52;
    mask-image: linear-gradient(90deg, transparent, black 18%, black 82%, transparent);
  }

  .edu__main,
  .edu__registry {
    position: relative;
    z-index: 1;
  }

  .edu__main {
    display: grid;
    grid-template-rows: auto 1fr;
    min-width: 0;
    border: 1px solid var(--border-dim);
    background:
      linear-gradient(135deg, rgba(49, 50, 68, 0.72), rgba(24, 24, 37, 0.68)),
      repeating-linear-gradient(
        90deg,
        transparent 0,
        transparent 52px,
        rgba(147, 153, 178, 0.055) 53px
      );
  }

  .edu__heading {
    padding: clamp(1rem, 2vw, 1.3rem) clamp(1rem, 2vw, 1.45rem);
    border-bottom: 1px solid var(--border-dim);
  }

  .edu__eyebrow,
  .edu__registry-kicker,
  .edu__type,
  .edu__period,
  .edu__tag,
  .edu__domains h4 {
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .edu__eyebrow,
  .edu__registry-kicker {
    display: block;
    margin-bottom: 0.45rem;
    color: var(--mauve);
    font-size: 0.72rem;
  }

  .edu__title {
    font-size: clamp(1.85rem, 4.5vw, 2.7rem);
    line-height: 1.02;
    margin: 0 0 0.55rem;
    letter-spacing: 0;
  }

  .edu__sub {
    max-width: 720px;
    color: var(--subtext-1);
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .edu__records {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    min-height: 0;
  }

  .edu__record {
    min-width: 0;
    border-right: 1px solid var(--border-dim);
  }

  .edu__record:last-child {
    border-right: 0;
  }

  .edu__entry {
    display: grid;
    grid-template-columns: 54px minmax(0, 1fr);
    min-height: 100%;
  }

  .edu__entry-index {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 1.15rem;
    color: rgba(203, 166, 247, 0.78);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    border-right: 1px dashed rgba(147, 153, 178, 0.28);
    background: rgba(17, 17, 27, 0.3);
  }

  .edu__entry-body {
    padding: clamp(1rem, 2vw, 1.25rem);
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .edu__entry-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.7rem;
    flex-wrap: wrap;
  }

  .edu__type {
    display: inline-flex;
    align-items: center;
    gap: 0.38rem;
    width: fit-content;
    color: var(--mauve);
    font-size: 0.68rem;
  }

  .edu__period {
    color: var(--subtext-0);
    font-size: 0.68rem;
  }

  .edu__entry-title {
    margin: 0.1rem 0 0;
    color: var(--text);
    font-family: var(--font-heading);
    font-size: clamp(1.15rem, 2.2vw, 1.45rem);
    line-height: 1.18;
  }

  .edu__org {
    display: flex;
    align-items: center;
    gap: 0.38rem;
    color: var(--subtext-1);
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }

  .edu__detail {
    color: var(--subtext-1);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .edu__tag {
    width: fit-content;
    margin-top: auto;
    padding: 0.38rem 0.58rem;
    border: 1px solid rgba(203, 166, 247, 0.28);
    background: rgba(203, 166, 247, 0.06);
    color: var(--text);
    font-size: 0.66rem;
  }

  .edu__registry {
    display: flex;
    flex-direction: column;
    min-width: 0;
    border: 1px solid var(--border-dim);
    background: rgba(24, 24, 37, 0.76);
    box-shadow: 0 18px 42px rgba(17, 17, 27, 0.28);
  }

  .edu__registry-head {
    padding: 1rem 1.05rem 0.9rem;
    border-bottom: 1px solid var(--border-dim);
  }

  .edu__registry-head h3 {
    margin: 0;
    color: var(--text);
    font-family: var(--font-heading);
    font-size: 1.05rem;
    line-height: 1.2;
  }

  .edu__registry-rows {
    margin: 0;
  }

  .edu__registry-row {
    display: grid;
    grid-template-columns: 0.72fr 1fr;
    gap: 0.8rem;
    padding: 0.75rem 1.05rem;
    border-bottom: 1px solid rgba(147, 153, 178, 0.18);
  }

  .edu__registry-row dt {
    color: var(--subtext-0);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .edu__registry-row dd {
    margin: 0;
    min-width: 0;
  }

  .edu__registry-row strong,
  .edu__registry-row span {
    display: block;
  }

  .edu__registry-row strong {
    color: var(--text);
    font-family: var(--font-heading);
    font-size: 0.95rem;
    line-height: 1.2;
  }

  .edu__registry-row span {
    margin-top: 0.18rem;
    color: var(--subtext-1);
    font-size: 0.78rem;
    line-height: 1.35;
  }

  .edu__domains {
    padding: 0.95rem 1.05rem;
    border-bottom: 1px solid var(--border-dim);
  }

  .edu__domains h4 {
    margin: 0 0 0.65rem;
    color: var(--subtext-0);
    font-size: 0.68rem;
  }

  .edu__domains ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.42rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .edu__domains li {
    padding: 0.36rem 0.5rem;
    border: 1px solid rgba(147, 153, 178, 0.22);
    color: var(--subtext-1);
    background: rgba(49, 50, 68, 0.38);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1;
  }

  .edu__registry-note {
    margin: auto 0 0;
    padding: 0.9rem 1.05rem 1rem;
    color: var(--subtext-1);
    font-size: 0.86rem;
    line-height: 1.5;
  }

  @media (hover: hover) {
    .edu__entry {
      transition:
        background-color 180ms ease,
        transform 180ms ease;
    }

    .edu__entry:hover {
      background: rgba(203, 166, 247, 0.035);
      transform: translateY(-2px);
    }
  }

  @media (max-width: 980px) {
    .edu {
      grid-template-columns: 1fr;
    }

    .edu::before {
      display: none;
    }

    .edu__registry {
      box-shadow: none;
    }
  }

  @media (max-width: 680px) {
    .edu__records {
      grid-template-columns: 1fr;
    }

    .edu__record {
      border-right: 0;
      border-bottom: 1px solid var(--border-dim);
    }

    .edu__record:last-child {
      border-bottom: 0;
    }

    .edu__entry {
      grid-template-columns: 42px minmax(0, 1fr);
    }

    .edu__registry-row {
      grid-template-columns: 1fr;
      gap: 0.28rem;
    }
  }

  @media (max-height: 760px) and (min-width: 981px) {
    .edu__heading {
      padding-block: 0.9rem;
    }

    .edu__title {
      font-size: clamp(1.65rem, 3.8vw, 2.25rem);
    }

    .edu__sub,
    .edu__detail {
      font-size: 0.86rem;
      line-height: 1.45;
    }

    .edu__entry-body {
      gap: 0.42rem;
      padding-block: 0.9rem;
    }

    .edu__registry-row {
      padding-block: 0.58rem;
    }

    .edu__domains,
    .edu__registry-note {
      padding-block: 0.7rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .edu__entry {
      transition: none;
    }

    .edu__entry:hover {
      transform: none;
    }
  }
</style>
