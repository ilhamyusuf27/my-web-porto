---
import Section from "../layout/Section.astro";
import { projects } from "../../data/projects";
import { ongoingBuilds } from "../../data/profile";

const experiments = projects.filter(
  (project) => project.category === "experimental" || project.status === "experimental"
);

const researchNotes = [
  ["Rendering", "Procedural geometry and scroll-linked WebGL trials."],
  ["Motion", "GSAP timing studies and reusable transition patterns."],
  ["Tooling", "Provider configuration and assistant workflow spikes."],
];

const phase = (progress: number) => {
  if (progress >= 70) return "Refining";
  if (progress >= 55) return "Building";
  return "Exploring";
};
---

<Section id="experimental" label="R&D and Build Queue" index="05" class="section--research">
  <div class="research" data-reveal data-research>
    <header class="research__head">
      <h2>Testing ideas.<br />Building the useful ones.</h2>
      <p>
        A combined view of small technical experiments and the work currently
        moving toward something usable.
      </p>
    </header>

    <section class="research__experiments" aria-labelledby="experiments-title">
      <div class="research__stack" data-research-stack>
        {researchNotes.map(([title, note], index) => (
          <article class={`research-note research-note--${index + 1}`} data-research-note>
            <span>{title}</span>
            <p>{note}</p>
          </article>
        ))}

        {experiments.map((experiment) => (
          <article class="research-card" data-research-card>
            <div class="research-card__meta">
              <span>Prototype</span>
              <span>{experiment.period}</span>
            </div>
            <h3 id="experiments-title">{experiment.title}</h3>
            <p>{experiment.summary}</p>
            <ul role="list" aria-label={`${experiment.title} tools`}>
              {experiment.stack.map((tool) => <li>{tool}</li>)}
            </ul>
          </article>
        ))}
      </div>

      <aside class="research__statement">
        <span>R&D approach</span>
        <p>
          Start small, isolate the uncertain part, and keep the result only
          when it improves the real product experience.
        </p>
      </aside>
    </section>

    <section class="builds" aria-labelledby="builds-title">
      <header class="builds__head">
        <h3 id="builds-title">In progress now</h3>
        <span>{ongoingBuilds.length} active tracks</span>
      </header>

      <div class="builds__lanes">
        {ongoingBuilds.map((item) => (
          <article class="build-lane" data-build-lane>
            <div class="build-lane__status">
              <span aria-hidden="true"></span>
              {phase(item.progress)}
            </div>
            <h4>{item.title}</h4>
            <p>{item.focus}</p>
            <footer>
              <span>Next</span>
              <strong>{item.next}</strong>
            </footer>
          </article>
        ))}
      </div>
    </section>
  </div>
</Section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const root = document.querySelector<HTMLElement>("[data-research]");

  if (root && !reduceMotion) {
    const notes = gsap.utils.toArray<HTMLElement>("[data-research-note]", root);
    const card = root.querySelector<HTMLElement>("[data-research-card]");
    const lanes = gsap.utils.toArray<HTMLElement>("[data-build-lane]", root);

    if (card) {
      gsap.fromTo(
        [card, ...notes],
        { autoAlpha: 0, y: 90, rotation: (index) => (index - 1) * 3 },
        {
          autoAlpha: 1,
          y: 0,
          rotation: 0,
          duration: 1,
          stagger: 0.09,
          ease: "power3.out",
          scrollTrigger: { trigger: card, start: "top 82%", once: true },
        }
      );
    }

    lanes.forEach((lane, index) => {
      gsap.fromTo(
        lane,
        { autoAlpha: 0, y: 34 },
        {
          autoAlpha: 1,
          y: 0,
          duration: 0.72,
          delay: index * 0.04,
          ease: "power3.out",
          scrollTrigger: {
            trigger: lane,
            start: "top 96%",
            once: true,
          },
        }
      );
    });
  }
</script>

<style>
  :global(.section--research) {
    min-height: 160dvh;
    padding-bottom: max(14rem, 34vh) !important;
  }
  .research { position: relative; display: grid; gap: clamp(7rem, 15vh, 12rem); }
  .research__head { display: grid; grid-template-columns: minmax(0,1.35fr) minmax(260px,.5fr); gap: 4rem; align-items: end; }
  .research__head h2 { max-width: 1020px; }
  .research__head > p { max-width: 42ch; color: #7d7d7d; line-height: 1.65; }

  .research__experiments { display: grid; grid-template-columns: minmax(0,1.25fr) minmax(250px,.45fr); gap: clamp(3rem,8vw,8rem); align-items: center; }
  .research__stack { position: relative; min-height: 600px; perspective: 1100px; }
  .research-card, .research-note { position: absolute; border: 1px solid #2a2a2a; background: #090909; }
  .research-card { inset: 5% 8% 2% 4%; z-index: 4; display: flex; flex-direction: column; justify-content: flex-end; padding: clamp(2rem,5vw,4.5rem); transform: rotate(-1.5deg); box-shadow: 0 30px 80px rgba(0,0,0,.4); }
  .research-card__meta { position: absolute; top: 2rem; left: 2rem; right: 2rem; display: flex; justify-content: space-between; color: #666; font-family: var(--font-mono); font-size: .63rem; text-transform: uppercase; letter-spacing: .08em; }
  .research-card h3 { max-width: 13ch; font-size: clamp(3rem,6vw,6.8rem); line-height: .9; letter-spacing: -.07em; }
  .research-card > p { max-width: 56ch; margin-top: 1.5rem; color: #858585; line-height: 1.65; }
  .research-card ul { display: flex; flex-wrap: wrap; gap: .55rem 1.3rem; margin: 2.5rem 0 0; padding: 0; list-style: none; }
  .research-card li { color: #aaa; font-family: var(--font-mono) !important; font-size: .66rem; }
  .research-note { z-index: 1; width: 36%; min-height: 150px; padding: 1.25rem; }
  .research-note span { color: #aaa; font-family: var(--font-mono) !important; font-size: .62rem; text-transform: uppercase; letter-spacing: .08em; }
  .research-note p { margin-top: 1rem; color: #666; font-size: .8rem; line-height: 1.5; }
  .research-note--1 { top: -4%; right: 2%; transform: rotate(7deg); }
  .research-note--2 { bottom: -5%; right: 0; transform: rotate(-5deg); }
  .research-note--3 { bottom: -8%; left: 0; transform: rotate(4deg); }
  .research__statement { align-self: end; padding-top: 1.2rem; border-top: 1px solid #292929; }
  .research__statement span { color: #666; font-family: var(--font-mono) !important; font-size: .62rem; text-transform: uppercase; letter-spacing: .08em; }
  .research__statement p { margin-top: 1.4rem; font-size: clamp(1.4rem,2.4vw,2.2rem); line-height: 1.25; letter-spacing: -.035em; }

  .builds { display: grid; gap: 2.5rem; }
  .builds__head { display: flex; align-items: end; justify-content: space-between; gap: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid #2a2a2a; }
  .builds__head h3 { font-size: clamp(2.8rem,6vw,6rem); line-height: .92; letter-spacing: -.06em; }
  .builds__head span { color: #666; font-family: var(--font-mono) !important; font-size: .63rem; text-transform: uppercase; letter-spacing: .08em; }
  .builds__lanes { display: grid; }
  .build-lane { display: grid; grid-template-columns: minmax(110px,.25fr) minmax(220px,.65fr) minmax(0,1fr) minmax(280px,.8fr); gap: clamp(1.5rem,4vw,4rem); align-items: start; padding: clamp(2rem,4vw,3.5rem) 0; border-bottom: 1px solid #292929; }
  .build-lane__status { display: inline-flex; align-items: center; gap: .55rem; color: #777; font-family: var(--font-mono); font-size: .62rem; text-transform: uppercase; letter-spacing: .08em; }
  .build-lane__status span { width: 6px; height: 6px; border-radius: 50%; background: #cba6f7; box-shadow: 0 0 0 4px rgba(203,166,247,.08); }
  .build-lane h4 { font-size: clamp(1.55rem,2.6vw,2.5rem); letter-spacing: -.045em; }
  .build-lane > p { max-width: 46ch; color: #777; line-height: 1.6; }
  .build-lane footer { display: grid; gap: .65rem; }
  .build-lane footer span { color: #5f5f5f; font-family: var(--font-mono) !important; font-size: .6rem; text-transform: uppercase; letter-spacing: .08em; }
  .build-lane footer strong { color: #aaa; font-size: .82rem; font-weight: 400; line-height: 1.55; }

  @media (max-width: 860px) {
    :global(.section--research) {
      min-height: 100dvh;
      padding-bottom: max(9rem, 24vh) !important;
    }
    .research__head, .research__experiments { grid-template-columns: 1fr; }
    .research__stack { min-height: 570px; }
    .research-card { inset: 4% 3% 3%; }
    .research-note { width: 42%; opacity: .7; }
    .build-lane { grid-template-columns: 1fr; gap: 1rem; }
    .build-lane footer { margin-top: 1rem; padding-top: 1rem; border-top: 1px solid #202020; }
  }
  @media (max-width: 560px) {
    .research__stack { min-height: 650px; }
    .research-card { padding: 1.5rem; }
    .research-note { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .research-card, .research-note, .build-lane { transform: none; }
  }
</style>
