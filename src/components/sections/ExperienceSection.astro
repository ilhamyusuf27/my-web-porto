---
import Section from "../layout/Section.astro";
import { experiences } from "../../data/experiences";
---

<Section id="experience" label="Experience" index="03" class="section--experience">
  <div class="experience" data-reveal>
    <header class="experience__head">
      <h2>Work shaped by<br />real delivery.</h2>
      <p>
        From production dashboards to client websites—each role added a
        different layer to how I build and ship interfaces.
      </p>
    </header>

    <div class="experience__accordion" aria-label="Career history">
      {experiences.map((item, index) => (
        <details class="experience__item" open={index === 0}>
          <summary>
            <span class="experience__period">{item.period}</span>
            <span class="experience__company">{item.company}</span>
            <span class="experience__role">{item.role}</span>
            <span class="experience__arrow" aria-hidden="true">↗</span>
          </summary>

          <div class="experience__body">
            <p>{item.highlights[0]}</p>
            <ul role="list">
              {item.highlights.slice(1).map((highlight) => <li>{highlight}</li>)}
            </ul>
            <div class="experience__stack" aria-label={`${item.company} tools`}>
              {item.stack.map((tool) => <span>{tool}</span>)}
            </div>
            <footer>
              <span>{item.location}</span>
              <span>{item.status === "active" ? "Current role" : "Completed"}</span>
            </footer>
          </div>
        </details>
      ))}
    </div>
  </div>
</Section>

<script>
  document.querySelectorAll<HTMLDetailsElement>(".experience__item").forEach((item, _, items) => {
    item.addEventListener("toggle", () => {
      if (!item.open) return;
      items.forEach((other) => {
        if (other !== item) other.open = false;
      });
    });
  });
</script>

<style>
  .experience { display: grid; gap: clamp(3.5rem, 8vh, 6.5rem); }
  .experience__head { display: grid; grid-template-columns: minmax(0, 1.35fr) minmax(260px, .55fr); gap: 3rem; align-items: end; }
  .experience__head p { max-width: 44ch; color: #858585; font-size: 1rem; line-height: 1.65; }
  .experience__accordion { display: flex; height: clamp(430px, 58vh, 610px); min-height: 0; overflow: hidden; border-top: 1px solid #292929; border-bottom: 1px solid #292929; contain: layout paint; }
  .experience__item { flex: 1 1 0; height: 100%; min-width: 0; overflow: hidden; border-right: 1px solid #292929; background: #070707; transition: flex 800ms cubic-bezier(.32,.72,0,1), background 600ms cubic-bezier(.32,.72,0,1); }
  .experience__item:first-child { border-left: 1px solid #292929; }
  .experience__item[open] { flex: 2.8 1 0; background: #0b0b0b; }
  .experience__item summary { position: relative; display: grid; grid-template-rows: auto auto 1fr auto; align-content: stretch; gap: .85rem; min-height: 100%; padding: clamp(1.2rem, 2.5vw, 2rem); cursor: pointer; list-style: none; }
  .experience__item summary::-webkit-details-marker { display: none; }
  .experience__period { font-family: var(--font-mono) !important; color: #666; font-size: .64rem; letter-spacing: .08em; }
  .experience__company { position: absolute; left: clamp(1.2rem, 2.5vw, 2rem); bottom: clamp(1.2rem, 2.5vw, 2rem); margin: 0; font-size: clamp(1.25rem, 2.2vw, 2rem); font-weight: 500; letter-spacing: -.04em; white-space: nowrap; transform: rotate(-90deg) translateY(100%); transform-origin: left bottom; transition: transform 700ms cubic-bezier(.16,1,.3,1), font-size 700ms cubic-bezier(.16,1,.3,1), opacity 250ms ease; }
  .experience__role { align-self: end; color: #777; font-size: .74rem; line-height: 1.45; }
  .experience__arrow { position: absolute; right: 1.35rem; bottom: 1.35rem; color: #777; transition: transform 500ms cubic-bezier(.32,.72,0,1), color 500ms cubic-bezier(.32,.72,0,1); }
  .experience__item[open] summary { min-height: auto; padding-bottom: 1rem; }
  .experience__item[open] .experience__company { position: relative; left: auto; bottom: auto; margin-top: 2rem; font-size: clamp(2.4rem, 4vw, 4.5rem); white-space: normal; transform: rotate(0deg) translateY(0); transform-origin: left center; }
  .experience__item[open] .experience__role { font-size: .9rem; }
  .experience__item[open] .experience__arrow { color: #f1f1f1; transform: translate(2px,-2px); }
  .experience__body { max-height: calc(100% - 9rem); overflow: hidden; padding: 0 clamp(1.2rem, 2.5vw, 2rem) clamp(1.2rem, 2.5vw, 2rem); animation: experience-in 650ms cubic-bezier(.32,.72,0,1) both; }
  .experience__body > p { max-width: 48ch; font-size: clamp(1.05rem, 1.7vw, 1.35rem); line-height: 1.45; }
  .experience__body ul { display: grid; gap: .55rem; max-width: 58ch; margin: 1.25rem 0 0; padding: 0; list-style: none; color: #777; font-size: .82rem; line-height: 1.5; }
  .experience__body li::before { content: "—"; margin-right: .55rem; color: #555; }
  .experience__stack { display: flex; flex-wrap: wrap; gap: .45rem; margin-top: 1.5rem; }
  .experience__stack span, .experience__body footer { font-family: var(--font-mono) !important; font-size: .62rem; }
  .experience__stack span { padding: .38rem .55rem; border: 1px solid #292929; color: #999; }
  .experience__body footer { display: flex; justify-content: space-between; gap: 1rem; margin-top: 1.75rem; padding-top: 1rem; border-top: 1px solid #292929; color: #666; text-transform: uppercase; letter-spacing: .06em; }
  @keyframes experience-in { from { opacity: 0; transform: translateY(12px); } }
  @media (max-width: 800px) {
    .experience__head { grid-template-columns: 1fr; }
    .experience__accordion { display: grid; height: auto; min-height: 0; overflow: visible; contain: none; }
    .experience__item, .experience__item:first-child { height: auto; border: 0; border-bottom: 1px solid #292929; }
    .experience__item summary { min-height: 130px; }
    .experience__company { position: relative; left: auto; bottom: auto; margin-top: 1.2rem; white-space: normal; transform: none; }
    .experience__item[open] .experience__company { font-size: clamp(2rem, 9vw, 3.5rem); }
    .experience__body { max-height: none; overflow: visible; }
  }
  @media (prefers-reduced-motion: reduce) { .experience__item, .experience__body, .experience__arrow { animation: none; transition: none; } }
</style>
