---
/**
 * Fixed canvas layer for the Three.js space scene. Bootstraps lazily once the
 * page is idle and only if WebGL is available. Lives in BaseLayout's
 * `scene` slot so it renders behind page content.
 */
---

<canvas id="space-canvas" class="space-canvas" aria-hidden="true"></canvas>

<script>
  function webglAvailable(): boolean {
    try {
      const canvas = document.createElement("canvas");
      return !!(
        window.WebGLRenderingContext &&
        (canvas.getContext("webgl") || canvas.getContext("experimental-webgl"))
      );
    } catch {
      return false;
    }
  }

  // Three.js is imported lazily here so it stays off the initial load path.
  async function boot() {
    if (!webglAvailable()) return;
    const canvas = document.getElementById("space-canvas") as HTMLCanvasElement | null;
    if (!canvas) return;
    try {
      const { SpaceScene } = await import("./SpaceScene");
      new SpaceScene({ canvas });
    } catch (err) {
      // Scene must never break the page; degrade silently to CSS background.
      console.warn("Space scene failed to start:", err);
    }
  }

  const schedule = () =>
    (window.requestIdleCallback || ((cb) => setTimeout(cb, 200)))(boot);

  if (document.readyState === "complete") {
    schedule();
  } else {
    window.addEventListener("load", schedule);
  }
</script>

<style>
  .space-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    z-index: 0;
    /* Upscale the low-res WebGL buffer to crisp pixels -> the pixel-art look. */
    image-rendering: pixelated;
    image-rendering: crisp-edges;
  }
</style>
