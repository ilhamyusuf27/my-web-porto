<canvas class="console-background" data-console-background aria-hidden="true"></canvas>

<div class="scene-loader" data-scene-loader>
  <div class="scene-loader__brand">
    <img src="/logo-mark.svg" alt="" width="32" height="32" />
    <span>Ilham Yusuf</span>
  </div>

  <div class="scene-loader__status">
    <span>Preparing portfolio</span>
    <strong>Loading visual system</strong>
  </div>

  <div class="scene-loader__progress" aria-hidden="true">
    <span></span>
  </div>
</div>

<script>
  const canvas = document.querySelector<HTMLCanvasElement>("[data-console-background]");
  const loader = document.querySelector<HTMLElement>("[data-scene-loader]");
  const compactViewport = window.matchMedia("(max-width: 760px)");
  const root = document.documentElement;
  const loaderStartedAt = window.performance.now();
  const minimumLoaderTime = 650;
  let started = false;
  let finished = false;

  const nextPaint = () => new Promise<void>((resolve) => {
    window.requestAnimationFrame(() => window.requestAnimationFrame(() => resolve()));
  });

  const finish = async (state: "ready" | "fallback", immediate = false) => {
    if (finished) return;
    finished = true;

    if (!immediate) {
      await nextPaint();
      const remaining = Math.max(
        0,
        minimumLoaderTime - (window.performance.now() - loaderStartedAt)
      );
      if (remaining) {
        await new Promise<void>((resolve) => window.setTimeout(resolve, remaining));
      }
      await nextPaint();
    }

    root.dataset.sceneState = state;
    window.dispatchEvent(new CustomEvent("portfolio:scene-ready", {
      detail: { state },
    }));
    window.setTimeout(() => loader?.remove(), 900);
  };

  const start = async () => {
    if (!canvas || started) return;
    if (compactViewport.matches) {
      void finish("fallback", true);
      return;
    }
    started = true;

    try {
      const { AtmosphericSystemScene } = await import("./AtmosphericSystemScene");
      new AtmosphericSystemScene({ canvas });
      canvas.dataset.sceneReady = "true";
      await finish("ready");
    } catch (error) {
      canvas.dataset.sceneFallback = "true";
      await finish("fallback");
      console.warn("Ambient system scene could not start; using CSS fallback.", error);
    }
  };

  const safetyTimer = window.setTimeout(() => void finish("fallback"), 5000);
  void start().finally(() => window.clearTimeout(safetyTimer));
</script>

<style>
  .console-background {
    width: 100%;
    height: 100%;
    opacity: 1;
    display: block;
    transform: scale(1.045);
    background:
      repeating-linear-gradient(90deg, transparent 0 7%, rgba(172, 184, 204, .075) 8%, transparent 9% 15%),
      radial-gradient(ellipse 70% 66% at 72% 34%, rgba(142, 150, 174, .28), transparent 72%),
      radial-gradient(ellipse 54% 50% at 22% 74%, rgba(61, 101, 154, .18), transparent 74%),
      linear-gradient(135deg, #111722, #0d111a 52%, #171821);
  }

  :global(html.js:not([data-scene-state]) .ambient-layer) {
    z-index: 12000;
  }

  :global(html.js:not([data-scene-state]) .console-background) {
    opacity: 0;
  }

  :global(html[data-scene-state] .ambient-layer) {
    z-index: 0;
    transition: z-index 0s linear .85s;
  }

  :global(html[data-scene-state] .console-background) {
    opacity: 1;
    transition: opacity .72s cubic-bezier(.16, 1, .3, 1);
  }

  .scene-loader {
    position: absolute;
    inset: 0;
    display: none;
    grid-template-columns: minmax(0, 1fr) auto;
    grid-template-rows: auto 1fr auto;
    gap: 2rem;
    padding: clamp(1.5rem, 4vw, 4.5rem);
    color: #e8ebf2;
    background:
      radial-gradient(ellipse 66% 58% at 76% 28%, rgba(116, 126, 158, .22), transparent 72%),
      radial-gradient(ellipse 48% 42% at 18% 78%, rgba(55, 83, 126, .16), transparent 76%),
      linear-gradient(135deg, #111722, #0d111a 54%, #171821);
    transform: translate3d(0, 0, 0);
    transition:
      transform .68s cubic-bezier(.16, 1, .3, 1),
      visibility 0s linear .68s;
    will-change: transform;
  }

  :global(html.js) .scene-loader {
    display: grid;
  }

  :global(html[data-scene-state]) .scene-loader {
    visibility: hidden;
    transform: translate3d(0, -100%, 0);
  }

  .scene-loader__brand {
    display: flex;
    align-items: center;
    gap: .8rem;
    font-size: .8rem;
    font-weight: 500;
    letter-spacing: -.015em;
  }

  .scene-loader__brand img {
    width: 2rem;
    height: 2rem;
  }

  .scene-loader__status {
    grid-column: 1 / -1;
    align-self: end;
    display: grid;
    gap: .65rem;
  }

  .scene-loader__status span,
  .scene-loader__status strong {
    font-family: var(--font-mono);
    text-transform: uppercase;
  }

  .scene-loader__status span {
    color: #9ca6ba;
    font-size: .58rem;
    letter-spacing: .12em;
  }

  .scene-loader__status strong {
    max-width: 18ch;
    color: #e4e7ed;
    font-size: clamp(1.2rem, 2.1vw, 2rem);
    font-weight: 400;
    letter-spacing: -.035em;
  }

  .scene-loader__progress {
    grid-column: 1 / -1;
    height: 1px;
    overflow: hidden;
    background: rgba(205, 214, 244, .18);
  }

  .scene-loader__progress span {
    display: block;
    width: 34%;
    height: 100%;
    background: #b795d9;
    animation: scene-loader-progress 1.1s cubic-bezier(.65, 0, .35, 1) infinite;
  }

  @keyframes scene-loader-progress {
    from { transform: translateX(-110%); }
    to { transform: translateX(310%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .console-background {
      opacity: 0.46;
      transform: none;
    }

    .scene-loader,
    .scene-loader__progress span {
      animation: none;
      transition: none;
    }
  }

  @media (max-width: 760px) {
    .console-background {
      display: none;
    }

    .scene-loader {
      padding: 1.25rem;
    }
  }
</style>
