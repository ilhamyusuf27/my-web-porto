---
import Modal from "../ui/Modal.astro";
import Icon from "../ui/Icon.astro";
import { projects } from "../../data/projects";

const getImages = (project: (typeof projects)[number]) =>
  project.images?.length
    ? project.images
    : project.image
      ? [{ src: project.image, alt: `${project.title} preview` }]
      : [];

const payload = projects.map((project) => ({
  id: project.id,
  title: project.title,
  category: project.category,
  type: project.type,
  period: project.period,
  role: project.role,
  status: project.status,
  summary: project.summary,
  problem: project.problem ?? null,
  contribution: project.contribution ?? [],
  outcomes: project.outcomes ?? [],
  stack: project.stack,
  links: project.links ?? [],
  accent: project.accent ?? "mauve",
  image: project.image ?? null,
  images: getImages(project),
}));
---

<Modal id="project-modal" titleId="project-modal-title" class="project-case-modal">
  <span slot="title" data-field="title">Project</span>

  <article class="case-modal">
    <section class="case-modal__visual" aria-label="Project images">
      <div class="case-modal__image" data-gallery-stage>
        <img data-gallery-image alt="" hidden />
        <div class="case-modal__placeholder" data-gallery-placeholder>
          <Icon name="mdi:image-outline" size={38} decorative />
          <span>No project image available</span>
        </div>
      </div>

      <div class="case-modal__gallery-footer">
        <span data-gallery-count>No images</span>
        <span data-gallery-caption>No preview asset</span>
      </div>
      <div class="case-modal__thumbs" data-gallery-thumbs hidden aria-label="Select project image"></div>
    </section>

    <div class="case-modal__story">
      <header class="case-modal__intro">
        <div class="case-modal__meta">
          <span data-field="type">Type</span>
          <span data-field="status-label">Status</span>
          <span data-field="period">Period</span>
        </div>
        <p class="case-modal__role">
          <span>Role</span>
          <strong data-field="role">Role</strong>
        </p>
        <p class="case-modal__summary" data-field="summary">Summary</p>
      </header>

      <section class="case-modal__block" data-block="problem" hidden>
        <h3>Context</h3>
        <p data-field="problem"></p>
      </section>

      <section class="case-modal__block" data-block="contribution" hidden>
        <h3>Contribution</h3>
        <ul class="case-modal__list" data-field="contribution"></ul>
      </section>

      <section class="case-modal__block" data-block="outcomes" hidden>
        <h3>System outcomes</h3>
        <dl class="case-modal__outcomes" data-field="outcomes"></dl>
      </section>

      <section class="case-modal__block case-modal__stack-block">
        <h3>Technology</h3>
        <div class="case-modal__stack" data-field="stack"></div>
      </section>

      <section class="case-modal__block case-modal__links" data-block="links">
        <h3>Project access</h3>
        <div class="case-modal__links-inner" data-field="links"></div>
        <p class="case-modal__no-links" data-field="no-links" hidden>
          This project does not have a public link.
        </p>
      </section>
    </div>
  </article>
</Modal>

<script type="application/json" id="project-data" set:html={JSON.stringify(payload)} is:inline />

<style>
  :global(.project-case-modal) {
    z-index: 10000;
    padding: clamp(.75rem, 2vw, 1.5rem);
  }
  :global(.project-case-modal .modal__backdrop) { background: rgba(5,5,5,.88); backdrop-filter: blur(12px); }
  :global(.project-case-modal .modal__panel) {
    width: min(1420px, 100%);
    max-height: calc(100dvh - clamp(1.5rem, 4vw, 3rem));
    border: 1px solid #303030;
    background: #090909;
    box-shadow: 0 40px 120px rgba(0,0,0,.65);
    overflow: hidden;
    animation: none;
  }
  :global(.project-case-modal .modal__header) { min-height: 5.4rem; align-items: center; padding: 1.2rem clamp(1.25rem, 3vw, 3rem); border-bottom: 1px solid #2b2b2b; background: #090909; }
  :global(.project-case-modal .modal__title) { max-width: 24ch; font-size: clamp(1.45rem, 2.6vw, 2.8rem); line-height: .95; letter-spacing: -.05em; }
  :global(.project-case-modal .modal__close) { width: 3rem; height: 3rem; border: 1px solid #383838; border-radius: 0; background: transparent; transition: transform .3s cubic-bezier(.16,1,.3,1), color .25s ease, background .25s ease; }
  :global(.project-case-modal .modal__close:hover), :global(.project-case-modal .modal__close:focus-visible) { color: #111; background: #cba6f7; transform: rotate(8deg); outline: none; }
  :global(.project-case-modal .modal__body) { padding: 0; overflow-y: auto; }
  .case-modal { display: grid; grid-template-columns: minmax(0, 1.18fr) minmax(380px, .82fr); min-height: 0; }
  .case-modal__visual { position: sticky; top: 0; align-self: start; min-width: 0; padding: clamp(1rem, 2vw, 1.5rem); border-right: 1px solid #2b2b2b; background: #070707; }
  .case-modal__image { position: relative; min-height: min(63dvh, 700px); overflow: hidden; background: #111; }
  .case-modal__image img { width: 100%; height: 100%; position: absolute; inset: 0; object-fit: cover; filter: saturate(.78) brightness(.8); animation: case-image-in .65s cubic-bezier(.16,1,.3,1); }
  .case-modal__placeholder { position: absolute; inset: 0; display: grid; place-content: center; justify-items: center; gap: .75rem; color: #777; font-family: var(--font-mono); font-size: .72rem; }
  .case-modal__placeholder[hidden], .case-modal__thumbs[hidden] { display: none; }
  .case-modal__gallery-footer { display: flex; justify-content: space-between; gap: 1rem; padding: 1rem 0 0; color: #717171; font-family: var(--font-mono); font-size: .63rem; }
  .case-modal__gallery-footer span:last-child { color: #969696; text-align: right; }
  .case-modal__thumbs { display: grid; grid-template-columns: repeat(auto-fill, minmax(72px, 1fr)); gap: .5rem; margin-top: 1rem; }
  :global(.pm-thumb) { position: relative; aspect-ratio: 16/10; padding: 0; overflow: hidden; border: 1px solid #303030; border-radius: 0; background: #111; opacity: .45; transition: opacity .25s ease, border-color .25s ease, transform .25s cubic-bezier(.16,1,.3,1); }
  :global(.pm-thumb:hover), :global(.pm-thumb:focus-visible) { opacity: .8; transform: translateY(-2px); outline: none; }
  :global(.pm-thumb[aria-selected="true"]) { opacity: 1; border-color: #a786c6; box-shadow: none; }
  :global(.pm-thumb img) { width: 100%; height: 100%; object-fit: cover; filter: saturate(.7) brightness(.78); }
  .case-modal__story { min-width: 0; padding: clamp(2rem, 4vw, 4rem); }
  .case-modal__intro { display: grid; gap: 2rem; padding-bottom: clamp(3rem, 6vh, 5rem); }
  .case-modal__meta { display: flex; flex-wrap: wrap; gap: .75rem 1.5rem; color: #767676; font-family: var(--font-mono); font-size: .61rem; letter-spacing: .07em; text-transform: uppercase; }
  .case-modal__meta span:nth-child(2) { color: #c19be5; }
  .case-modal__role { display: grid; gap: .4rem; }
  .case-modal__role > span, .case-modal__block h3 { color: #686868; font-family: var(--font-mono); font-size: .62rem; letter-spacing: .08em; text-transform: uppercase; }
  .case-modal__role strong { color: #bdbdbd; font-size: .88rem; font-weight: 500; }
  .case-modal__summary { color: #e0e0e0; font-size: clamp(1.45rem, 2.5vw, 2.65rem); line-height: 1.18; letter-spacing: -.045em; }
  .case-modal__block { display: grid; grid-template-columns: minmax(100px, .3fr) minmax(0, 1fr); gap: clamp(1.5rem, 3vw, 3rem); padding: clamp(2rem, 4vh, 3rem) 0; border-top: 1px solid #2d2d2d; }
  .case-modal__block[hidden] { display: none; }
  .case-modal__block > p { color: #8d8d8d; line-height: 1.7; }
  .case-modal__list { display: grid; gap: 1rem; margin: 0; padding: 0; list-style: none; }
  .case-modal__list li { position: relative; padding-left: 1.25rem; color: #8d8d8d; line-height: 1.6; }
  .case-modal__list li::before { content: "/"; position: absolute; left: 0; color: #a786c6; font-family: var(--font-mono); }
  .case-modal__outcomes { display: grid; gap: 1.5rem; margin: 0; }
  .case-modal__outcomes > :global(div) { display: grid; grid-template-columns: minmax(90px, .35fr) 1fr; gap: 1rem; }
  .case-modal__outcomes :global(dt) { color: #7b7b7b; font-family: var(--font-mono); font-size: .65rem; text-transform: uppercase; }
  .case-modal__outcomes :global(dd) { margin: 0; color: #b8b8b8; line-height: 1.5; }
  .case-modal__stack { display: flex; flex-wrap: wrap; gap: .55rem; }
  :global(.pm-chip) { display: inline-flex; padding: .42rem .66rem; border: 1px solid #303030; border-radius: 0; background: transparent; color: #aaa; font-family: var(--font-mono); font-size: .67rem; }
  .case-modal__links-inner { display: flex; flex-wrap: wrap; gap: .65rem; }
  :global(.pm-link) { display: inline-flex; align-items: center; min-height: 2.8rem; padding: .65rem .9rem; border: 1px solid #3a3a3a; border-radius: 0; background: transparent; color: #ddd; font-family: var(--font-mono); font-size: .72rem; transition: transform .25s cubic-bezier(.16,1,.3,1), border-color .25s ease; }
  :global(.pm-link:hover), :global(.pm-link:focus-visible) { transform: translateY(-2px); border-color: #a786c6; outline: none; }
  :global(.pm-link--primary) { color: #111; background: #cba6f7; border-color: #cba6f7; }
  .case-modal__no-links { color: #777; font-family: var(--font-mono); font-size: .72rem; }
  @keyframes case-image-in { from { opacity: 0; transform: scale(1.035); } }
  @media (max-width: 900px) {
    :global(.project-case-modal .modal__panel) { max-height: calc(100dvh - 1.5rem); }
    .case-modal { grid-template-columns: 1fr; }
    .case-modal__visual { position: relative; border-right: 0; border-bottom: 1px solid #2b2b2b; }
    .case-modal__image { min-height: 46dvh; }
  }
  @media (max-width: 600px) {
    :global(.project-case-modal) { padding: .5rem; }
    :global(.project-case-modal .modal__header) { min-height: 4.5rem; }
    .case-modal__image { min-height: 34dvh; }
    .case-modal__story { padding: 1.5rem; }
    .case-modal__block { grid-template-columns: 1fr; gap: 1rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    .case-modal__image img { animation: none; }
    :global(.pm-thumb), :global(.pm-link), :global(.project-case-modal .modal__close) { transition: none; }
  }
</style>
