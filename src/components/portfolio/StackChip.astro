---
interface Props {
  label: string;
  accent?: string;
}
const { label } = Astro.props;
---

<span class="stack-chip">{label}</span>

<style>
  .stack-chip {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    color: var(--text);
    background: rgba(49, 50, 68, 0.58);
    border: 1px solid var(--border-dim);
    border-left: 2px solid rgba(203, 166, 247, 0.42);
    padding: 0.3rem 0.55rem;
    border-radius: 2px;
    line-height: 1;
  }
</style>
