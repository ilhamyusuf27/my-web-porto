---
import { filterProjects, projects, projectFilters } from "../../data/projects";
import Icon from "../ui/Icon.astro";

const visibleFilters = projectFilters.filter((filter) => filter.id !== "all");
const firstProject = projects[0];

const statusLabels: Record<string, string> = {
  completed: "Completed",
  ongoing: "Ongoing",
  experimental: "Experimental",
};

const categoryLabels: Record<string, string> = {
  work: "Client work",
  personal: "Personal",
  experimental: "R&D",
  ongoing: "Build queue",
};

const getImages = (project: (typeof projects)[number]) =>
  project.images?.length
    ? project.images
    : project.image
      ? [{ src: project.image, alt: `${project.title} preview` }]
      : [];

const firstProjectImages = firstProject ? getImages(firstProject) : [];
---

<div class="directory" data-project-grid data-project-directory data-view="list">
  <aside class="directory__folders" aria-label="Project folders">
    <div class="directory__panel-head">
      <span>Folders</span>
      <span>{projects.length} files</span>
    </div>

    <button type="button" class="directory__folder is-active" data-filter="all" aria-pressed="true" aria-current="true">
      <span class="directory__folder-label">
        <span class="directory__folder-icon directory__folder-icon--closed">
          <Icon name="mdi:folder-outline" size={16} decorative />
        </span>
        <span class="directory__folder-icon directory__folder-icon--open">
          <Icon name="mdi:folder-open-outline" size={16} decorative />
        </span>
        All case files
      </span>
      <span>{projects.length}</span>
    </button>

    {
      visibleFilters.map((filter) => {
        const count = filterProjects(filter.id).length;
        return (
          <button type="button" class="directory__folder" data-filter={filter.id} aria-pressed="false">
            <span class="directory__folder-label">
              <span class="directory__folder-icon directory__folder-icon--closed">
                <Icon name="mdi:folder-outline" size={16} decorative />
              </span>
              <span class="directory__folder-icon directory__folder-icon--open">
                <Icon name="mdi:folder-open-outline" size={16} decorative />
              </span>
              {filter.label}
            </span>
            <span>{count}</span>
          </button>
        );
      })
    }
  </aside>

  <div class="directory__files">
    <div class="directory__panel-head directory__panel-head--files">
      <span>Case files</span>
      <span data-project-count>{projects.length} shown</span>
      <div class="directory__view-toggle" aria-label="Project view mode">
        <button type="button" class="is-active" data-view-toggle="list" aria-pressed="true">List</button>
        <button type="button" data-view-toggle="grid" aria-pressed="false">Grid</button>
      </div>
    </div>

    <div class="directory__file-list" data-view-panel="list" aria-label="Project case files list">
      {
        projects.map((project, index) => {
          const imageCount = getImages(project).length;
          return (
            <button
              type="button"
              class={`directory__file ${index === 0 ? "is-selected" : ""}`}
              data-category={project.category}
              data-project-select={project.id}
              aria-label={`Select case file for ${project.title}`}
              aria-current={index === 0 ? "true" : "false"}
            >
              <span class="directory__file-icon" aria-hidden="true">
                <Icon name="mdi:file-document-outline" size={18} decorative />
              </span>
              <span class="directory__file-main">
                <span class="directory__file-title">{project.title}</span>
                <span class="directory__file-meta">
                  {categoryLabels[project.category] ?? project.category} / {project.period}
                </span>
              </span>
              <span class="directory__file-side">
                <span>{statusLabels[project.status] ?? project.status}</span>
                <span>{imageCount ? `${imageCount} image${imageCount > 1 ? "s" : ""}` : "No image"}</span>
              </span>
            </button>
          );
        })
      }
    </div>

    <div class="directory__card-grid" data-view-panel="grid" aria-label="Project case files grid" hidden>
      {
        projects.map((project, index) => {
          const imageCount = getImages(project).length;
          return (
            <button
              type="button"
              class={`directory__card ${index === 0 ? "is-selected" : ""}`}
              data-category={project.category}
              data-project-select={project.id}
              aria-label={`Select case file for ${project.title}`}
              aria-current={index === 0 ? "true" : "false"}
            >
              <span class="directory__card-top">
                <Icon name="mdi:file-document-outline" size={17} decorative />
                <span>{statusLabels[project.status] ?? project.status}</span>
              </span>
              <span class="directory__card-title">{project.title}</span>
              <span class="directory__card-meta">{categoryLabels[project.category] ?? project.category}</span>
              <span class="directory__card-foot">
                <span>{project.period}</span>
                <span>{imageCount ? `${imageCount} img` : "No image"}</span>
              </span>
            </button>
          );
        })
      }
    </div>

    <p class="directory__empty" data-project-empty hidden>No case files in this folder.</p>
  </div>

  <aside class="directory__preview" data-project-preview aria-live="polite">
    {
      firstProject ? (
        <>
          <div class="directory__preview-media" data-preview-media>
            <img
              src={firstProjectImages[0]?.src}
              alt=""
              loading="lazy"
              decoding="async"
              data-preview-image
              hidden={firstProjectImages.length === 0}
            />
            <div class="directory__preview-placeholder" data-preview-placeholder hidden={firstProjectImages.length > 0}>
              <Icon name="mdi:file-document-outline" size={34} decorative />
              <span>No preview image</span>
            </div>
          </div>

          <div class="directory__preview-body" data-preview-body>
            <div class="directory__preview-kicker" data-preview-type>{firstProject.type}</div>
            <h3 data-preview-title>{firstProject.title}</h3>
            <p data-preview-summary>{firstProject.summary}</p>

            <dl class="directory__preview-meta">
              <div>
                <dt>Status</dt>
                <dd data-preview-status>{statusLabels[firstProject.status]}</dd>
              </div>
              <div>
                <dt>Images</dt>
                <dd data-preview-image-count>{firstProjectImages.length ? `${firstProjectImages.length} available` : "No image"}</dd>
              </div>
              <div>
                <dt>Role</dt>
                <dd data-preview-role>{firstProject.role}</dd>
              </div>
            </dl>

            <div class="directory__preview-stack" data-preview-stack>
              {firstProject.stack.slice(0, 5).map((item) => <span>{item}</span>)}
            </div>

            <div class="directory__preview-actions">
              <button type="button" class="directory__open" data-preview-open data-project-trigger={firstProject.id}>
                Open case file
                <Icon name="mdi:arrow-top-right" size={15} decorative />
              </button>
              <span class="directory__link-state" data-preview-link-state>
                {firstProject.links?.length ? `${firstProject.links.length} public link${firstProject.links.length > 1 ? "s" : ""}` : "No public link"}
              </span>
            </div>
          </div>
        </>
      ) : (
        <p class="directory__empty">No case files available.</p>
      )
    }
  </aside>
</div>

<style>
  .directory {
    --directory-panel: rgba(24, 24, 37, 0.76);
    --directory-panel-strong: rgba(30, 30, 46, 0.88);
    display: grid;
    grid-template-columns: minmax(150px, 0.72fr) minmax(330px, 1.48fr) minmax(280px, 1fr);
    min-height: 0;
    height: 100%;
    border: 1px solid var(--border-dim);
    background: linear-gradient(180deg, rgba(49, 50, 68, 0.34), rgba(17, 17, 27, 0.2));
    box-shadow: 0 18px 60px rgba(17, 17, 27, 0.34);
    backdrop-filter: blur(10px);
    overflow: hidden;
    animation: directory-in 0.48s ease both;
  }

  .directory__folders,
  .directory__files,
  .directory__preview {
    min-height: 0;
    background: var(--directory-panel);
  }

  .directory__folders,
  .directory__files {
    border-right: 1px solid var(--border-dim);
  }

  .directory__panel-head {
    min-height: 2.55rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.7rem;
    padding: 0.7rem 0.85rem;
    border-bottom: 1px solid var(--border-dim);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--subtext-0);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .directory__panel-head--files {
    display: grid;
    grid-template-columns: auto 1fr auto;
  }

  .directory__panel-head--files [data-project-count] {
    justify-self: end;
  }

  .directory__view-toggle {
    display: inline-flex;
    border: 1px solid var(--border-dim);
    background: rgba(17, 17, 27, 0.38);
    border-radius: 3px;
    overflow: hidden;
  }

  .directory__view-toggle button {
    border: 0;
    background: transparent;
    color: var(--subtext-0);
    padding: 0.3rem 0.52rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
  }

  .directory__view-toggle button:hover,
  .directory__view-toggle button:focus-visible,
  .directory__view-toggle button.is-active {
    color: var(--text);
    background: rgba(203, 166, 247, 0.14);
  }

  .directory__folders {
    padding-bottom: 0.6rem;
  }

  .directory__folder {
    width: calc(100% - 1rem);
    margin: 0.5rem 0.5rem 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    border: 1px solid transparent;
    background: transparent;
    color: var(--subtext-1);
    padding: 0.62rem 0.65rem;
    text-align: left;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    border-radius: 3px;
    transition: transform 0.14s ease, background 0.14s ease, color 0.14s ease, border-color 0.14s ease;
  }

  .directory__folder:hover,
  .directory__folder:focus-visible {
    color: var(--text);
    background: rgba(49, 50, 68, 0.58);
    border-color: var(--border-dim);
    transform: translateX(2px);
  }

  .directory__folder.is-active {
    color: var(--text);
    background: rgba(203, 166, 247, 0.12);
    border-color: rgba(203, 166, 247, 0.42);
  }

  .directory__folder-label {
    min-width: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .directory__folder-icon {
    display: inline-flex;
    align-items: center;
  }

  .directory__folder-icon--open,
  .directory__folder.is-active .directory__folder-icon--closed {
    display: none;
  }

  .directory__folder.is-active .directory__folder-icon--open {
    display: inline-flex;
  }

  .directory__file-list,
  .directory__card-grid {
    height: calc(100% - 2.55rem);
    overflow: auto;
    scrollbar-width: thin;
  }

  .directory__file-list[hidden],
  .directory__card-grid[hidden] {
    display: none;
  }

  .directory__file-list {
    display: flex;
    flex-direction: column;
  }

  .directory__file,
  .directory__card {
    animation: file-in 0.38s ease both;
  }

  .directory__file {
    min-height: 4.25rem;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    border: 0;
    border-bottom: 1px solid rgba(147, 153, 178, 0.16);
    background: transparent;
    color: var(--text);
    padding: 0.66rem 0.85rem;
    text-align: left;
    transition: transform 0.14s ease, background 0.14s ease, color 0.14s ease;
  }

  .directory__file:hover,
  .directory__file:focus-visible,
  .directory__file.is-selected {
    background: rgba(49, 50, 68, 0.56);
  }

  .directory__file:hover,
  .directory__file:focus-visible {
    transform: translateX(2px);
  }

  .directory__file.is-selected,
  .directory__card.is-selected {
    box-shadow: inset 2px 0 0 var(--mauve);
  }

  .directory__file[hidden],
  .directory__card[hidden] {
    display: none;
  }

  .directory__file-icon {
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    color: var(--mauve);
    background: rgba(203, 166, 247, 0.1);
    border: 1px solid rgba(203, 166, 247, 0.24);
    border-radius: 3px;
  }

  .directory__file-main {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.28rem;
  }

  .directory__file-title,
  .directory__card-title {
    font-family: var(--font-heading);
    font-weight: 600;
    line-height: 1.15;
  }

  .directory__file-title {
    font-size: 0.95rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .directory__file-meta,
  .directory__file-side,
  .directory__card-meta,
  .directory__card-foot,
  .directory__card-top {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    line-height: 1.35;
    color: var(--subtext-0);
  }

  .directory__file-side {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.22rem;
    white-space: nowrap;
  }

  .directory__card-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-content: start;
    gap: 0.65rem;
    padding: 0.75rem;
  }

  .directory__card {
    min-height: 8.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.48rem;
    border: 1px solid var(--border-dim);
    background: rgba(24, 24, 37, 0.48);
    color: var(--text);
    padding: 0.72rem;
    text-align: left;
    border-radius: 3px;
    transition: transform 0.14s ease, background 0.14s ease, border-color 0.14s ease;
  }

  .directory__card:hover,
  .directory__card:focus-visible,
  .directory__card.is-selected {
    background: rgba(49, 50, 68, 0.58);
    border-color: rgba(203, 166, 247, 0.32);
  }

  .directory__card:hover,
  .directory__card:focus-visible {
    transform: translateY(-2px);
  }

  .directory__card-top,
  .directory__card-foot {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .directory__card-top {
    align-items: center;
  }

  .directory__card-title {
    color: var(--text);
    font-size: 0.95rem;
  }

  .directory__card-meta {
    color: var(--mauve);
  }

  .directory__card-foot {
    margin-top: auto;
    padding-top: 0.5rem;
    border-top: 1px solid rgba(147, 153, 178, 0.16);
  }

  .directory__preview {
    display: flex;
    flex-direction: column;
    background: var(--directory-panel-strong);
  }

  .directory__preview.is-updating .directory__preview-body,
  .directory__preview.is-updating .directory__preview-media {
    animation: preview-change 0.22s ease both;
  }

  .directory__preview-media {
    position: relative;
    aspect-ratio: 16 / 9;
    margin: 0.85rem;
    margin-bottom: 0;
    background: rgba(17, 17, 27, 0.72);
    border: 1px solid var(--border-dim);
    overflow: hidden;
  }

  .directory__preview-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.82) brightness(0.82);
  }

  .directory__preview-placeholder {
    height: 100%;
    display: grid;
    place-items: center;
    gap: 0.5rem;
    color: var(--subtext-0);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    background: linear-gradient(135deg, rgba(49, 50, 68, 0.45), rgba(17, 17, 27, 0.7));
  }

  .directory__preview-placeholder[hidden] {
    display: none;
  }

  .directory__preview-body {
    min-height: 0;
    display: flex;
    flex-direction: column;
    gap: 0.72rem;
    padding: 0.9rem;
  }

  .directory__preview-kicker {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    line-height: 1.35;
    color: var(--mauve);
  }

  .directory__preview h3 {
    font-size: clamp(1.12rem, 2.2vw, 1.45rem);
    line-height: 1.1;
  }

  .directory__preview p {
    color: var(--subtext-1);
    line-height: 1.5;
    font-size: 0.86rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .directory__preview-meta {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.5rem;
    margin: 0;
  }

  .directory__preview-meta div {
    border: 1px solid var(--border-dim);
    background: rgba(49, 50, 68, 0.38);
    padding: 0.52rem 0.58rem;
  }

  .directory__preview-meta dt {
    margin-bottom: 0.25rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--subtext-0);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .directory__preview-meta dd {
    margin: 0;
    color: var(--text);
    font-size: 0.76rem;
    line-height: 1.35;
  }

  .directory__preview-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.36rem;
  }

  .directory__preview-stack span {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    color: var(--subtext-1);
    border: 1px solid var(--border-dim);
    background: rgba(49, 50, 68, 0.42);
    padding: 0.25rem 0.42rem;
    border-radius: 2px;
  }

  .directory__preview-actions {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    border-top: 1px solid var(--border-dim);
    padding-top: 0.72rem;
  }

  .directory__open {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--crust);
    background: var(--mauve);
    border: 1px solid rgba(205, 214, 244, 0.58);
    padding: 0.56rem 0.74rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    border-radius: 3px;
    transition: transform 0.14s ease;
  }

  .directory__open:hover,
  .directory__open:focus-visible {
    transform: translateY(-1px);
  }

  .directory__open:disabled {
    cursor: not-allowed;
    color: var(--subtext-0);
    background: rgba(49, 50, 68, 0.45);
    border-color: var(--border-dim);
    transform: none;
  }

  .directory__link-state {
    color: var(--subtext-0);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-align: right;
  }

  .directory__empty {
    color: var(--subtext-0);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 1rem;
  }

  @keyframes directory-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
  }

  @keyframes file-in {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
  }

  @keyframes preview-change {
    from {
      opacity: 0.72;
      transform: translateY(4px);
    }
  }

  @media (max-width: 980px) {
    .directory {
      grid-template-columns: minmax(180px, 0.72fr) minmax(0, 1.35fr);
    }

    .directory__preview {
      grid-column: 1 / -1;
      min-height: 280px;
      border-top: 1px solid var(--border-dim);
    }
  }

  @media (max-width: 760px) {
    .directory {
      height: auto;
      min-height: 0;
      display: block;
      overflow: visible;
    }

    .directory__folders,
    .directory__files {
      border-right: 0;
      border-bottom: 1px solid var(--border-dim);
    }

    .directory__file-list,
    .directory__card-grid {
      height: auto;
      max-height: none;
      overflow: visible;
    }

    .directory__file {
      grid-template-columns: auto minmax(0, 1fr);
    }

    .directory__file-side {
      grid-column: 2;
      align-items: flex-start;
      flex-direction: row;
      flex-wrap: wrap;
    }

    .directory__card-grid {
      grid-template-columns: 1fr;
    }

    .directory__preview-meta {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .directory,
    .directory__file,
    .directory__card,
    .directory__preview.is-updating .directory__preview-body,
    .directory__preview.is-updating .directory__preview-media {
      animation: none;
    }

    .directory__folder:hover,
    .directory__folder:focus-visible,
    .directory__file:hover,
    .directory__file:focus-visible,
    .directory__card:hover,
    .directory__card:focus-visible,
    .directory__open:hover,
    .directory__open:focus-visible {
      transform: none;
    }
  }
</style>
