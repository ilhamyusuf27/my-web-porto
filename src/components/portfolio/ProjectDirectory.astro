---
import Icon from "../ui/Icon.astro";
import { projects } from "../../data/projects";

const selectedProjects = projects.filter((project) => project.category === "work").slice(0, 5);
---

<div class="work-bento" data-project-grid data-work-bento>
  {selectedProjects.map((project, index) => (
    <article class={`work-tile work-tile--${index + 1}`} data-project-select={project.id} data-work-tile>
      <button
        type="button"
        class="work-tile__trigger"
        data-project-trigger={project.id}
        aria-label={`Open case study: ${project.title}`}
      >
        <figure class="work-tile__media">
          {project.image ? (
            <img src={project.image} alt={`${project.title} interface`} loading="lazy" decoding="async" />
          ) : (
            <span>No preview available</span>
          )}
          <span class="work-tile__arrow" aria-hidden="true">
            <Icon name="mdi:arrow-top-right" size={22} />
          </span>
        </figure>

        <div class="work-tile__body">
          <div class="work-tile__meta">
            <span>{project.period}</span>
            <span>{project.type}</span>
          </div>
          <h3>{project.title}</h3>
          <p>{project.summary}</p>
          <footer>
            <span>{project.role}</span>
            <strong>Open case study</strong>
          </footer>
        </div>
      </button>
    </article>
  ))}
</div>

<style>
  .work-bento {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    grid-template-rows: 410px 330px 390px;
    gap: clamp(.75rem, 1.5vw, 1.25rem);
  }
  .work-tile { min-width: 0; border: 1px solid #292929; background: #090909; overflow: hidden; }
  .work-tile--1 { grid-column: 1 / span 8; grid-row: 1 / span 2; }
  .work-tile--2 { grid-column: 9 / span 4; grid-row: 1; }
  .work-tile--3 { grid-column: 9 / span 4; grid-row: 2; }
  .work-tile--4 { grid-column: 1 / span 5; grid-row: 3; }
  .work-tile--5 { grid-column: 6 / span 7; grid-row: 3; }
  .work-tile__trigger { width: 100%; height: 100%; display: grid; grid-template-rows: minmax(0, 1.35fr) minmax(240px, .65fr); padding: 0; border: 0; background: transparent; color: #eee; text-align: left; }
  .work-tile--2 .work-tile__trigger, .work-tile--3 .work-tile__trigger { grid-template-rows: minmax(0, 1fr) auto; }
  .work-tile--4 .work-tile__trigger, .work-tile--5 .work-tile__trigger { grid-template-columns: minmax(0, .9fr) minmax(260px, 1fr); grid-template-rows: 1fr; }
  .work-tile__media { position: relative; min-height: 0; margin: 0; overflow: hidden; background: #111; }
  .work-tile__media::after { content: ""; position: absolute; inset: 0; background: linear-gradient(to top, rgba(7,7,7,.44), transparent 45%); pointer-events: none; }
  .work-tile__media img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(.9) brightness(.58) contrast(1.12); transform: scale(1.02); transition: transform .9s cubic-bezier(.16,1,.3,1), filter .8s ease; }
  .work-tile__arrow { position: absolute; z-index: 2; top: 1rem; right: 1rem; display: grid; place-items: center; width: 3rem; height: 3rem; color: #d3b3f2; border: 1px solid rgba(203,166,247,.34); background: rgba(8,8,8,.72); transition: transform .35s cubic-bezier(.16,1,.3,1), color .3s ease, background .3s ease; }
  .work-tile__body { display: flex; flex-direction: column; min-width: 0; padding: clamp(1.35rem, 3vw, 2.6rem); }
  .work-tile__meta { display: flex; justify-content: space-between; gap: 1.25rem; color: #666; font-family: var(--font-mono); font-size: .61rem; letter-spacing: .06em; text-transform: uppercase; }
  .work-tile__meta span:last-child { max-width: 28ch; overflow: hidden; text-align: right; text-overflow: ellipsis; white-space: nowrap; }
  .work-tile h3 { max-width: 14ch; margin-top: auto; font-size: clamp(2rem, 4vw, 5.2rem); line-height: .9; letter-spacing: -.065em; }
  .work-tile--2 h3, .work-tile--3 h3 { font-size: clamp(1.35rem, 2.1vw, 2.35rem); }
  .work-tile--4 h3, .work-tile--5 h3 { font-size: clamp(1.8rem, 3vw, 3.5rem); }
  .work-tile p { display: -webkit-box; max-width: 54ch; margin-top: 1rem; overflow: hidden; color: #787878; font-size: .84rem; line-height: 1.55; -webkit-box-orient: vertical; -webkit-line-clamp: 2; }
  .work-tile--2 p, .work-tile--3 p { display: none; }
  .work-tile footer { display: flex; justify-content: space-between; gap: 1rem; margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid #292929; color: #777; font-size: .68rem; }
  .work-tile footer strong { color: #c6c6c6; font-weight: 500; }
  .work-tile--2 footer, .work-tile--3 footer { display: none; }
  .work-tile__trigger:hover img, .work-tile__trigger:focus-visible img { transform: scale(1.075); filter: grayscale(.1) brightness(.78) contrast(1.05); }
  .work-tile__trigger:hover .work-tile__arrow, .work-tile__trigger:focus-visible .work-tile__arrow { color: #111; background: #cba6f7; transform: rotate(8deg); }
  .work-tile__trigger:focus-visible { outline: 2px solid #cba6f7; outline-offset: -2px; }
  @media (max-width: 900px) {
    .work-bento { grid-template-columns: repeat(2, minmax(0, 1fr)); grid-template-rows: auto; }
    .work-tile, .work-tile:nth-child(n) { grid-column: auto; grid-row: auto; min-height: 480px; }
    .work-tile--1 { grid-column: 1 / -1; min-height: 680px; }
    .work-tile--5 { grid-column: 1 / -1; }
    .work-tile--4 .work-tile__trigger, .work-tile--5 .work-tile__trigger { grid-template-columns: 1fr; grid-template-rows: minmax(240px, 1fr) auto; }
  }
  @media (max-width: 640px) {
    .work-bento { grid-template-columns: 1fr; }
    .work-tile, .work-tile:nth-child(n) { grid-column: 1; min-height: 520px; }
    .work-tile--1 { min-height: 620px; }
    .work-tile__trigger, .work-tile--2 .work-tile__trigger, .work-tile--3 .work-tile__trigger { grid-template-rows: minmax(260px, 1fr) auto; }
    .work-tile--2 p, .work-tile--3 p { display: -webkit-box; }
    .work-tile--2 footer, .work-tile--3 footer { display: flex; }
  }
  @media (prefers-reduced-motion: reduce) {
    .work-tile__media img, .work-tile__arrow { transition: none; }
  }
</style>
