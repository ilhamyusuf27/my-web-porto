---
interface Props {
  accent?: string;
  hud?: string;
  class?: string;
  interactive?: boolean;
  ["aria-label"]?: string;
}

const { hud, class: className = "", interactive = false } = Astro.props;
---

<div
  class:list={["pixel-card", "pixel-card--custom", { interactive }, className]}
  style="--card-accent: var(--mauve);"
  aria-label={Astro.props["aria-label"]}
>
  {hud && (
    <span class="pixel-card__hud" aria-hidden="true">
      <span class="pixel-card__dot" />
      {hud}
    </span>
  )}
  <slot />
</div>

<style>
  .pixel-card--custom {
    --accent: var(--mauve);
    position: relative;
    padding: clamp(1rem, 2.5vw, 1.75rem);
    border-top: 1px solid rgba(203, 166, 247, 0.34);
    transition: transform 0.12s ease, box-shadow 0.12s ease, border-color 0.12s ease;
  }

  .pixel-card--custom::before,
  .pixel-card--custom::after {
    content: "";
    position: absolute;
    width: 8px;
    height: 8px;
    border-color: rgba(203, 166, 247, 0.55);
    pointer-events: none;
  }

  /* top-left corner bracket */
  .pixel-card--custom::before {
    top: -2px;
    left: -2px;
    border-top: 1px solid rgba(203, 166, 247, 0.55);
    border-left: 1px solid rgba(203, 166, 247, 0.55);
  }

  /* bottom-right corner bracket */
  .pixel-card--custom::after {
    bottom: -2px;
    right: -2px;
    border-bottom: 1px solid rgba(203, 166, 247, 0.55);
    border-right: 1px solid rgba(203, 166, 247, 0.55);
  }

  .pixel-card__hud {
    position: absolute;
    top: 0;
    right: 14px;
    transform: translateY(-50%);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--subtext-0);
    background: var(--surface-panel);
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--border-dim);
    z-index: 1;
  }

  .pixel-card__dot {
    width: 6px;
    height: 6px;
    background: var(--mauve);
    display: inline-block;
  }

  .pixel-card--custom.interactive {
    cursor: pointer;
  }

  .pixel-card--custom.interactive:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 rgba(17, 17, 27, 0.82), 0 0 0 1px rgba(203, 166, 247, 0.34);
  }
</style>
