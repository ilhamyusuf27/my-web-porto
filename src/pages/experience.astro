---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import TabNav from "../components/TabNav.astro";
import ExperienceItem from "../components/ExperienceItem.astro";

const experiences = [
  ["Madeindonesia", "Front-End Web Developer", "Aug 2025 – Present", "Developed and maintained WordPress webshop projects using HTML, SCSS, jQuery, PHP, and WooCommerce."],
  ["Tomps by Telkom Indonesia", "Front-End Web Developer", "Jan 2023 – Mar 2025", "Built and maintained tomps.id, Tomps Admin, and Tomps Project using Vue, Nuxt, Next.js, and unit testing with Jest, React Testing Library, and Vitest."],
  ["Telkom Indonesia", "Front-End Web Developer", "Sep 2022 – Dec 2022", "Developed dashboard interfaces with React, Tailwind CSS, Bootstrap, Jest, and Enzyme for projects including HunianAja / Tomps Building."],
  ["UGM FK-KMK", "IT Assistant · Contract", "Nov 2020 – Apr 2021", "Created posters, live-stream overlays, broadcast support, and video editing for seminars and learning materials."],
];

const education = [
  ["Pijar Camp", "Full-Stack Website Developer", "May 2022 – Aug 2022", "JavaScript, Node.js, Express.js, React.js, Next.js, time management, public speaking."],
  ["Universitas AMIKOM Yogyakarta", "S1 Informatics · GPA 3.85 / 4.00", "Sep 2017 – Aug 2021", "Graduated cum laude; studied web development, C++, C#, multimedia, animation, AR, and interactive media."],
];

const tabs = [
  { id: "work", label: "Work", count: experiences.length },
  { id: "education", label: "Education", count: education.length },
];
---

<Layout title="CV" description="CV, work experience, and education for Ilham Yusuf Alghani.">
  <main class="page-shell">
    <section class="page-card">
      <nav class="crumb"><a href="/" data-astro-reload>← Home</a><span>CV</span></nav>
      <header>
        <p>Career overview</p>
        <h1>Experience & Education</h1>
      </header>

      <TabNav items={tabs} defaultId="work" ariaLabel="CV sections" />

      <section class="archive-section" data-category="work">
        <h2>Work Experience</h2>
        <div class="timeline-list">
          {experiences.map(([company, role, date, desc]) => (
            <ExperienceItem title={company} role={role} date={date} description={desc} />
          ))}
        </div>
      </section>

      <section class="archive-section" data-category="education" hidden>
        <h2>Education</h2>
        <div class="timeline-list compact">
          {education.map(([school, role, date, desc]) => (
            <ExperienceItem title={school} role={role} date={date} description={desc} />
          ))}
        </div>
      </section>
    </section>
  </main>
</Layout>

<script>
  function initHashRouter(tabsSelector, panelsSelector, defaultHash) {
    const tabs = document.querySelectorAll(tabsSelector);
    const panels = document.querySelectorAll(panelsSelector);
    if (!tabs.length || !panels.length) return;

    function switchTab(hash) {
      const targetHash = hash || defaultHash;
      let found = false;
      tabs.forEach((tab) => {
        const isTarget = tab.getAttribute('href') === targetHash;
        tab.classList.toggle('is-active', isTarget);
        tab.setAttribute('aria-selected', isTarget ? 'true' : 'false');
        if (isTarget) found = true;
      });
      if (!found && defaultHash && targetHash !== defaultHash) {
        switchTab(defaultHash);
        if (window.location.hash) history.replaceState(null, '', defaultHash);
        return;
      }
      panels.forEach((panel) => {
        panel.hidden = `#${panel.dataset.category}` !== targetHash;
      });
    }

    tabs.forEach((tab) => tab.addEventListener('click', () => window.setTimeout(() => switchTab(window.location.hash), 0)));
    window.addEventListener('hashchange', () => switchTab(window.location.hash));
    switchTab(window.location.hash);
  }

  document.addEventListener('astro:page-load', () => {
    initHashRouter('.tab-btn[href]', '.archive-section[data-category]', '#work');
  });
</script>

<style>
  :global(html), :global(body) { overflow: auto; }
  .page-shell { height: 100svh; overflow: hidden; display: grid; place-items: center; padding: clamp(1rem, 3vw, 2rem); background: radial-gradient(circle at 20% 10%, rgba(203,166,247,.22), transparent 28rem), var(--crust); color: var(--text); }
  .page-card { width: min(100%, 1080px); max-height: calc(100svh - 4rem); overflow-y: auto; overscroll-behavior: contain; scrollbar-width: thin; scrollbar-color: var(--mauve) rgba(49,50,68,.34); border: 1px solid var(--border); background: rgba(30,30,46,.88); padding: clamp(1rem, 3vw, 2rem); box-shadow: 0 24px 80px rgba(0,0,0,.36); }
  .crumb { display: flex; justify-content: space-between; gap: 1rem; margin-bottom: 2rem; font-family: var(--mono); font-size: .78rem; text-transform: uppercase; }
  a { color: var(--mauve); text-decoration: none; }
  header p { margin: 0; color: var(--mauve); font-family: var(--mono); font-size: .72rem; text-transform: uppercase; letter-spacing: .12em; }
  h1 { max-width: 12ch; margin: .5rem 0 1rem; color: var(--rosewater); font-size: clamp(2.2rem, 6vw, 4.5rem); line-height: .92; letter-spacing: -.06em; }
  :global(.tab-bar) { display: flex; flex-wrap: wrap; gap: .42rem; margin-bottom: 1.15rem; font-family: var(--mono); text-transform: uppercase; letter-spacing: .12em; }
  :global(.tab-btn) { display: inline-flex; align-items: center; gap: .42rem; padding: .48rem .72rem; border: 1px solid var(--surface1); background: rgba(17,17,27,.62); color: var(--subtext0); font-family: var(--mono); font-size: .72rem; cursor: pointer; box-shadow: 3px 3px 0 rgba(17,17,27,.38); transition: border-color 140ms ease, color 140ms ease, transform 140ms ease, background 140ms ease; }
  :global(.tab-btn b) { min-width: 1.35rem; padding: .1rem .28rem; border: 1px solid rgba(148,226,213,.32); color: var(--teal); text-align: center; font-size: .6rem; }
  :global(.tab-btn:hover) { border-color: var(--mauve); color: var(--rosewater); transform: translate(-2px, -2px); }
  :global(.tab-btn.is-active) { border-color: var(--mauve); background: rgba(203,166,247,.12); color: var(--rosewater); box-shadow: 0 0 16px rgba(203,166,247,.1), 3px 3px 0 rgba(17,17,27,.38); }
  .archive-section[hidden] { display: none; }
  h2 { margin: 0 0 .8rem; color: var(--lavender); font-size: 1rem; }
  .timeline-list { display: grid; gap: 1.1rem; position: relative; padding-left: 1.5rem; }
  :global(.timeline-item) { position: relative; display: grid; }
  :global(.timeline-item:not(:last-child)::after) { content: ""; position: absolute; left: -19px; top: 23px; bottom: -1.1rem; width: 1px; border-left: 1px dashed var(--surface2); }
  :global(.timeline-dot) { position: absolute; left: -23px; top: 10px; width: 9px; height: 9px; background: var(--crust); border: 2px solid var(--mauve); box-shadow: 0 0 8px rgba(203,166,247,.72); transform: rotate(45deg); z-index: 1; }
  :global(.timeline-content) { border: 1px solid var(--surface1); background: rgba(49,50,68,.2); padding: 1rem 1.25rem; transition: border-color 140ms ease, transform 140ms ease, box-shadow 140ms ease; }
  :global(.timeline-content:hover) { border-color: var(--mauve); transform: translateX(3px); box-shadow: 4px 4px 0 rgba(17,17,27,.35); }
  :global(.timeline-header) { display: flex; justify-content: space-between; gap: 1rem; align-items: baseline; }
  :global(.timeline-header h3) { margin: 0; color: var(--text); font-size: 1.1rem; }
  :global(.timeline-date) { color: var(--mauve); font-family: var(--mono); font-size: .72rem; text-transform: uppercase; letter-spacing: .12em; white-space: nowrap; }
  :global(.timeline-role) { display: block; color: var(--teal); font-size: .88rem; margin: .34rem 0 .45rem; }
  :global(.timeline-desc) { margin: 0; color: var(--subtext1); line-height: 1.5; }
  @media (max-width: 720px) { .page-card { max-height: calc(100svh - 2rem); } :global(.timeline-header) { display: grid; gap: .25rem; } }
</style>
