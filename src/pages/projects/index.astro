---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import TabNav from "../../components/TabNav.astro";
import ProjectRow from "../../components/ProjectRow.astro";
import { archiveCategories, projectHref } from "../../data/projects";

const categories = archiveCategories;
const tabItems = categories.map((category) => ({ id: category.id, label: category.title, count: category.projects.length }));
const defaultCategory = categories[0]?.id ?? "production";
---

<Layout title="Project archive" description="Categorized portfolio projects from work, freelance, learning, and ongoing tracks.">
  <main class="page-shell">
    <section class="page-card">
      <nav class="crumb"><a href="/" data-astro-reload>← Home</a><span>Project archive</span></nav>
      <header class="archive-hero">
        <p>Project overview</p>
        <h1>Categorized work, learning labs, and ongoing builds.</h1>
        <TabNav items={tabItems} defaultId={defaultCategory} ariaLabel="Project categories" />
      </header>
      <div class="category-stack">
        {categories.map((category) => (
          <section class="archive-section" id={category.id} data-category={category.id} hidden={category.id !== defaultCategory}>
            <div class="section-title">
              <span>{category.eyebrow}</span>
              <h2>{category.title}</h2>
              <p>{category.summary}</p>
            </div>
            <div class="project-list">
              {category.projects.map((project) => (
                <ProjectRow
                  href={"href" in project ? project.href : projectHref(project.slug)}
                  status={project.status}
                  period={project.period}
                  title={"name" in project ? project.name : project.title}
                  stack={Array.isArray(project.stack) ? project.stack.join(" · ") : project.stack}
                  description={"description" in project ? project.description : project.cardDescription}
                />
              ))}
            </div>
          </section>
        ))}
      </div>
    </section>
  </main>
</Layout>

<script>
  function initHashRouter(tabsSelector, panelsSelector, defaultHash) {
    const tabs = document.querySelectorAll(tabsSelector);
    const panels = document.querySelectorAll(panelsSelector);
    if (!tabs.length || !panels.length) return;

    function switchTab(hash) {
      const targetHash = hash || defaultHash;
      let found = false;
      tabs.forEach((tab) => {
        const isTarget = tab.getAttribute('href') === targetHash;
        tab.classList.toggle('is-active', isTarget);
        tab.setAttribute('aria-selected', isTarget ? 'true' : 'false');
        if (isTarget) found = true;
      });
      if (!found && defaultHash && targetHash !== defaultHash) {
        switchTab(defaultHash);
        if (window.location.hash) history.replaceState(null, '', defaultHash);
        return;
      }
      panels.forEach((panel) => {
        panel.hidden = `#${panel.dataset.category}` !== targetHash;
      });
    }

    tabs.forEach((tab) => tab.addEventListener('click', () => window.setTimeout(() => switchTab(window.location.hash), 0)));
    window.addEventListener('hashchange', () => switchTab(window.location.hash));
    switchTab(window.location.hash);
  }

  document.addEventListener('astro:page-load', () => {
    initHashRouter('.tab-btn[href]', '.archive-section[data-category]', '#production');
  });
</script>

<style>
  :global(html), :global(body) { overflow: auto; }
  .page-shell { min-height: 100svh; padding: clamp(1rem, 3vw, 2rem); background: linear-gradient(rgba(17,17,27,.82), rgba(17,17,27,.82)), radial-gradient(circle at 18% 12%, rgba(203,166,247,.22), transparent 30rem), radial-gradient(circle at 82% 18%, rgba(148,226,213,.14), transparent 28rem), var(--crust); color: var(--text); }
  .page-shell::before { content: ""; position: fixed; inset: 0; pointer-events: none; opacity: .07; background-image: linear-gradient(var(--surface1) 1px, transparent 1px), linear-gradient(90deg, var(--surface1) 1px, transparent 1px); background-size: 18px 18px; }
  .page-card { width: min(100%, 1180px); margin: 0 auto; border: 1px solid var(--border); background: rgba(30,30,46,.9); padding: clamp(1rem, 3vw, 2rem); box-shadow: 0 24px 80px rgba(0,0,0,.36), inset 0 1px 0 rgba(205,214,244,.06); position: relative; }
  .crumb, .section-title span { font-family: var(--mono); text-transform: uppercase; letter-spacing: .12em; }
  .crumb { display: flex; justify-content: space-between; gap: 1rem; margin-bottom: 2rem; font-size: .72rem; color: var(--subtext0); }
  a { color: var(--mauve); text-decoration: none; }
  a:hover { color: var(--teal); }
  .archive-hero { display: grid; gap: .9rem; margin-bottom: 1.5rem; }
  .archive-hero p { margin: 0; color: var(--mauve); font-family: var(--mono); font-size: .72rem; text-transform: uppercase; letter-spacing: .14em; }
  h1 { max-width: 14ch; margin: 0; color: var(--rosewater); font-size: clamp(2.6rem, 7vw, 5.4rem); line-height: .88; letter-spacing: -.075em; background: linear-gradient(90deg, var(--rosewater), var(--mauve), var(--teal)); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .archive-hero::after { content: ""; width: min(320px, 42vw); height: 3px; background: linear-gradient(90deg, var(--mauve), var(--teal), transparent); box-shadow: 0 0 22px rgba(203,166,247,.28); }
  :global(.tab-bar) { display: flex; flex-wrap: wrap; gap: .42rem; margin-top: .25rem; font-family: var(--mono); text-transform: uppercase; letter-spacing: .12em; }
  :global(.tab-btn) { display: inline-flex; align-items: center; gap: .42rem; padding: .48rem .72rem; border: 1px solid var(--surface1); background: rgba(17,17,27,.62); color: var(--subtext0); font-family: var(--mono); font-size: .68rem; text-transform: uppercase; letter-spacing: .1em; cursor: pointer; box-shadow: 3px 3px 0 rgba(17,17,27,.38); transition: border-color 140ms ease, color 140ms ease, transform 140ms ease, background 140ms ease; text-decoration: none; }
  :global(.tab-btn b) { min-width: 1.35rem; padding: .1rem .28rem; border: 1px solid rgba(148,226,213,.32); color: var(--teal); text-align: center; font-size: .6rem; }
  :global(.tab-btn:hover) { border-color: var(--mauve); color: var(--rosewater); transform: translate(-2px, -2px); }
  :global(.tab-btn.is-active) { border-color: var(--mauve); background: rgba(203,166,247,.12); color: var(--rosewater); box-shadow: 0 0 16px rgba(203,166,247,.1), 3px 3px 0 rgba(17,17,27,.38); }
  .category-stack { display: grid; gap: 1.5rem; }
  .archive-section { scroll-margin-top: 1rem; border: 1px solid var(--surface1); background: linear-gradient(135deg, rgba(49,50,68,.42), rgba(17,17,27,.28)); padding: 1.25rem; box-shadow: inset 0 1px 0 rgba(205,214,244,.05); }
  .archive-section[hidden] { display: none; }
  .section-title { display: grid; gap: .35rem; margin-bottom: 1rem; padding-bottom: .75rem; border-bottom: 1px solid var(--surface1); }
  .section-title span { color: var(--mauve); font-size: .7rem; }
  h2 { margin: 0; color: var(--text); font-size: clamp(1.1rem, 2.2vw, 1.5rem); letter-spacing: -.035em; }
  .section-title p { max-width: 60ch; margin: 0; color: var(--subtext1); line-height: 1.45; font-size: .9rem; }
  .project-list { display: grid; gap: .55rem; }
  :global(.project-row) { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: .75rem 1.25rem; align-items: start; padding: .9rem 1rem; border: 1px solid rgba(180,190,254,.24); background: rgba(17,17,27,.54); color: inherit; text-decoration: none; box-shadow: 4px 4px 0 rgba(17,17,27,.38); transition: border-color 160ms ease, transform 160ms ease, box-shadow 160ms ease; }
  :global(.project-row:hover) { border-color: var(--mauve); transform: translateX(3px); box-shadow: 0 0 20px rgba(203,166,247,.1), 4px 4px 0 rgba(17,17,27,.38); }
  :global(.project-row-main) { display: grid; gap: .45rem; min-width: 0; }
  :global(.card-chrome) { display: flex; justify-content: space-between; gap: .75rem; color: var(--subtext1); font-family: var(--mono); font-size: .7rem; text-transform: uppercase; letter-spacing: .12em; }
  :global(.card-chrome span) { color: var(--green); }
  :global(.card-chrome b) { color: var(--yellow); font-weight: 500; }
  :global(.project-row h3) { margin: .15rem 0 0; color: var(--rosewater); font-size: 1.3rem; line-height: 1; letter-spacing: -.035em; }
  :global(.project-row strong) { color: var(--teal); font-family: var(--mono); font-size: .8rem; font-weight: 500; }
  :global(.project-row p) { margin: 0; color: var(--subtext1); line-height: 1.5; font-size: .9rem; }
  :global(.row-action) { align-self: center; color: var(--lavender); font-family: var(--mono); font-size: .72rem; text-transform: uppercase; letter-spacing: .08em; white-space: nowrap; }
  @media (max-width: 820px) { :global(.project-row) { grid-template-columns: 1fr; } :global(.row-action) { align-self: start; } h1 { max-width: 10ch; } }
</style>
