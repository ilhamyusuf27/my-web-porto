---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import { projectCaseStudies, projectHref } from "../../data/projects";

export function getStaticPaths() {
  return projectCaseStudies.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const currentIndex = projectCaseStudies.findIndex((item) => item.slug === project.slug);
const previousProject = projectCaseStudies[(currentIndex - 1 + projectCaseStudies.length) % projectCaseStudies.length];
const nextProject = projectCaseStudies[(currentIndex + 1) % projectCaseStudies.length];
const facts = project.facts;
const gallery = project.gallery;
const responsibilities = project.responsibilities;
const modules = project.modules;
const outcomes = project.outcomes;
---

<Layout title={project.title} description={project.summary} image={project.gallery[0]?.[1]}>
  <main class="detail-shell">
    <article class="detail-card">
      <nav class="crumb">
        <a href="/projects">← Projects</a>
        <span>{project.label}</span>
      </nav>

      <header class="project-hero reveal" id="overview">
        <div class="hero-title">
          <p>{project.status}</p>
          <h1>{project.title}</h1>
        </div>
        <div class="hero-detail">
          <span>{project.summary}</span>
          <div class="stack-list">
            {project.stack.map((item) => <b>{item}</b>)}
          </div>
          <dl class="project-meta" aria-label="Project metadata">
            <div><dt>Type</dt><dd>{project.type}</dd></div>
            <div><dt>Period</dt><dd>{project.period}</dd></div>
            <div><dt>Role</dt><dd>{project.role}</dd></div>
          </dl>
        </div>
      </header>

      <section class="image-section reveal" id="screens" aria-labelledby="gallery-title">
        <div class="section-head">
          <span>01</span>
          <h2 id="gallery-title">{project.galleryTitle}</h2>
          <p>{project.galleryIntro}</p>
        </div>

        <div class="screen-slider" data-screen-slider>
          <div class="slider-main">
            <div class="slider-stage" aria-live="polite">
              <div class="slider-track" data-slider-track>
                {gallery.map(([title, src, caption], index) => (
                  <figure class={index === 0 ? "slider-slide is-active" : "slider-slide"} aria-hidden={index === 0 ? "false" : "true"}>
                    <button class="slide-image-button" type="button" data-zoom-src={src} data-zoom-title={title} data-zoom-caption={caption} aria-label={`Expand ${title}`}>
                      <img src={src} alt={title} loading={index === 0 ? "eager" : "lazy"} />
                      <span>Expand image</span>
                    </button>
                    <figcaption>
                      <b>{String(index + 1).padStart(2, "0")} · {title}</b>
                      <span>{caption}</span>
                    </figcaption>
                  </figure>
                ))}
              </div>
            </div>

            <div class="slider-thumbs" aria-label="Screenshot thumbnails">
              {gallery.map(([title, src], index) => (
                <button class={index === 0 ? "is-active" : ""} type="button" data-thumb-index={index} aria-label={`Show ${title}`}>
                  <img src={src} alt="" loading="lazy" draggable="false" />
                  <span>{String(index + 1).padStart(2, "0")}</span>
                </button>
              ))}
            </div>
          </div>

          <div class="slider-controls" aria-label="Screenshot slider controls">
            <button type="button" data-slider-prev>← Prev</button>
            <div class="slider-count"><span data-slider-current>01</span><b>/</b><span>{String(gallery.length).padStart(2, "0")}</span></div>
            <button type="button" data-slider-next>Next →</button>
          </div>
        </div>
      </section>

      <div class="image-zoom" data-image-zoom hidden aria-hidden="true" role="dialog" aria-modal="true" aria-label="Expanded project screenshot">
        <div class="zoom-modal" role="document">
          <div class="zoom-toolbar">
            <div>
              <b data-zoom-heading>Screenshot</b>
              <span data-zoom-copy>Use controls, mouse wheel, or drag to inspect the image.</span>
            </div>
            <div class="zoom-actions">
              <button type="button" data-zoom-out>−</button>
              <button type="button" data-zoom-reset>100%</button>
              <button type="button" data-zoom-in>+</button>
              <button type="button" data-zoom-close>Close</button>
            </div>
          </div>
          <div class="zoom-viewport" data-zoom-viewport>
            <img data-zoom-image src="" alt="" />
          </div>
          <p data-zoom-caption></p>
        </div>
      </div>

      <section class="info-grid reveal" aria-label="Project quick facts">
        {facts.map(([label, value]) => (
          <div>
            <span>{label}</span>
            <p>{value}</p>
          </div>
        ))}
      </section>

      <section class="split-section reveal">
        <div class="section-head compact">
          <span>02</span>
          <h2>Module breakdown</h2>
        </div>
        <div class="module-grid">
          {modules.map(([label, value]) => (
            <div>
              <strong>{label}</strong>
              <p>{value}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="split-section reveal">
        <div class="section-head compact">
          <span>03</span>
          <h2>Responsibilities</h2>
        </div>
        <ul class="check-list">
          {responsibilities.map((item) => <li>{item}</li>)}
        </ul>
      </section>

      <section class="outcome-section reveal">
        <div class="section-head compact">
          <span>04</span>
          <h2>Result notes</h2>
        </div>
        <div class="outcome-grid">
          {outcomes.map(([label, value]) => (
            <div>
              <strong>{label}</strong>
              <p>{value}</p>
            </div>
          ))}
        </div>
      </section>

      <nav class="project-pager reveal" aria-label="Project pagination">
        <a href={projectHref(previousProject.slug)}>
          <span>Previous project</span>
          <strong>{previousProject.title}</strong>
        </a>
        <a href={projectHref(nextProject.slug)}>
          <span>Next project</span>
          <strong>{nextProject.title}</strong>
        </a>
      </nav>
    </article>
  </main>
</Layout>

<script>
  function initProjectScreens() {
    const root = document.querySelector('[data-screen-slider]');
    if (!root || root.dataset.ready === 'true') return;
    root.dataset.ready = 'true';

    const track = root.querySelector('[data-slider-track]');
    const slides = Array.from(root.querySelectorAll('.slider-slide'));
    const thumbs = Array.from(root.querySelectorAll('[data-thumb-index]'));
    const currentLabel = root.querySelector('[data-slider-current]');
    const prevButton = root.querySelector('[data-slider-prev]');
    const nextButton = root.querySelector('[data-slider-next]');
    let activeSlide = 0;
    let thumbDrag = null;

    function scrollActiveThumb() {
      const activeThumb = thumbs[activeSlide];
      if (!activeThumb) return;
      activeThumb.scrollIntoView({ block: 'nearest', inline: 'nearest', behavior: 'smooth' });
    }

    function setSlide(index) {
      if (!slides.length) return;
      activeSlide = (index + slides.length) % slides.length;
      if (track) track.style.transform = `translate3d(-${activeSlide * 100}%, 0, 0)`;
      slides.forEach((slide, slideIndex) => {
        const isActive = slideIndex === activeSlide;
        slide.classList.toggle('is-active', isActive);
        slide.setAttribute('aria-hidden', isActive ? 'false' : 'true');
      });
      thumbs.forEach((thumb, thumbIndex) => thumb.classList.toggle('is-active', thumbIndex === activeSlide));
      if (currentLabel) currentLabel.textContent = String(activeSlide + 1).padStart(2, '0');
      scrollActiveThumb();
    }

    const thumbScroller = root.querySelector('.slider-thumbs');
    let suppressThumbClick = false;

    thumbScroller?.addEventListener('pointerdown', (event) => {
      if (event.button !== 0) return;
      thumbDrag = {
        pointerId: event.pointerId,
        thumb: event.target.closest('[data-thumb-index]'),
        x: event.clientX,
        y: event.clientY,
        left: thumbScroller.scrollLeft,
        top: thumbScroller.scrollTop,
        moved: false,
      };
      thumbScroller.setPointerCapture(event.pointerId);
    });

    thumbScroller?.addEventListener('pointermove', (event) => {
      if (!thumbDrag || thumbDrag.pointerId !== event.pointerId) return;
      const dx = event.clientX - thumbDrag.x;
      const dy = event.clientY - thumbDrag.y;
      if (Math.abs(dx) > 6 || Math.abs(dy) > 6) {
        thumbDrag.moved = true;
        thumbScroller.classList.add('is-dragging');
      }
      if (!thumbDrag.moved) return;
      event.preventDefault();
      thumbScroller.scrollLeft = thumbDrag.left - dx;
      thumbScroller.scrollTop = thumbDrag.top - dy;
    });

    function endThumbDrag(event) {
      if (!thumbDrag || thumbDrag.pointerId !== event.pointerId) return;
      const wasMoved = thumbDrag.moved;
      const clickedThumb = thumbDrag.thumb;
      thumbDrag = null;
      thumbScroller?.classList.remove('is-dragging');

      if (!wasMoved && clickedThumb) {
        setSlide(Number(clickedThumb.getAttribute('data-thumb-index') || 0));
      }

      suppressThumbClick = true;
      window.setTimeout(() => { suppressThumbClick = false; }, 0);
    }

    thumbScroller?.addEventListener('pointerup', endThumbDrag);
    thumbScroller?.addEventListener('pointercancel', endThumbDrag);
    thumbScroller?.addEventListener('lostpointercapture', () => {
      thumbDrag = null;
      thumbScroller?.classList.remove('is-dragging');
    });

    thumbScroller?.addEventListener('click', (event) => {
      const thumb = event.target.closest('[data-thumb-index]');
      if (!thumb || !thumbScroller.contains(thumb)) return;
      if (suppressThumbClick) {
        event.preventDefault();
        event.stopPropagation();
        return;
      }
      setSlide(Number(thumb.getAttribute('data-thumb-index') || 0));
    });

    prevButton?.addEventListener('click', () => setSlide(activeSlide - 1));
    nextButton?.addEventListener('click', () => setSlide(activeSlide + 1));

    const zoom = document.querySelector('[data-image-zoom]');
    const zoomModal = zoom?.querySelector('.zoom-modal');
    const zoomImage = zoom?.querySelector('[data-zoom-image]');
    const zoomHeading = zoom?.querySelector('[data-zoom-heading]');
    const zoomCaption = zoom?.querySelector('[data-zoom-caption]');
    const zoomViewport = zoom?.querySelector('[data-zoom-viewport]');
    const zoomIn = zoom?.querySelector('[data-zoom-in]');
    const zoomOut = zoom?.querySelector('[data-zoom-out]');
    const zoomReset = zoom?.querySelector('[data-zoom-reset]');
    const zoomClose = zoom?.querySelector('[data-zoom-close]');
    let zoomScale = 1;
    let dragStart = null;
    let pan = { x: 0, y: 0 };
    let lastFocus = null;

    function renderZoom() {
      if (!zoomImage) return;
      zoomImage.style.transform = `translate3d(${pan.x}px, ${pan.y}px, 0) scale(${zoomScale})`;
      if (zoomReset) zoomReset.textContent = `${Math.round(zoomScale * 100)}%`;
    }

    function setZoomScale(nextScale) {
      zoomScale = Math.min(3, Math.max(0.55, nextScale));
      renderZoom();
    }

    function openZoom(button) {
      if (!zoom || !zoomImage) return;
      lastFocus = document.activeElement;
      zoomImage.src = button.getAttribute('data-zoom-src') || '';
      zoomImage.alt = button.getAttribute('data-zoom-title') || 'Expanded project screenshot';
      if (zoomHeading) zoomHeading.textContent = button.getAttribute('data-zoom-title') || 'Screenshot';
      if (zoomCaption) zoomCaption.textContent = button.getAttribute('data-zoom-caption') || '';
      zoomScale = 1;
      pan = { x: 0, y: 0 };
      renderZoom();
      zoom.hidden = false;
      zoom.classList.add('is-open');
      zoom.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      zoomClose?.focus();
    }

    function closeZoom() {
      if (!zoom) return;
      zoom.classList.remove('is-open');
      zoom.hidden = true;
      zoom.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      if (lastFocus && typeof lastFocus.focus === 'function') lastFocus.focus();
    }

    root.querySelectorAll('[data-zoom-src]').forEach((button) => button.addEventListener('click', () => openZoom(button)));
    zoomIn?.addEventListener('click', () => setZoomScale(zoomScale + 0.2));
    zoomOut?.addEventListener('click', () => setZoomScale(zoomScale - 0.2));
    zoomReset?.addEventListener('click', () => { zoomScale = 1; pan = { x: 0, y: 0 }; renderZoom(); });
    zoomClose?.addEventListener('click', closeZoom);
    zoom?.addEventListener('click', (event) => { if (event.target === zoom) closeZoom(); });
    zoomModal?.addEventListener('click', (event) => event.stopPropagation());

    document.addEventListener('keydown', (event) => {
      const modalOpen = zoom && !zoom.hidden;
      if (modalOpen) {
        if (event.key === 'Escape') closeZoom();
        if (event.key === '+' || event.key === '=') setZoomScale(zoomScale + 0.2);
        if (event.key === '-') setZoomScale(zoomScale - 0.2);
        return;
      }
      if (event.key === 'ArrowRight') setSlide(activeSlide + 1);
      if (event.key === 'ArrowLeft') setSlide(activeSlide - 1);
    });

    zoomViewport?.addEventListener('wheel', (event) => {
      event.preventDefault();
      setZoomScale(zoomScale + (event.deltaY > 0 ? -0.12 : 0.12));
    }, { passive: false });
    zoomViewport?.addEventListener('pointerdown', (event) => {
      dragStart = { x: event.clientX - pan.x, y: event.clientY - pan.y };
      zoomViewport.setPointerCapture(event.pointerId);
    });
    zoomViewport?.addEventListener('pointermove', (event) => {
      if (!dragStart) return;
      pan = { x: event.clientX - dragStart.x, y: event.clientY - dragStart.y };
      renderZoom();
    });
    zoomViewport?.addEventListener('pointerup', () => { dragStart = null; });
    zoomViewport?.addEventListener('pointercancel', () => { dragStart = null; });

    setSlide(0);

    const revealItems = Array.from(document.querySelectorAll('.reveal'));
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      }, { threshold: 0.16, rootMargin: '0px 0px -8% 0px' });
      revealItems.forEach((item, index) => {
        item.style.setProperty('--reveal-delay', `${Math.min(index * 70, 280)}ms`);
        observer.observe(item);
      });
    } else {
      revealItems.forEach((item) => item.classList.add('is-visible'));
    }
  }

  document.addEventListener('astro:page-load', initProjectScreens);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProjectScreens, { once: true });
  } else {
    initProjectScreens();
  }
</script>

<style>
  :global(html), :global(body) { overflow: auto; }
  .detail-shell {
    min-height: 100svh;
    padding: clamp(.55rem, 1.4vw, 1rem);
    background:
      linear-gradient(rgba(17,17,27,.84), rgba(17,17,27,.84)),
      radial-gradient(circle at 16% 10%, rgba(203,166,247,.22), transparent 30rem),
      radial-gradient(circle at 86% 16%, rgba(137,180,250,.16), transparent 28rem),
      var(--crust);
    color: var(--text);
  }
  .detail-shell::before { content: ""; position: fixed; inset: 0; pointer-events: none; opacity: .07; background-image: linear-gradient(var(--surface1) 1px, transparent 1px), linear-gradient(90deg, var(--surface1) 1px, transparent 1px); background-size: 18px 18px; }
  .detail-card { width: min(100%, 1480px); margin: 0 auto; border: 1px solid var(--border); background: rgba(30,30,46,.9); padding: clamp(.78rem, 1.6vw, 1.25rem); box-shadow: 0 24px 80px rgba(0,0,0,.36), inset 0 1px 0 rgba(205,214,244,.06); position: relative; }
  .detail-card::before { content: ""; position: absolute; inset: 0; pointer-events: none; opacity: .1; background: linear-gradient(90deg, transparent, rgba(148,226,213,.18), transparent); transform: translateX(-120%); animation: page-scan 4.8s ease-in-out infinite; }
  .reveal { opacity: 0; transform: translateY(14px); transition: opacity 420ms ease var(--reveal-delay, 0ms), transform 420ms ease var(--reveal-delay, 0ms), border-color 220ms ease, box-shadow 220ms ease; }
  .reveal.is-visible { opacity: 1; transform: translateY(0); }
  .crumb, .project-hero p, dt, .stack-list, .section-head span, .info-grid span, figcaption b { font-family: var(--mono); text-transform: uppercase; letter-spacing: .12em; }
  .crumb { display: flex; justify-content: space-between; align-items: center; gap: 1rem; margin-bottom: .58rem; color: var(--subtext0); font-size: .72rem; }
  a { color: var(--mauve); text-decoration: none; }
  a:hover { color: var(--teal); }
  .project-hero { display: grid; grid-template-columns: minmax(320px, .9fr) minmax(460px, 1.1fr); gap: clamp(1rem, 2.6vw, 2rem); align-items: end; margin-bottom: .7rem; padding: .72rem .78rem; border: 1px solid rgba(180,190,254,.16); background: linear-gradient(135deg, rgba(49,50,68,.3), rgba(17,17,27,.18)); scroll-margin-top: 1rem; }
  .hero-title, .hero-detail { min-width: 0; }
  .project-hero p { margin: 0 0 .38rem; color: var(--mauve); font-size: .68rem; }
  h1 { max-width: 15ch; margin: 0; color: var(--rosewater); font-size: clamp(2.15rem, 3.9vw, 3.75rem); line-height: .9; letter-spacing: -.075em; }
  .hero-detail { display: grid; gap: .5rem; }
  .hero-detail > span { display: block; color: var(--subtext1); line-height: 1.35; }
  .stack-list { display: flex; flex-wrap: wrap; gap: .24rem; max-width: 760px; font-size: .5rem; letter-spacing: .1em; }
  .stack-list b { padding: .2rem .3rem; border: 1px solid var(--surface1); color: var(--teal); background: rgba(148,226,213,.08); font-weight: 500; line-height: 1; }
  .project-meta { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: .28rem; margin: 0; }
  .project-meta div { display: grid; gap: .14rem; padding: .24rem .34rem; border: 1px solid rgba(180,190,254,.18); background: rgba(49,50,68,.28); }
  dt { color: var(--subtext0); font-size: .5rem; }
  dd { margin: 0; color: var(--rosewater); font-size: .66rem; line-height: 1.12; }
  .info-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: .5rem; margin: 1rem 0; }
  .info-grid div { padding: .68rem; border: 1px solid var(--surface1); background: linear-gradient(135deg, rgba(137,180,250,.11), rgba(203,166,247,.08)); }
  .info-grid span { color: var(--mauve); font-size: .56rem; }
  .info-grid p { margin: .35rem 0 0; color: var(--subtext1); font-size: .82rem; line-height: 1.35; }
  .image-section, .split-section, .outcome-section { margin-top: .72rem; padding: clamp(.62rem, 1.25vw, .85rem); border: 1px solid var(--surface1); background: rgba(17,17,27,.32); scroll-margin-top: 1rem; }
  .image-section { box-shadow: inset 0 0 0 1px rgba(203,166,247,.05), 4px 4px 0 rgba(17,17,27,.34); }

  .section-head { display: grid; grid-template-columns: 46px minmax(220px, .62fr) minmax(260px, 1fr); gap: .75rem; align-items: baseline; margin-bottom: .58rem; }
  .section-head.compact { grid-template-columns: 46px 1fr; }
  .section-head span { color: var(--mauve); font-size: .62rem; }
  h2 { margin: 0; color: var(--text); font-size: 1.16rem; letter-spacing: -.035em; }
  .section-head p { margin: 0; color: var(--subtext1); font-size: .84rem; line-height: 1.35; }
  .screen-slider { display: grid; gap: .58rem; }
  .slider-main { display: grid; grid-template-columns: minmax(0, 1fr) clamp(170px, 15vw, 240px); gap: .62rem; align-items: stretch; }
  .slider-stage { position: relative; height: clamp(330px, 39vw, 560px); border: 1px solid rgba(180,190,254,.24); background: rgba(17,17,27,.52); overflow: hidden; box-shadow: 4px 4px 0 rgba(17,17,27,.38); }
  .slider-track { height: 100%; display: flex; transition: transform 260ms ease; will-change: transform; }
  .slider-slide { flex: 0 0 100%; min-width: 100%; display: grid; grid-template-rows: minmax(0, 1fr) auto; margin: 0; }
  .slider-slide:not(.is-active) { pointer-events: none; }
  .slide-image-button { position: relative; min-height: 0; display: grid; place-items: center; width: 100%; border: 0; border-bottom: 1px solid var(--surface1); padding: 0; background: #f7f7f7; cursor: zoom-in; overflow: hidden; }
  .slide-image-button img { display: block; width: 100%; height: 100%; object-fit: contain; }
  .slide-image-button span { position: absolute; right: .7rem; bottom: .7rem; padding: .34rem .48rem; border: 1px solid var(--mauve); background: rgba(17,17,27,.86); color: var(--rosewater); font-family: var(--mono); font-size: .58rem; text-transform: uppercase; letter-spacing: .12em; box-shadow: 3px 3px 0 rgba(17,17,27,.45); }
  .slide-image-button:hover span { border-color: var(--teal); color: var(--teal); }
  figcaption { display: grid; gap: .28rem; padding: .68rem .78rem; background: rgba(17,17,27,.92); }
  figcaption b { color: var(--teal); font-size: .58rem; font-weight: 500; }
  figcaption span { color: var(--subtext1); font-size: .82rem; line-height: 1.35; }
  .slider-controls { display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: .5rem; margin-top: -.08rem; }
  .slider-controls button, .zoom-actions button { border: 1px solid var(--surface1); background: rgba(49,50,68,.34); color: var(--rosewater); padding: .48rem .62rem; font-family: var(--mono); font-size: .62rem; text-transform: uppercase; cursor: pointer; }
  .slider-controls button:hover, .zoom-actions button:hover { border-color: var(--teal); color: var(--teal); transform: translate(-1px, -1px); }
  .slider-count { justify-self: center; display: flex; align-items: center; gap: .38rem; color: var(--subtext0); font-family: var(--mono); font-size: .68rem; }
  .slider-count span:first-child { color: var(--mauve); }
  .slider-thumbs { min-height: 0; max-height: clamp(330px, 39vw, 560px); display: grid; grid-template-columns: 1fr; gap: .32rem; overflow: auto; padding-right: .2rem; cursor: grab; touch-action: none; overscroll-behavior: contain; scrollbar-width: thin; scrollbar-color: var(--mauve) rgba(49,50,68,.34); }
  .slider-thumbs.is-dragging { cursor: grabbing; user-select: none; }
  .slider-thumbs.is-dragging * { pointer-events: none; }
  .slider-thumbs button { position: relative; min-width: 0; padding: 0; border: 1px solid var(--surface1); background: rgba(49,50,68,.32); cursor: pointer; opacity: .62; user-select: none; }
  .slider-thumbs button.is-active { opacity: 1; border-color: var(--mauve); box-shadow: 0 0 0 2px rgba(203,166,247,.12); }
  .slider-thumbs img { display: block; width: 100%; aspect-ratio: 16 / 10; object-fit: cover; }
  .slider-thumbs span { position: absolute; left: .2rem; top: .2rem; padding: .12rem .2rem; background: rgba(17,17,27,.82); color: var(--teal); font-family: var(--mono); font-size: .48rem; }
  .image-zoom { position: fixed; inset: 0; z-index: 200; display: grid; place-items: center; padding: clamp(.75rem, 2vw, 1.5rem); background: rgba(17,17,27,.78); backdrop-filter: blur(8px); }
  .image-zoom[hidden] { display: none; }
  .zoom-modal { width: min(100%, 1120px); height: min(92svh, 780px); display: grid; grid-template-rows: auto minmax(0, 1fr) auto; gap: .75rem; padding: .75rem; border: 1px solid var(--mauve); background: rgba(30,30,46,.97); box-shadow: 0 0 0 999px rgba(17,17,27,.35), 0 24px 90px rgba(0,0,0,.55), 6px 6px 0 rgba(17,17,27,.65); }
  .zoom-toolbar { display: flex; justify-content: space-between; gap: 1rem; align-items: center; padding: .65rem .75rem; border: 1px solid var(--border); background: rgba(17,17,27,.72); box-shadow: 4px 4px 0 rgba(17,17,27,.45); }
