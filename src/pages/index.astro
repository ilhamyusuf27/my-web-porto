  .cat-sprite {
    position: absolute;
    right: 4px;
    bottom: 0;
    width: 58px;
    height: 48px;
    animation: cat-bob 1.6s steps(2, end) infinite;
  }

  .cat-body {
    position: absolute;
    left: 10px;
    top: 9px;
