  .footer-cell { min-width: 0; display: grid; align-content: center; gap: .05rem; padding: .24rem .38rem; border: 1px solid var(--surface1); background: rgba(49,50,68,.34); }
  .footer-cell span, .footer-social > span { color: var(--subtext0); font-family: var(--mono); font-size: .52rem; letter-spacing: .1em; text-transform: uppercase; }
  .footer-cell strong { color: var(--teal); font-family: var(--mono); font-size: .62rem; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .footer-social { display: grid; grid-template-columns: auto auto; align-items: center; gap: .48rem; padding-left: .45rem; border-left: 1px solid var(--surface1); }
  .footer-social div { display: flex; gap: .32rem; }
