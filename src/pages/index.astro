  .pixel-cat[data-mood="sleepy"] .cat-eye { height: 2px; top: 15px; background: var(--yellow); }
  .pixel-cat[data-mood="curious"] .cat-sprite { animation-duration: 950ms; }


  .home-reveal { opacity: 0; transform: translateY(12px); transition: opacity 420ms ease var(--reveal-delay, 0ms), transform 420ms ease var(--reveal-delay, 0ms), border-color 180ms ease, box-shadow 180ms ease; }
  .home-reveal.is-visible { opacity: 1; transform: translateY(0); }
  .pixel-cat { animation: cat-attention 3.8s steps(2, end) 1.2s infinite; }
  .pixel-cat:hover, .pixel-cat:focus-visible { animation: none; }
  .you-pin::before { animation: you-pin-pulse 1.5s steps(2, end) infinite; }
  .map-node.active .node-card { border-color: rgba(166,227,161,.55); box-shadow: 0 0 18px rgba(166,227,161,.12), 3px 3px 0 rgba(17,17,27,.5); }

  @keyframes cat-attention {
