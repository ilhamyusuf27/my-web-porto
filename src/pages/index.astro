    height: 30px;
    background: var(--surface0);
    border: 3px solid var(--lavender);
    box-shadow: inset 0 -6px 0 rgba(203,166,247,.18), 4px 4px 0 rgba(17,17,27,.7);
  }

  .cat-ear {
    position: absolute;
    top: -11px;
    width: 13px;
    height: 13px;
    background: var(--surface0);
    border-left: 3px solid var(--lavender);
    border-top: 3px solid var(--lavender);
    transform: rotate(45deg);
  }
  .cat-ear.left { left: 3px; }
  .cat-ear.right { right: 3px; }

  .cat-face { position: absolute; inset: 0; }
  .cat-eye {
    position: absolute;
    top: 11px;
    width: 5px;
    height: 7px;
    background: var(--teal);
    box-shadow: 0 0 8px rgba(148,226,213,.7);
    animation: cat-blink 4.4s steps(1, end) infinite;
  }
  .cat-eye.left { left: 8px; }
  .cat-eye.right { right: 8px; }
  .cat-mouth {
    position: absolute;
    left: 16px;
    top: 21px;
    width: 6px;
    height: 3px;
    background: var(--pink);
