  .map-lane-label { z-index: 3; padding: .18rem .38rem; border: 1px solid rgba(180,190,254,.26); background: rgba(17,17,27,.64); color: var(--subtext1); font-family: var(--mono); font-size: .48rem; letter-spacing: .1em; text-transform: uppercase; box-shadow: 2px 2px 0 rgba(17,17,27,.36); }
