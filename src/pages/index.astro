  .panel-cta:hover { border-color: var(--teal); color: var(--teal); transform: translate(-1px, -1px); }
  .project-stack { display: grid; gap: .3rem; margin-bottom: .46rem; position: relative; z-index: 1; }
  .project-mini { display: grid; grid-template-columns: 66px 1fr auto; align-items: center; column-gap: .46rem; padding: .32rem .42rem; border: 1px solid var(--surface1); background: linear-gradient(135deg, rgba(137,180,250,.12), rgba(203,166,247,.09)); }
  .project-mini span { color: var(--green); font-family: var(--mono); font-size: .52rem; text-transform: uppercase; }
  .project-mini strong { color: var(--rosewater); font-size: .72rem; font-weight: 600; }
  .project-mini small { grid-column: 2; color: var(--subtext0); font-family: var(--mono); font-size: .56rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .project-mini em { grid-row: 1 / span 2; grid-column: 3; color: var(--yellow); font-family: var(--mono); font-size: .52rem; font-style: normal; text-transform: uppercase; }
