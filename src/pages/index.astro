---
import BaseLayout from "../components/layout/BaseLayout.astro";
import ScrollProgress from "../components/layout/ScrollProgress.astro";
import HudNav from "../components/layout/HudNav.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import AboutSection from "../components/sections/AboutSection.astro";
import SkillsSection from "../components/sections/SkillsSection.astro";
import ExperienceSection from "../components/sections/ExperienceSection.astro";
import ProjectsSection from "../components/sections/ProjectsSection.astro";
import ExperimentalSection from "../components/sections/ExperimentalSection.astro";
import EducationSection from "../components/sections/EducationSection.astro";
import ContactSection from "../components/sections/ContactSection.astro";
import { profile } from "../data/profile";
---

<BaseLayout
  title={`${profile.name} - ${profile.role} | Production Systems Portfolio`}
  description="Ilham Yusuf is a frontend developer with fullstack range, building maintainable web interfaces, client systems, and reliability-minded product experiences."
>
  <ScrollProgress slot="nav" />
  <HudNav slot="nav" />
  <HeroSection />
  <AboutSection />
  <SkillsSection />
  <ExperienceSection />
  <ProjectsSection />
  <ExperimentalSection />
  <EducationSection />
  <ContactSection />
</BaseLayout>

<script>
  import { initScrollAnimations } from "../scripts/scroll";
  import { initModal } from "../scripts/modal";

  // Reveal animations only matter once content is in the DOM.
  initScrollAnimations();
  initModal();
</script>
