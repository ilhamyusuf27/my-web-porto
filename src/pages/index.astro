  .compass-rose { right: 8%; top: 17%; width: 42px; height: 42px; display: grid !important; place-items: center; border: 1px solid rgba(180,190,254,.18); color: rgba(245,224,220,.28); font-size: 1.25rem; transform: rotate(45deg); }
  .compass-rose::before, .compass-rose::after { content: ""; position: absolute; background: rgba(180,190,254,.18); }
  .compass-rose::before { width: 1px; height: 54px; }
  .compass-rose::after { width: 54px; height: 1px; }
  .you-pin { right: 16%; bottom: 34%; color: rgba(166,227,161,.55); font-family: var(--mono); font-size: .45rem; letter-spacing: .08em; }
  .you-pin::before { content: ""; position: absolute; left: -12px; top: 2px; width: 8px; height: 8px; border: 2px solid var(--green); background: rgba(166,227,161,.18); transform: rotate(45deg); box-shadow: 0 0 10px rgba(166,227,161,.35); }
  .contour { border: 1px dashed rgba(180,190,254,.12); border-radius: 999px; }
