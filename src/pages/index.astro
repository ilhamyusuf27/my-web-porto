  .pixel-cat {
    --cat-x: calc(100vw - 112px);
    --cat-y: 76px;
    position: fixed;
    left: 0;
    top: 0;
    width: 92px;
    height: 86px;
    border: 0;
    padding: 0;
    background: transparent;
    z-index: 12;
    cursor: pointer;
    transform: translate(var(--cat-x), var(--cat-y));
    transition: transform 620ms cubic-bezier(.2, .9, .2, 1);
    image-rendering: pixelated;
  }

  .cat-bubble {
    position: absolute;
    right: 38px;
    bottom: 68px;
    width: max-content;
    max-width: 180px;
    padding: .34rem .48rem;
    border: 1px solid var(--mauve);
    background: rgba(17,17,27,.92);
    color: var(--rosewater);
    font-family: var(--mono);
    font-size: .62rem;
