    box-shadow: 0 0 0 2px var(--surface1), 2px 2px 0 rgba(17,17,27,.38);
  }
  .map-node.active .node-dot {
    background: var(--green);
    box-shadow: 0 0 0 2px var(--surface1), 0 0 0 6px rgba(166,227,161,.2), 0 0 14px rgba(166,227,161,.7);
