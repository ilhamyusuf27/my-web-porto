  .map-node:hover { z-index: 10; }
  .map-node:hover .node-card { background: rgba(30,30,46,.95); border-color: var(--mauve); transform: translate(2px, -2px); }
  .map-node:hover .node-dot { background: var(--yellow); }

  .resource-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: .32rem; margin-bottom: .48rem; position: relative; z-index: 1; }
  .resource-grid div { min-height: 34px; display: grid; align-content: center; gap: .08rem; padding: .32rem .4rem; border: 1px solid var(--surface1); background: linear-gradient(135deg, rgba(137,180,250,.13), rgba(203,166,247,.1)); }
  .resource-grid span { color: var(--subtext0); font-family: var(--mono); font-size: .58rem; text-transform: uppercase; }
  .resource-grid strong { color: var(--teal); font-size: .7rem; font-weight: 600; }

  .quest-list { display: grid; gap: .2rem; margin: 0; padding: 0; list-style: none; position: relative; z-index: 1; }
  .quest-list li { color: var(--subtext1); font-size: .74rem; line-height: 1.12; }
  .quest-list li::before { content: "[ ]"; color: var(--sapphire); margin-right: .42rem; font-family: var(--mono); }
  .quest-list li.done::before { content: "[x]"; color: var(--green); }

  .note-queue { display: grid; grid-template-columns: repeat(3, 1fr); gap: .26rem; margin-top: .42rem; position: relative; z-index: 1; }
  .note-queue a { padding: .25rem .32rem; border: 1px solid var(--surface1); background: rgba(49,50,68,.36); color: var(--lavender); font-family: var(--mono); font-size: .62rem; text-align: center; }
  .note-queue a:hover { border-color: var(--mauve); }

  .pixel-cat {
    --cat-x: calc(100vw - 132px);
    --cat-y: calc(100vh - 128px);
    position: fixed;
    left: 0;
    top: 0;
    width: 92px;
    height: 86px;
    border: 0;
    padding: 0;
    background: transparent;
    z-index: 8;
