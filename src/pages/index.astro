---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";

const selectedWork = [
  ["Work 04", "Madeindonesia", "Front-End Web Developer", "WordPress · WooCommerce · PHP", "2025 →", "active", "80%", "24%"],
  ["Work 03", "Tomps by Telkom", "Front-End Web Developer", "React · TypeScript · Redux · Testing", "2022–24", "done", "58%", "36%"],
  ["Work 02", "Telkom Indonesia", "Front-End Web Developer", "React · Tailwind · Bootstrap · Jest", "2022", "done", "38%", "22%"],
  ["Work 01", "IT Assistant · UGM FK-KMK", "IT Assistant", "Design · streaming · video editing", "2020–21", "done", "18%", "36%"],
  ["Edu 02", "Pijar Camp", "Full-Stack Website Developer", "JS · Node · Express · React · Next", "2022", "edu", "58%", "73%"],
  ["Edu 01", "AMIKOM Yogyakarta", "S1 Informatics · GPA 3.85", "Web · multimedia · animation", "2017–21", "edu", "22%", "80%"],
];

const profile = [
  ["Open for", "Freelance · remote"],
  ["Location", "Indonesia · GMT+7"],
  ["Focus", "Full-stack → SRE"],
  ["Delivery", "Reliable web systems"],
];

const hiringSnapshot = [
  ["Now", "Full-stack web"],
  ["Core", "React · Next · Node"],
  ["Ops", "Docker · Cloudflare"],
  ["Target", "SRE path"],
];

const runtime = [
  ["Runtime", "Static Astro"],
  ["Host", "Cloudflare"],
  ["Client JS", "Tiny"],
  ["Repos", "27 public"],
];

const toolbelt = [
  ["Frontend", "TypeScript · React · Next.js · Vue · Nuxt · Tailwind"],
  ["Backend", "Node.js · Express · NestJS · PHP · REST API"],
  ["Data", "PostgreSQL · MariaDB · MongoDB · Prisma · Supabase"],
  ["Reliability", "Docker · GitHub Actions · Cloudflare · Vercel · Railway"],
  ["Testing", "Vitest · Jest · React Testing Library"],
  ["Tools", "Git · pnpm · Figma · Postman · AI coding agents"],
];

const projects = [
  ["Work", "Tomps SaaS", "Nuxt · Next · Redux", "SaaS portal", "/projects/tomps-saas"],
  ["Work", "Tomps Project", "Vue · TypeScript · Vuex", "Project management SaaS", "/projects/tomps-project"],
  ["Work", "BRI Box", "React · Redux · Socket", "Multi-role dashboard", "/projects/bri-box"],
  ["Freelance", "Daily Language", "React · Redux · MUI", "Tutoring admin", "/projects/daily-language"],
];

const questLog = [
  ["done", "Create categorized project overview"],
  ["done", "Prepare readable single-project template"],
  ["todo", "Replace examples with real project data"],
];

const projectQueues = ["Work projects", "Learning labs", "Ongoing builds"];

const footerStats = [
  ["Latency", "measuring…", "latency-value"],
  ["Server time", "--:--:-- GMT+7", "server-time"],
  ["Build", "Astro static", "build-value"],
  ["Location / edge", "Cloudflare Pages", "edge-value"],
];

const socialLinks = [
  ["GitHub", "https://github.com/ilhamyusuf27", "GH"],
  ["Email", "mailto:hello@ilhamya.dev", "@"],
  ["LinkedIn", "https://www.linkedin.com/in/ilhamyusufalghani/", "IN"],
];
---

<Layout title="Ilham Yusuf — Full-Stack Developer" description="Full-stack developer portfolio with work projects, SRE direction, and production-minded web systems." image="/ilham-avatar.webp">
  <main class="home-shell" aria-label="Ilham Yusuf portfolio homepage">
    <div class="cursor-glow" aria-hidden="true"></div>
    <div class="decor-layer" aria-hidden="true">
      <span class="pixel-star star-a"></span>
      <span class="pixel-star star-b"></span>
      <span class="pixel-star star-c"></span>
      <span class="pixel-star star-d"></span>
      <span class="hud-rune rune-a">◇</span>
      <span class="hud-rune rune-b">▣</span>
      <span class="hud-rune rune-c">✦</span>
    </div>
    <button class="pixel-cat" type="button" aria-label="Pixel cat assistant" data-mood="idle">
      <span class="cat-bubble">nya~ hover a panel</span>
      <span class="cat-sprite" aria-hidden="true">
        <span class="cat-tail"></span>
        <span class="cat-body">
          <span class="cat-ear left"></span>
          <span class="cat-ear right"></span>
          <span class="cat-face">
            <span class="cat-eye left"></span>
            <span class="cat-eye right"></span>
            <span class="cat-mouth"></span>
          </span>
        </span>
        <span class="cat-paw paw-a"></span>
        <span class="cat-paw paw-b"></span>
      </span>
    </button>
    <section class="desktop-frame">
      <header class="topbar panel-lite">
        <a class="brand" href="/" data-astro-reload aria-label="Ilhamya home">
          <span class="pixel-logo" aria-hidden="true"></span>
          <span>ilhamya.dev</span>
        </a>
        <nav class="nav-links" aria-label="Navigation links">
          <a href="/projects">Projects</a>
          <a href="/experience">Experience</a>
          <a href="/documents/cv-ilham-yusuf-alghani.pdf" target="_blank" rel="noreferrer">CV</a>
          <a href="https://github.com/ilhamyusuf27" target="_blank" rel="noreferrer">GitHub</a>
          <span class="profile-loaded">Profile loaded →</span>
        </nav>
      </header>

      <section class="hero-grid" aria-label="Intro summary">
        <article class="intro-panel panel home-reveal" aria-labelledby="intro-title">
          <button class="pixel-avatar" type="button" aria-label="Pixel character representing Ilham" data-avatar-mood="focus">
            <span class="avatar-aura" aria-hidden="true"></span>
            <span class="avatar-particle particle-a" aria-hidden="true"></span>
            <span class="avatar-particle particle-b" aria-hidden="true"></span>
            <span class="avatar-shadow" aria-hidden="true"></span>
            <picture>
              <source srcset="/ilham-avatar.webp" type="image/webp" />
              <img class="avatar-image" src="/ilham-avatar.png" alt="" aria-hidden="true" loading="eager" fetchpriority="high" decoding="async" />
            </picture>
            <span class="avatar-caption">UI + terminal mode</span>
          </button>
          <div class="save-label"><span>Save file</span><strong>Full-stack Builder</strong></div>
          <p class="eyebrow">Clean UI · backend integration · SRE mindset</p>
          <h1 id="intro-title">Ilham Yusuf</h1>
          <p class="headline">I turn rough product ideas into clean web interfaces.</p>
          <p class="summary">Full-stack web developer who builds polished interfaces, connects backend pieces, and is growing toward reliable SRE-style systems.</p>
          <div class="actions">
            <a class="button primary" href="mailto:hello@ilhamya.dev">Start a quest</a>
            <a class="button secondary" href="https://github.com/ilhamyusuf27" target="_blank" rel="noreferrer">Open inventory</a>
          </div>
        </article>

        <article class="profile-panel panel home-reveal" aria-label="Profile status">
          <div class="section-head"><span>Profile</span><h2>Hiring signal</h2></div>
          <dl class="status-list">
            {profile.map(([label, value]) => (
              <div><dt>{label}</dt><dd>{value}</dd></div>
            ))}
          </dl>
          <div class="hiring-grid" aria-label="Recruiter useful snapshot">
            {hiringSnapshot.map(([label, value]) => (
              <div><span>{label}</span><strong>{value}</strong></div>
            ))}
          </div>
        </article>

        <article class="code-panel panel home-reveal" aria-label="Terminal activity">
          <div class="window-dots" aria-hidden="true"><span></span><span></span><span></span></div>
          <div class="terminal-title" aria-hidden="true">
            <span>~/portfolio</span>
            <strong>terminal</strong>
          </div>
          <div class="terminal-log" aria-live="polite">
            <p><span>$</span> whoami</p>
            <p><i>[user]</i> ilham · frontend builder</p>
            <p><span>$</span> pnpm build</p>
            <p><i>[astro]</i> static routes generated</p>
            <p><span>$</span> docker compose up -d</p>
            <p><i>[ok]</i> api + db containers ready</p>
            <p><span>$</span> cloudflare deploy --dry-run</p>
            <p><i>[ready]</i> static assets prepared</p>
            <p><span>$</span> git log --oneline -5</p>
            <p><i>a17c9e2</i> tune career-map lanes</p>
            <p><i>7bc42aa</i> add quest-log cards</p>
            <p><i>40f8d31</i> polish hero avatar</p>
            <p><span>$</span> npm test</p>
            <p><i>[pass]</i> 18 tests · 3 suites · 0 failed</p>
            <p><span>$</span> ls projects/</p>
            <p><i>[dir]</i> tomps-saas · bri-box · daily-language</p>
          </div>
          <form class="terminal-input" aria-label="Interactive terminal demo">
            <label for="terminal-command">$</label>
            <input id="terminal-command" name="command" autocomplete="off" spellcheck="false" value="help" aria-label="Type a terminal command" />
            <button type="submit">run</button>
          </form>
          <div class="terminal-capability">
            <b>try</b>
            <span>help · skills · stack · contact · clear</span>
          </div>
        </article>
      </section>

      <section class="content-grid" aria-label="Portfolio summary">
        <article class="toolbelt-panel panel home-reveal">
          <div class="section-head"><span>01</span><h2>Toolbelt</h2></div>
          <dl class="toolbelt-list">
            {toolbelt.map(([label, value]) => (
              <div><dt>{label}</dt><dd>{value}</dd></div>
            ))}
          </dl>
        </article>

        <article class="ops-panel panel home-reveal">
          <div class="section-head panel-head-link"><span>02</span><h2>Projects</h2><a href="/projects" class="panel-cta">View all →</a></div>
          <div class="project-stack" aria-label="Featured projects overview">
            {projects.map(([type, name, stack, status, href]) => (
              <a href={href} class="project-mini">
                <span>{type}</span>
                <strong>{name}</strong>
                <small>{stack}</small>
                <em>{status}</em>
              </a>
            ))}
          </div>
        </article>

        <article class="work-panel panel home-reveal">
          <div class="section-head"><span>03</span><h2>Career map</h2></div>
          <div class="experience-map" aria-label="Work experience map">
            <div class="map-toolbar">
              <div class="map-banner">Work experience</div>
              <button class="map-expand" type="button" aria-expanded="false">Expand map</button>
            </div>
            <div class="map-canvas">
              <div class="map-art" aria-hidden="true">
                <svg class="map-paths" viewBox="0 0 100 100" preserveAspectRatio="none">
                  <path class="work-route route-shadow" d="M18 36 C26 20, 31 18, 38 22 S48 45, 58 36 S70 16, 80 24" />
                  <path class="work-route" d="M18 36 C26 20, 31 18, 38 22 S48 45, 58 36 S70 16, 80 24" />
                  <path class="edu-route route-shadow" d="M22 80 C34 88, 47 62, 58 73" />
                  <path class="edu-route" d="M22 80 C34 88, 47 62, 58 73" />
                </svg>
                <span class="map-lane-label work-label">Work experience</span>
                <span class="map-lane-label edu-label">Education</span>
                <span class="compass-rose">✦</span>
                <span class="you-pin">YOU</span>
                <span class="contour contour-a"></span>
                <span class="contour contour-b"></span>
                <span class="map-corner corner-a"></span>
                <span class="map-corner corner-b"></span>
              </div>
              {selectedWork.map(([act, name, role, tech, date, state, x, y]) => (
                <a
                  class={`map-node ${state}`}
                  href="/experience"
                  style={`--x:${x}; --y:${y}`}
                  aria-label={`${act}: ${name} - ${role}`}
                  data-tooltip={`${act} · ${date}|${name}|${role}|${tech}`}
                >
                  <span class="node-dot"></span>
                  <span class="node-card">
                    <b>{act} · {date}</b>
                    <strong>{name}</strong>
                    <em>{role}</em>
                    <small>{tech}</small>
                  </span>
                </a>
              ))}
            </div>
          </div>
        </article>
      </section>

      <footer class="status-footer panel-lite home-reveal" aria-label="System footer">
        <div class="footer-stats">
          {footerStats.map(([label, value, id]) => (
            <div class="footer-cell">
              <span>{label}</span>
              <strong data-footer-id={id}>{value}</strong>
            </div>
          ))}
        </div>
        <div class="footer-social" aria-label="Social links">
          <span>Social</span>
          <div>
            {socialLinks.map(([label, href, icon]) => (
              <a href={href} target={href.startsWith('http') ? '_blank' : undefined} rel={href.startsWith('http') ? 'noreferrer' : undefined} aria-label={label}>
                <b>{icon}</b><em>{label}</em>
              </a>
            ))}
          </div>
        </div>
      </footer>
    </section>
    <div class="cursor-tooltip" hidden aria-hidden="true"></div>
  </main>
</Layout>

<script>
  const root = document.documentElement;
  const cards = [...document.querySelectorAll('.panel, .panel-lite')];
  const cat = document.querySelector('.pixel-cat');
  const bubble = cat?.querySelector('.cat-bubble');
  const terminalForm = document.querySelector('.terminal-input');
  const terminalInput = document.querySelector('#terminal-command');
  const terminalLog = document.querySelector('.terminal-log');
  const avatar = document.querySelector('.pixel-avatar');
  const avatarCaption = avatar?.querySelector('.avatar-caption');
  const experienceMap = document.querySelector('.experience-map');
  const mapCanvas = document.querySelector('.map-canvas');
  const mapExpand = document.querySelector('.map-expand');
  const mapNodes = [...document.querySelectorAll('.map-node')];
  const cursorTooltip = document.querySelector('.cursor-tooltip');
  const latencyValue = document.querySelector('[data-footer-id="latency-value"]');
  const serverTime = document.querySelector('[data-footer-id="server-time"]');
  const buildValue = document.querySelector('[data-footer-id="build-value"]');
  const mapSlot = document.createComment('experience-map-slot');
  experienceMap?.after(mapSlot);
  let mapPan = { x: 0, y: 0 };
  let mapDrag = null;
  const avatarMoods = [
    ['focus', 'UI + terminal mode'],
    ['ship', 'shipping clean UI'],
    ['debug', 'debugging mode'],
    ['coffee', 'coffee + deploy'],
  ];
  const terminalReplies = {
    help: 'commands: skills, stack, work, contact, clear',
    skills: 'ts, react, next, vue, nuxt, node, nest, php, postgres, docker',
    stack: 'full-stack core now; reliability, deploys, automation, and SRE next',
    work: 'madeindonesia, tomps by telkom, telkom indonesia, ugm fk-kmk',
    contact: 'email: hello@ilhamya.dev · github: ilhamyusuf27',
    docker: 'can read compose files, run containers, inspect logs, prepare handoff',
    cloudflare: 'portfolio target: cloudflare pages',
  };
  const catLines = {
    '.intro-panel': 'profile loaded ✦',
    '.profile-panel': 'hiring signal', 
    '.code-panel': 'terminal ready',
    '.work-panel': 'career route ready',
    '.toolbelt-panel': 'nice inventory',
    '.ops-panel': 'project archive ready',
    '.topbar': 'choose a path',
  };

  const revealItems = [...document.querySelectorAll('.home-reveal')];
  if ('IntersectionObserver' in window) {
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target.classList.add('is-visible');
        revealObserver.unobserve(entry.target);
      });
    }, { threshold: 0.14, rootMargin: '0px 0px -6% 0px' });
    revealItems.forEach((item, index) => {
      item.style.setProperty('--reveal-delay', `${Math.min(index * 65, 260)}ms`);
      revealObserver.observe(item);
    });
  } else {
    revealItems.forEach((item) => item.classList.add('is-visible'));
  }

  // home reveal timeout fallback: prevents invisible panels if page-transition global styles are stale
  window.setTimeout(() => {
    revealItems.forEach((item) => item.classList.add('is-visible'));
  }, 600);

  function updateFooterTelemetry() {
    if (latencyValue) {
      const nav = performance.getEntriesByType('navigation')[0];
      const fallback = performance.timing ? performance.timing.responseStart - performance.timing.requestStart : 86;
      const latency = Math.max(1, Math.round(nav?.responseStart || fallback || 86));
      latencyValue.textContent = `${latency}ms edge`;
    }
    if (buildValue) buildValue.textContent = document.lastModified ? `built ${new Date(document.lastModified).toLocaleDateString('en-GB')}` : 'Astro static';
  }

  function tickServerTime() {
    if (!serverTime) return;
    serverTime.textContent = new Intl.DateTimeFormat('en-GB', {
      timeZone: 'Asia/Jakarta', hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false,
    }).format(new Date()) + ' GMT+7';
  }

  updateFooterTelemetry();
  tickServerTime();
  setInterval(tickServerTime, 1000);

  function moveCatTo(target, mood = 'curious') {
    if (!cat || !target) return;
    if (target.matches?.('.intro-panel, .pixel-avatar, .work-panel')) {
      cat.style.setProperty('--cat-x', 'calc(100vw - 116px)');
      cat.style.setProperty('--cat-y', '76px');
      cat.dataset.mood = mood;
      return;
    }
    const rect = target.getBoundingClientRect();
    const x = Math.min(window.innerWidth - 120, Math.max(28, rect.right - 86));
    const y = Math.min(window.innerHeight - 116, Math.max(28, rect.top + rect.height * 0.5));
    cat.style.setProperty('--cat-x', `${x}px`);
    cat.style.setProperty('--cat-y', `${y}px`);
    cat.dataset.mood = mood;
  }

  function addTerminalLine(kind, text) {
    if (!terminalLog) return;
    const row = document.createElement('p');
    const token = document.createElement(kind === 'command' ? 'span' : 'i');
    token.textContent = kind === 'command' ? '$' : '[out]';
    row.append(token, document.createTextNode(` ${text}`));
    terminalLog.append(row);
    while (terminalLog.children.length > 14) terminalLog.firstElementChild?.remove();
  }

  function setMapPan(x, y) {
    mapPan = { x, y };
    experienceMap?.style.setProperty('--pan-x', `${x}px`);
    experienceMap?.style.setProperty('--pan-y', `${y}px`);
  }

  function positionCursorTooltip(event) {
    if (!cursorTooltip || cursorTooltip.hidden) return;
    const offset = 18;
    const rect = cursorTooltip.getBoundingClientRect();
    const x = Math.min(window.innerWidth - rect.width - 12, event.clientX + offset);
    const y = Math.min(window.innerHeight - rect.height - 12, event.clientY + offset);
    cursorTooltip.style.setProperty('--tip-x', `${Math.max(12, x)}px`);
    cursorTooltip.style.setProperty('--tip-y', `${Math.max(12, y)}px`);
  }

  mapNodes.forEach((node) => {
    node.addEventListener('pointerenter', (event) => {
      if (!cursorTooltip) return;
      const [meta, title, role, tech] = (node.dataset.tooltip || '').split('|');
      cursorTooltip.replaceChildren();
      for (const [tag, value] of [['b', meta], ['strong', title], ['em', role], ['small', tech]]) {
        const el = document.createElement(tag);
        el.textContent = value || '';
        cursorTooltip.append(el);
      }
      cursorTooltip.hidden = false;
      positionCursorTooltip(event);
    });
    node.addEventListener('pointermove', positionCursorTooltip);
    node.addEventListener('pointerleave', () => {
      if (cursorTooltip) cursorTooltip.hidden = true;
    });
  });

  mapExpand?.addEventListener('click', () => {
    const expanded = !experienceMap.classList.contains('is-expanded');
    const workPanel = experienceMap.closest('.panel');
    if (expanded) document.body.append(experienceMap);
    experienceMap.classList.toggle('is-expanded', expanded);
    if (!expanded) mapSlot.after(experienceMap);
    if (workPanel) workPanel.style.transform = expanded ? 'none' : '';
    mapExpand.setAttribute('aria-expanded', String(expanded));
    mapExpand.textContent = expanded ? 'Close map' : 'Expand map';
    if (!expanded) setMapPan(0, 0);
    if (bubble) bubble.textContent = expanded ? 'drag the map!' : 'map closed';
  });

  mapCanvas?.addEventListener('pointerdown', (event) => {
    if (!experienceMap?.classList.contains('is-expanded')) return;
    if (event.target.closest('a, button')) return;
    mapDrag = { startX: event.clientX, startY: event.clientY, x: mapPan.x, y: mapPan.y };
    experienceMap.classList.add('is-dragging');
    mapCanvas.setPointerCapture(event.pointerId);
  });

  mapCanvas?.addEventListener('pointermove', (event) => {
    if (!mapDrag) return;
    setMapPan(mapDrag.x + event.clientX - mapDrag.startX, mapDrag.y + event.clientY - mapDrag.startY);
  });

  mapCanvas?.addEventListener('pointerup', (event) => {
    mapDrag = null;
    experienceMap?.classList.remove('is-dragging');
    mapCanvas.releasePointerCapture?.(event.pointerId);
  });

  window.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && experienceMap?.classList.contains('is-expanded')) {
      experienceMap.classList.remove('is-expanded');
      mapSlot.after(experienceMap);
      experienceMap.closest('.panel')?.style.removeProperty('transform');
      mapExpand?.setAttribute('aria-expanded', 'false');
      if (mapExpand) mapExpand.textContent = 'Expand map';
      setMapPan(0, 0);
    }
  });

  terminalForm?.addEventListener('submit', (event) => {
    event.preventDefault();
    const command = (terminalInput?.value || '').trim().toLowerCase();
    if (!command) return;
    addTerminalLine('command', command);
    if (command === 'clear') {
      terminalLog.replaceChildren();
      addTerminalLine('output', 'terminal cleared · type help');
    } else {
      addTerminalLine('output', terminalReplies[command] || `command not found: ${command}`);
    }
    if (terminalInput) terminalInput.value = '';
    if (bubble) bubble.textContent = command === 'clear' ? 'clean slate' : 'command executed';
    moveCatTo(document.querySelector('.code-panel'), 'happy');
  });

  avatar?.addEventListener('click', () => {
    const current = avatar.dataset.avatarMood || 'focus';
    const index = avatarMoods.findIndex(([mood]) => mood === current);
    const [nextMood, nextText] = avatarMoods[(index + 1) % avatarMoods.length];
    avatar.dataset.avatarMood = nextMood;
    if (avatarCaption) avatarCaption.textContent = nextText;
    if (bubble) bubble.textContent = nextMood === 'debug' ? 'debug buddy!' : nextMood === 'ship' ? 'ship clean!' : 'that is Ilham';
  });

  avatar?.addEventListener('pointerenter', () => {
    if (avatarCaption) avatarCaption.textContent = 'click to change mode';
  });

  avatar?.addEventListener('pointermove', (event) => {
    const rect = avatar.getBoundingClientRect();
    const tx = ((event.clientX - rect.left) / rect.width - 0.5) * 5;
    const ty = ((event.clientY - rect.top) / rect.height - 0.5) * 4;
    avatar.style.setProperty('--avatar-tilt-x', `${tx}px`);
    avatar.style.setProperty('--avatar-tilt-y', `${ty}px`);
  });

  avatar?.addEventListener('pointerleave', () => {
    const mood = avatar.dataset.avatarMood || 'focus';
    const entry = avatarMoods.find(([key]) => key === mood);
    avatar.style.setProperty('--avatar-tilt-x', '0px');
    avatar.style.setProperty('--avatar-tilt-y', '0px');
    if (avatarCaption && entry) avatarCaption.textContent = entry[1];
  });

  window.addEventListener('pointermove', (event) => {
    const x = event.clientX;
    const y = event.clientY;
    root.style.setProperty('--mx', `${x}px`);
    root.style.setProperty('--my', `${y}px`);
    if (experienceMap?.classList.contains('is-expanded')) return;

    let active = null;
    for (const card of cards) {
      const rect = card.getBoundingClientRect();
      const inside = x >= rect.left && x <= rect.right && y >= rect.top && y <= rect.bottom;
      card.classList.toggle('is-hot', inside);
      if (inside) {
        active = card;
        const rx = ((x - rect.left) / rect.width - 0.5) * 7;
        const ry = ((y - rect.top) / rect.height - 0.5) * -7;
        card.style.setProperty('--rx', `${ry}deg`);
        card.style.setProperty('--ry', `${rx}deg`);
      }
    }

    if (active) {
      const key = Object.keys(catLines).find((selector) => active.matches(selector));
      if (bubble && key) bubble.textContent = catLines[key];
      moveCatTo(active, 'curious');
    }
  }, { passive: true });

  cat?.addEventListener('click', () => {
    const moods = ['idle', 'happy', 'sleepy', 'curious'];
    const next = moods[(moods.indexOf(cat.dataset.mood || 'idle') + 1) % moods.length];
    cat.dataset.mood = next;
    if (bubble) bubble.textContent = next === 'sleepy' ? 'zzz... still compiling' : next === 'happy' ? 'ready to deploy!' : 'nya~ hover a panel';
  });

  document.addEventListener('pointerdown', (event) => {
    const target = event.target.closest('a, button, .panel, .panel-lite');
    if (!target || target === cat || target === avatar) return;
    if (bubble) bubble.textContent = target.matches('a') ? 'opening route...' : 'selected!';
    moveCatTo(target, 'happy');
  });

  window.addEventListener('pointerleave', () => {
    for (const card of cards) card.classList.remove('is-hot');
    if (cat) cat.dataset.mood = 'idle';
  });
</script>

