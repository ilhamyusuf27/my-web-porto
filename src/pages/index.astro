---
import BaseLayout from "../components/layout/BaseLayout.astro";
import ScrollProgress from "../components/layout/ScrollProgress.astro";
import HudNav from "../components/layout/HudNav.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import AboutSection from "../components/sections/AboutSection.astro";
import SkillsSection from "../components/sections/SkillsSection.astro";
import ExperienceSection from "../components/sections/ExperienceSection.astro";
import ProjectsSection from "../components/sections/ProjectsSection.astro";
import ExperimentalSection from "../components/sections/ExperimentalSection.astro";
import EducationSection from "../components/sections/EducationSection.astro";
import ContactSection from "../components/sections/ContactSection.astro";
import ConsoleBackgroundScene from "../components/scene/ConsoleBackgroundScene.astro";
import { profile } from "../data/profile";
---

<BaseLayout
  title={`${profile.name} | Frontend Developer for Production Web Systems`}
  description="Frontend developer building maintainable interfaces, SaaS dashboards, customer portals, and content-led web systems with React, Vue, TypeScript, and WordPress."
>
  <ConsoleBackgroundScene slot="ambient" />
  <ScrollProgress slot="nav" />
  <HudNav slot="nav" />
  <HeroSection />
  <AboutSection />
  <SkillsSection />
  <ExperienceSection />
  <ProjectsSection />
  <ExperimentalSection />
  <EducationSection />
  <ContactSection />
</BaseLayout>

<script>
  import { initScrollAnimations } from "../scripts/scroll";

  // Reveal animations only matter once content is in the DOM.
  initScrollAnimations();

  const projects = document.getElementById("projects");
  let modalLoaded = false;
  const loadModal = async () => {
    if (modalLoaded) return;
    modalLoaded = true;
    const { initModal } = await import("../scripts/modal");
    initModal();
  };

  if (projects && "IntersectionObserver" in window) {
    const observer = new IntersectionObserver((entries) => {
      if (!entries.some((entry) => entry.isIntersecting)) return;
      observer.disconnect();
      void loadModal();
    }, { rootMargin: "1200px 0px" });
    observer.observe(projects);
  } else {
    window.setTimeout(() => void loadModal(), 0);
  }
</script>
