  .node-card b { color: var(--mauve); font-family: var(--mono); font-size: .52rem; text-transform: uppercase; }
  .node-card strong { color: var(--rosewater); font-size: .66rem; }
  .node-card em { color: var(--subtext1); font-size: .56rem; font-style: normal; }
  .node-card small { color: var(--teal); font-family: var(--mono); font-size: .5rem; }
  .experience-map:not(.is-expanded) .node-card small { display: none; }
