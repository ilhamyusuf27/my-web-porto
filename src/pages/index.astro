  .pixel-avatar[data-avatar-mood="coffee"] .avatar-mouth { width: 13px; background: var(--yellow); }
  .pixel-avatar:hover .avatar-body { animation-duration: 900ms; }
  .save-label { width: fit-content; display: flex; gap: .55rem; align-items: center; margin-bottom: .55rem; padding: .34rem .48rem; border: 1px solid var(--surface1); background: rgba(49,50,68,.42); font-family: var(--mono); font-size: .68rem; text-transform: uppercase; }
  .save-label span { color: var(--subtext0); }
  .save-label strong { color: var(--green); font-weight: 600; }

  .eyebrow, .section-head span { margin: 0; color: var(--mauve); font-family: var(--mono); font-size: .68rem; letter-spacing: .14em; text-transform: uppercase; }
  h1, h2, p, pre, dl, dd { margin: 0; }
  h1 { margin-top: .38rem; color: var(--rosewater); font-size: clamp(3rem, 5vw, 6rem); line-height: .86; letter-spacing: -.085em; }
  .headline { max-width: 18ch; margin-top: .45rem; color: var(--lavender); font-size: clamp(1.12rem, 1.48vw, 1.76rem); line-height: 1.02; letter-spacing: -.045em; text-wrap: balance; }
  .summary { max-width: 68ch; margin-top: .5rem; color: var(--subtext1); font-size: clamp(.84rem, .86vw, .98rem); line-height: 1.34; }
  .actions { flex-wrap: wrap; gap: .55rem; margin-top: .68rem; }

  .button { min-height: 34px; display: inline-flex; align-items: center; padding: 0 .78rem; border: 1px solid var(--border); font-family: var(--mono); font-size: .72rem; text-decoration: none; transition: transform 160ms ease, border-color 160ms ease, background 160ms ease; }
  .button:hover { transform: translate(-2px, -2px); }
  .button.primary { background: var(--mauve); color: var(--crust); border-color: var(--mauve); box-shadow: 4px 4px 0 rgba(137,180,250,.35); }
  .button.secondary { color: var(--subtext1); background: rgba(49,50,68,.46); }

  .section-head { display: flex; align-items: baseline; gap: .58rem; margin-bottom: .56rem; position: relative; z-index: 1; }
  h2 { color: var(--text); font-size: .92rem; letter-spacing: -.02em; }

  .status-list, .toolbelt-list { display: grid; gap: .28rem; position: relative; z-index: 1; }
  .status-list div, .toolbelt-list div { display: grid; grid-template-columns: 86px 1fr; gap: .58rem; padding: .28rem .44rem; border: 1px solid var(--surface1); background: rgba(49,50,68,.36); }
  dt { color: var(--subtext0); font-family: var(--mono); font-size: .66rem; text-transform: uppercase; }
  dd { color: var(--rosewater); font-size: .76rem; }

  .stat-bars { display: grid; gap: .28rem; margin-top: .5rem; position: relative; z-index: 1; }
  .stat-row { display: grid; grid-template-columns: 82px 40px 1fr; align-items: center; gap: .45rem; font-family: var(--mono); font-size: .64rem; color: var(--subtext0); }
  .stat-row strong { color: var(--sky); font-weight: 500; }
  .stat-row i { height: 6px; border: 1px solid var(--surface1); background: linear-gradient(90deg, var(--teal) var(--value), rgba(49,50,68,.75) var(--value)); }

  .code-panel { display: grid; grid-template-rows: auto auto 1fr auto; padding: 0; background: rgba(17,17,27,.78); }
  .window-dots { display: flex; gap: .42rem; padding: .6rem; border-bottom: 1px solid var(--surface1); }
  .window-dots span { width: .52rem; height: .52rem; background: var(--red); }
  .window-dots span:nth-child(2) { background: var(--yellow); }
  .window-dots span:nth-child(3) { background: var(--green); }
  .terminal-title { display: flex; justify-content: space-between; gap: .75rem; padding: .46rem .72rem; border-bottom: 1px solid var(--surface1); font-family: var(--mono); font-size: .68rem; position: relative; z-index: 1; }
  .terminal-title span { color: var(--blue); }
  .terminal-title strong { color: var(--teal); font-weight: 500; text-transform: uppercase; letter-spacing: .12em; }
  .terminal-log { display: grid; align-content: center; gap: .16rem; padding: .46rem .72rem; color: var(--subtext1); font-family: var(--mono); font-size: clamp(.58rem, .62vw, .72rem); line-height: 1.12; position: relative; z-index: 1; overflow: hidden; }
  .terminal-log p { display: flex; gap: .45rem; align-items: baseline; min-width: 0; }
  .terminal-log span { color: var(--green); }
  .terminal-log i { color: var(--mauve); font-style: normal; }
  .terminal-log p:nth-child(2n) { padding-left: .9rem; color: var(--overlay2); }
  .terminal-input { display: grid; grid-template-columns: auto 1fr auto; gap: .35rem; align-items: center; padding: .34rem .72rem; border-top: 1px solid var(--surface1); font-family: var(--mono); position: relative; z-index: 2; }
  .terminal-input label { color: var(--green); font-size: .7rem; }
  .terminal-input input { min-width: 0; border: 1px solid var(--surface1); background: rgba(17,17,27,.62); color: var(--text); padding: .28rem .4rem; font: inherit; font-size: .66rem; outline: none; }
  .terminal-input input:focus { border-color: var(--mauve); box-shadow: 0 0 0 2px rgba(203,166,247,.12); }
  .terminal-input button { border: 1px solid var(--mauve); background: rgba(203,166,247,.18); color: var(--rosewater); padding: .28rem .42rem; font: inherit; font-size: .62rem; text-transform: uppercase; cursor: pointer; }
  .terminal-input button:hover { background: var(--mauve); color: var(--crust); }
  .terminal-capability { display: flex; justify-content: space-between; gap: .6rem; padding: .34rem .72rem; border-top: 1px solid var(--surface1); background: rgba(49,50,68,.42); font-family: var(--mono); font-size: .58rem; position: relative; z-index: 1; }
  .terminal-capability b { color: var(--yellow); text-transform: uppercase; font-weight: 500; }
  .terminal-capability span { color: var(--rosewater); text-align: right; }

  .experience-map {
    --pan-x: 0px;
    --pan-y: 0px;
    --map-scale: 1;
    position: relative;
    z-index: 1;
    min-height: 0;
    height: 100%;
    overflow: hidden;
    border: 1px solid var(--surface1);
    background:
      radial-gradient(circle at 22% 20%, rgba(203,166,247,.18), transparent 28%),
      radial-gradient(circle at 80% 70%, rgba(137,220,235,.14), transparent 26%),
      linear-gradient(135deg, rgba(49,50,68,.85), rgba(24,24,37,.88));
    box-shadow: inset 0 0 0 2px rgba(180,190,254,.08), 4px 4px 0 rgba(17,17,27,.5);
  }

  .work-panel { display: grid; grid-template-rows: auto minmax(0, 1fr); }
  .work-panel:has(.experience-map.is-expanded) { overflow: visible; z-index: 100; transform: none !important; }

  .experience-map.is-expanded {
    position: fixed;
    inset: clamp(1rem, 4vw, 3rem);
    z-index: 90;
    height: auto;
    min-height: 0;
    border-color: var(--mauve);
    box-shadow: 0 0 0 999px rgba(17,17,27,.72), 0 0 40px rgba(203,166,247,.25);
    --map-scale: 1.35;
  }

  .experience-map::before {
    content: "";
    position: absolute;
    inset: 7px;
    border: 1px dashed rgba(180,190,254,.28);
    pointer-events: none;
    z-index: 3;
  }

  .map-toolbar {
    position: absolute;
    inset: 7px 8px auto 8px;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .6rem;
    pointer-events: none;
  }

  .map-banner {
    padding: .22rem .82rem .28rem;
    background: linear-gradient(135deg, rgba(203,166,247,.95), rgba(137,180,250,.92));
    color: var(--crust);
    border: 1px solid var(--mauve);
    box-shadow: 2px 2px 0 rgba(17,17,27,.5);
    font-family: var(--mono);
    font-size: .62rem;
    font-weight: 700;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .map-expand {
    pointer-events: auto;
    border: 1px solid var(--surface2);
    background: rgba(17,17,27,.72);
    color: var(--teal);
    padding: .25rem .46rem;
    font-family: var(--mono);
    font-size: .58rem;
    text-transform: uppercase;
    cursor: pointer;
  }

  .map-expand:hover { border-color: var(--teal); color: var(--crust); background: var(--teal); }

  .map-canvas {
    position: absolute;
    inset: 0;
    transform: translate(var(--pan-x), var(--pan-y)) scale(var(--map-scale));
    transform-origin: center;
    cursor: grab;
    touch-action: none;
  }

  .experience-map.is-expanded .map-canvas { cursor: grab; }
  .experience-map.is-dragging .map-canvas { cursor: grabbing; }

  .map-art span { position: absolute; display: block; }
  .mountains {
    left: 5%; top: 18%; width: 42%; height: 44%;
    background: linear-gradient(135deg, transparent 0 47%, rgba(180,190,254,.22) 48% 52%, transparent 53%), linear-gradient(45deg, transparent 0 46%, rgba(245,224,220,.18) 47% 53%, transparent 54%);
    clip-path: polygon(0 100%, 16% 28%, 28% 86%, 42% 18%, 56% 88%, 72% 34%, 100% 100%);
    opacity: .82;
  }
  .river {
    left: 8%; bottom: 3%; width: 70%; height: 55%;
    border-left: 2px dashed rgba(137,180,250,.4);
    border-bottom: 2px dashed rgba(137,180,250,.4);
    transform: skewX(-18deg) rotate(-8deg);
    opacity: .8;
  }
  .trail-line {
    left: 48%; top: 20%; width: 16%; height: 65%;
    border-left: 3px dotted rgba(203,166,247,.72);
    transform: rotate(-5deg);
  }
  .village { width: 34px; height: 26px; background: rgba(203,166,247,.24); clip-path: polygon(0 46%, 50% 0, 100% 46%, 100% 100%, 0 100%); }
  .village-a { left: 10%; bottom: 16%; }
  .village-b { right: 10%; bottom: 24%; transform: scale(.85); }
  .trees-a, .trees-b { width: 42px; height: 38px; background: rgba(166,227,161,.22); clip-path: polygon(10% 100%, 24% 54%, 0 54%, 34% 12%, 68% 54%, 44% 54%, 58% 100%, 76% 100%, 86% 58%, 70% 58%, 100% 24%, 100% 100%); }
  .trees-a { right: 14%; top: 18%; }
  .trees-b { left: 18%; top: 48%; transform: scale(.75); }

  .map-node {
    position: absolute;
    left: var(--x);
    top: var(--y);
    z-index: 5;
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: .38rem;
    color: var(--text);
    transform: translate(-50%, -50%);
