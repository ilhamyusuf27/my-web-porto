    max-width: 180px;
    padding: .34rem .48rem;
    border: 1px solid var(--mauve);
    background: rgba(17,17,27,.92);
    color: var(--rosewater);
    font-family: var(--mono);
    font-size: .62rem;
    text-transform: uppercase;
    box-shadow: 3px 3px 0 rgba(203,166,247,.18);
