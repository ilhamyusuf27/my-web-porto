  .node-card {
    display: grid;
    min-width: 140px;
    padding: .2rem .34rem;
    border: 1px solid rgba(180,190,254,.42);
    background: rgba(17,17,27,.78);
    box-shadow: 2px 2px 0 rgba(17,17,27,.32);
    line-height: 1.05;
