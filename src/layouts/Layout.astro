---
import { ViewTransitions } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  lang?: string;
}

const siteName = "Ilham Yusuf Portfolio";
const defaultTitle = "Ilham Yusuf — Full-Stack Developer";
const defaultDescription = "Ilham Yusuf is a full-stack developer in Indonesia building reliable web products, dashboards, and portfolio case studies while moving toward SRE.";
const {
  title = defaultTitle,
  description = defaultDescription,
  image = "/ilham-avatar.webp",
  canonical,
  lang = "en",
} = Astro.props;
const pageTitle = title.includes("Ilham Yusuf") ? title : `${title} — Ilham Yusuf`;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const imageUrl = new URL(image, Astro.site ?? Astro.url).toString();
const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Ilham Yusuf Alghani",
  url: new URL("/", Astro.site ?? Astro.url).toString(),
  jobTitle: "Full-Stack Developer",
  address: { "@type": "PostalAddress", addressCountry: "ID" },
  sameAs: [
    "https://github.com/ilhamyusuf27",
    "https://www.linkedin.com/in/ilhamyusufalghani/",
  ],
  knowsAbout: ["React", "Next.js", "Nuxt", "Node.js", "SRE", "Docker", "Cloudflare"],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <ViewTransitions />
    <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
  </head>
  <body>
    <slot />
  </body>
</html>
